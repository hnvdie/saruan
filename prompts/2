### Ornamen & Dekorasi (harus ada SVG/Canvas dalam scene):

Ornamen TIDAK boleh flat — harus punya kedalaman dan posisi Z:

```html
<!-- Ornamen di layer jauh — terlihat kecil dan sedikit blur karena Z depth -->
<div class="layer-mid-far">
  <svg class="ornament-far" style="transform: translateZ(0); opacity: 0.4;">
    <!-- Bunga, rangkaian daun, geometrik, batik, dll — sesuai tema -->
  </svg>
</div>

<!-- Ornamen di layer tengah — lebih besar, lebih jelas -->
<div class="layer-mid">
  <svg class="ornament-wreath" style="filter: none;">
    <!-- Bingkai melingkar / mahkota bunga / frame ornamental -->
  </svg>
</div>

<!-- Elemen terdepan — terlihat "melayang di depan" nama pasangan -->
<div class="layer-front">
  <div class="floating-petal" style="transform: translateZ(80px);">🌸</div>
</div>
```

### Partikel 3D di Canvas:

```javascript
// Partikel bergerak dalam ruang 3D nyata — bukan hanya X/Y
const particles = Array.from({ length: 80 }, () => ({
  x: Math.random() * W,
  y: Math.random() * H,
  z: Math.random() * 600 - 300,  // Z dari -300 sampai +300
  vx: (Math.random() - 0.5) * 0.3,
  vy: (Math.random() - 0.5) * 0.3,
  vz: (Math.random() - 0.5) * 0.5,
  size: Math.random() * 3 + 1,
}));

function drawParticles() {
  particles.forEach(p => {
    // Proyeksi perspektif: elemen yang lebih jauh (Z rendah) terlihat lebih kecil
    const fov = 500;
    const scale = fov / (fov - p.z);
    const screenX = (p.x - W/2) * scale + W/2;
    const screenY = (p.y - H/2) * scale + H/2;
    const alpha = Math.max(0, Math.min(1, (p.z + 300) / 600));
    
    ctx.globalAlpha = alpha * 0.7;
    ctx.fillStyle = primaryColor;
    ctx.beginPath();
    ctx.arc(screenX, screenY, p.size * scale, 0, Math.PI * 2);
    ctx.fill();
    
    // Update posisi Z
    p.z += p.vz;
    if (p.z > 300) p.z = -300;
    if (p.z < -300) p.z = 300;
  });
}
```

