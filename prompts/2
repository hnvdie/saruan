## BAGIAN 1 — TEKNIK 3D SCENE WAJIB DIIMPLEMENTASIKAN
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

### A. CSS 3D Stage Setup (WAJIB)

```css
/* Container utama — ini adalah "kamera" yang melihat ke scene */
.stage {
  perspective: 900px;
  perspective-origin: 50% 40%; /* titik pandang sedikit di atas tengah */
  overflow: hidden;
  width: 100vw;
  height: 100vh;
}

/* Scene 3D — ini adalah "dunia" yang bisa diputar */
.scene {
  transform-style: preserve-3d;
  width: 100%;
  height: 100%;
  position: relative;
  /* Digerakkan oleh mouse dan scroll */
  transition: transform 0.1s ease-out;
}

/* Setiap layer di kedalaman berbeda */
.layer-bg     { transform: translateZ(-500px) scale(1.6); }
.layer-mid-far{ transform: translateZ(-280px) scale(1.3); }
.layer-mid    { transform: translateZ(-120px) scale(1.15); }
.layer-near   { transform: translateZ(0px); }
.layer-front  { transform: translateZ(80px); }
.layer-closest{ transform: translateZ(160px); }

/* Semua elemen dalam scene harus preserve-3d */
.layer-bg, .layer-mid-far, .layer-mid, .layer-near, .layer-front {
  transform-style: preserve-3d;
  position: absolute;
  width: 100%;
  height: 100%;
}
```

### B. Mouse = Camera Tilt (WAJIB)

```javascript
// Saat mouse bergerak, SELURUH scene miring seperti kanvas 3D dipegang tangan
document.addEventListener('mousemove', (e) => {
  const cx = window.innerWidth / 2;
  const cy = window.innerHeight / 2;
  const dx = (e.clientX - cx) / cx; // -1 sampai 1
  const dy = (e.clientY - cy) / cy; // -1 sampai 1
  
  // Rotasi scene terasa seperti "mengintip dari sudut berbeda"
  const rotX = dy * -8;   // max 8 derajat rotasi X
  const rotY = dx * 12;   // max 12 derajat rotasi Y
  
  scene.style.transform = `rotateX(${rotX}deg) rotateY(${rotY}deg)`;
});

// Smooth dengan lerp untuk feel yang halus
let currentRotX = 0, currentRotY = 0;
let targetRotX = 0, targetRotY = 0;

function lerp(a, b, t) { return a + (b - a) * t; }

function updateScene() {
  currentRotX = lerp(currentRotX, targetRotX, 0.06);
  currentRotY = lerp(currentRotY, targetRotY, 0.06);
  scene.style.transform = `rotateX(${currentRotX}deg) rotateY(${currentRotY}deg)`;
  requestAnimationFrame(updateScene);
}
updateScene();
```

### C. Scroll = Perjalanan Menembus Ruang (WAJIB)

```javascript
// Scroll BUKAN geser halaman — tapi "terbang masuk" ke scene berikutnya
// Gunakan GSAP ScrollTrigger untuk drive translateZ pada camera/stage

gsap.to(".scene", {
  scrollTrigger: {
    trigger: ".main-wrapper",
    start: "top top",
    end: "bottom bottom",
    scrub: 1.5
  },
  // "Kamera" bergerak maju menembus Z-space
  z: 400,  // Kamera maju 400px sepanjang scroll
  ease: "none"
});

// Atau: tiap section punya "scene sendiri" yang reveal dengan translateZ
gsap.from(".section-scene", {
  scrollTrigger: { trigger: ".section-scene", start: "top 80%", scrub: 1 },
  z: -200,
  opacity: 0,
  rotateX: 15,
  transformOrigin: "center top"
});
```

