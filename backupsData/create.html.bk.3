<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Buat Undangan — Admin</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--gold:#c9a84c;--border:#e8e8e4;--bg:#f7f7f5;--red:#e53935;}
body{font-family:'DM Sans',sans-serif;font-weight:300;background:var(--bg);color:#1a1a1a;}
.header{background:#fff;border-bottom:1px solid var(--border);padding:.9rem 1.5rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;}
.logo{font-size:1rem;font-weight:500;text-decoration:none;color:#1a1a1a;}
.logo span{color:var(--gold);}
.back{font-size:.78rem;color:#888;text-decoration:none;}
.back:hover{color:#1a1a1a;}
.container{max-width:680px;margin:0 auto;padding:1.5rem;}
.page-title{font-size:1.3rem;font-weight:400;margin-bottom:.3rem;}
.page-sub{font-size:.78rem;color:#888;margin-bottom:1.75rem;}
.card{background:#fff;border:1px solid var(--border);border-radius:6px;padding:1.5rem;margin-bottom:1.25rem;}
.card-title{font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;color:#888;font-weight:400;margin-bottom:1.25rem;padding-bottom:.75rem;border-bottom:1px solid var(--border);}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
.form-group{margin-bottom:1rem;}
.form-group label{display:block;font-size:.68rem;letter-spacing:.08em;text-transform:uppercase;color:#888;margin-bottom:.35rem;}
.form-input{width:100%;padding:.72rem .9rem;border:1px solid #e0e0e0;border-radius:4px;font-family:'DM Sans',sans-serif;font-size:.85rem;font-weight:300;color:#1a1a1a;outline:none;transition:border .2s;background:#fff;}
.form-input:focus{border-color:var(--gold);}
textarea.form-input{resize:vertical;min-height:80px;}
.helper{font-size:.68rem;color:#bbb;margin-top:.25rem;line-height:1.4;}
.error{background:#fff3f3;border:1px solid #ffd5d5;color:#c62828;padding:.75rem 1rem;border-radius:4px;font-size:.82rem;margin-bottom:1.25rem;}

/* ── THEME SEARCH PICKER ── */
.theme-search-wrap{position:relative;margin-bottom:.6rem;}
.theme-search-input{width:100%;padding:.72rem .9rem .72rem 2.2rem;border:1px solid #e0e0e0;border-radius:4px;font-family:'DM Sans',sans-serif;font-size:.85rem;font-weight:300;color:#1a1a1a;outline:none;transition:border .2s;background:#fff;}
.theme-search-input:focus{border-color:var(--gold);}
.theme-search-icon{position:absolute;left:.75rem;top:50%;transform:translateY(-50%);font-size:.8rem;color:#bbb;pointer-events:none;}
.theme-results{display:none;position:absolute;top:calc(100% + 4px);left:0;right:0;background:#fff;border:1px solid var(--border);border-radius:6px;box-shadow:0 8px 24px rgba(0,0,0,.09);max-height:300px;overflow-y:auto;z-index:50;}
.theme-results.open{display:block;}
.tr-item{display:flex;align-items:center;gap:.75rem;padding:.6rem .85rem;cursor:pointer;border-bottom:1px solid var(--border);transition:background .1s;}
.tr-item:last-child{border-bottom:none;}
.tr-item:hover,.tr-item.focused{background:var(--bg);}
.tr-swatch{width:36px;height:36px;border-radius:4px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.75rem;font-style:italic;}
.tr-info{flex:1;min-width:0;}
.tr-name{font-size:.82rem;font-weight:400;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.tr-tags{font-size:.64rem;color:#aaa;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.tr-price{font-size:.7rem;color:var(--gold);flex-shrink:0;}
.theme-selected{display:none;align-items:center;gap:.85rem;padding:.75rem 1rem;background:var(--bg);border:1px solid var(--border);border-radius:6px;margin-top:.4rem;}
.theme-selected.show{display:flex;}
.ts-swatch{width:44px;height:44px;border-radius:4px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.8rem;font-style:italic;overflow:hidden;}
.ts-info{flex:1;}
.ts-name{font-size:.88rem;font-weight:400;}
.ts-id{font-size:.68rem;color:#aaa;font-family:monospace;}
.ts-clear{font-size:.7rem;color:#aaa;cursor:pointer;padding:.25rem .5rem;border-radius:3px;transition:all .12s;white-space:nowrap;}
.ts-clear:hover{color:var(--red);}
.no-results{padding:1rem;text-align:center;font-size:.78rem;color:#aaa;}

/* ── PHOTO UPLOAD ── */
.photo-upload-zone{border:2px dashed #ddd;border-radius:6px;padding:1.5rem;text-align:center;cursor:pointer;transition:all .2s;position:relative;}
.photo-upload-zone:hover,.photo-upload-zone.dragover{border-color:var(--gold);background:#fffdf5;}
.photo-upload-zone input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.puz-icon{font-size:1.5rem;margin-bottom:.3rem;}
.puz-text{font-size:.78rem;color:#888;}
.puz-sub{font-size:.68rem;color:#bbb;margin-top:.2rem;}
.photo-preview-row{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.75rem;}
.photo-thumb{width:60px;height:60px;object-fit:cover;border-radius:4px;border:1px solid var(--border);}
.portrait-zone{border:2px dashed #ddd;border-radius:6px;padding:.9rem;text-align:center;cursor:pointer;transition:all .2s;position:relative;}
.portrait-zone:hover{border-color:var(--gold);background:#fffdf5;}
.portrait-zone input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.portrait-preview{display:none;width:60px;height:72px;object-fit:cover;border-radius:4px;border:1px solid var(--border);margin-top:.5rem;}

/* URL PHOTOS */
.url-row{display:flex;gap:.5rem;align-items:center;margin-bottom:.5rem;}
.url-row input{flex:1;}
.add-url-btn{padding:.5rem .85rem;background:transparent;border:1px solid #ddd;border-radius:4px;font-size:.75rem;cursor:pointer;color:#666;white-space:nowrap;}
.add-url-btn:hover{border-color:var(--gold);color:var(--gold);}

/* SUBMIT */
.submit-area{display:flex;gap:.75rem;justify-content:flex-end;padding-top:.5rem;}
.btn{display:inline-flex;align-items:center;gap:.3rem;padding:.65rem 1.4rem;border-radius:4px;font-size:.8rem;font-family:'DM Sans',sans-serif;cursor:pointer;border:1px solid transparent;transition:all .15s;text-decoration:none;}
.btn-primary{background:#1a1a1a;color:#fff;border-color:#1a1a1a;}
.btn-primary:hover{background:#333;}
.btn-ghost{background:transparent;border-color:#ddd;color:#666;}
.btn-ghost:hover{border-color:#aaa;}
@media(max-width:480px){.form-row{grid-template-columns:1fr;}}
</style>
</head>
<body>
<div class="header">
  <a href="/admin" class="logo">Undangan<span>Kita</span></a>
  <a href="/admin" class="back">← Dashboard</a>
</div>

<div class="container">
  <div class="page-title">Buat Undangan Baru</div>
  <p class="page-sub">Isi semua informasi pernikahan di bawah ini</p>

  {% if error %}<div class="error">⚠️ {{ error }}</div>{% endif %}

  <form method="post" enctype="multipart/form-data" id="mainForm">

    <!-- TEMA -->
    <div class="card">
      <div class="card-title">Pilih Tema</div>
      <input type="hidden" name="theme_id" id="theme_id_input" value="{{ form.get('theme_id', themes[0].id if themes else '') }}">
      <div class="theme-search-wrap">
        <span class="theme-search-icon">⌕</span>
        <input type="text" class="theme-search-input" id="themeSearch"
               placeholder="Cari nama atau tag tema... (mis: romantic, floral, modern)" autocomplete="off">
        <div class="theme-results" id="themeResults"></div>
      </div>
      <div class="theme-selected" id="themeSelected">
        <div class="ts-swatch" id="tsSwatchEl"></div>
        <div class="ts-info">
          <div class="ts-name" id="tsNameEl">—</div>
          <div class="ts-id" id="tsIdEl"></div>
        </div>
        <span class="ts-clear" onclick="clearTheme()">✕ Ganti tema</span>
      </div>
      <p style="margin-top:.6rem"><a href="/themes" target="_blank" style="font-size:.73rem;color:var(--gold);">Lihat semua tema →</a></p>
    </div>

    <!-- IDENTITAS -->
    <div class="card">
      <div class="card-title">Identitas Pasangan & URL</div>
      <div class="form-row">
        <div class="form-group">
          <label>Nama Panggilan Pria *</label>
          <input class="form-input" type="text" name="groom_name" value="{{ form.get('groom_name','') }}" required placeholder="Rizky">
        </div>
        <div class="form-group">
          <label>Nama Panggilan Wanita *</label>
          <input class="form-input" type="text" name="bride_name" value="{{ form.get('bride_name','') }}" required placeholder="Amara">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Nama Lengkap Pria</label>
          <input class="form-input" type="text" name="groom_full" value="{{ form.get('groom_full','') }}" placeholder="Beserta gelar">
        </div>
        <div class="form-group">
          <label>Nama Lengkap Wanita</label>
          <input class="form-input" type="text" name="bride_full" value="{{ form.get('bride_full','') }}" placeholder="Beserta gelar">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Orang Tua Pria</label>
          <input class="form-input" type="text" name="groom_parents" value="{{ form.get('groom_parents','') }}" placeholder="Bapak ... & Ibu ...">
        </div>
        <div class="form-group">
          <label>Orang Tua Wanita</label>
          <input class="form-input" type="text" name="bride_parents" value="{{ form.get('bride_parents','') }}" placeholder="Bapak ... & Ibu ...">
        </div>
      </div>
      <div class="form-group" style="display:flex;align-items:center;gap:.75rem">
        <input type="checkbox" name="show_parents" id="show_parents" value="1" checked style="width:16px;height:16px;accent-color:var(--gold)">
        <label for="show_parents" style="font-size:.78rem;color:#555;text-transform:none;letter-spacing:0;cursor:pointer">Tampilkan nama orang tua di undangan</label>
      </div>
      <div class="form-group">
        <label>Slug URL *</label>
        <input class="form-input" type="text" name="slug" value="{{ form.get('slug','') }}" required placeholder="rizky-amara-2025">
        <div class="helper">Link undangan: undangankita.com/i/<strong>[slug]</strong> — huruf kecil, angka, tanda strip saja</div>
      </div>
    </div>

    <!-- FOTO PROFIL MEMPELAI -->
    <div class="card">
      <div class="card-title">Foto Profil Mempelai <span style="font-weight:300;color:#bbb;text-transform:none;letter-spacing:0">(opsional — untuk kartu profil di tema)</span></div>
      <div class="form-row">
        <div class="form-group">
          <label>Foto Mempelai Pria</label>
          <div class="portrait-zone">
            <input type="file" name="groom_photo" accept=".jpg,.jpeg,.png,.webp" onchange="previewPortrait(this,'prev-groom')">
            <div class="puz-text" style="font-size:.72rem">📷 Upload foto pria</div>
            <div class="puz-sub">JPG/PNG/WebP · maks 5MB</div>
          </div>
          <img id="prev-groom" class="portrait-preview" src="#" alt="">
          <div class="helper">Jika tidak diupload, tema pakai foto gallery sebagai fallback.</div>
        </div>
        <div class="form-group">
          <label>Foto Mempelai Wanita</label>
          <div class="portrait-zone">
            <input type="file" name="bride_photo" accept=".jpg,.jpeg,.png,.webp" onchange="previewPortrait(this,'prev-bride')">
            <div class="puz-text" style="font-size:.72rem">📷 Upload foto wanita</div>
            <div class="puz-sub">JPG/PNG/WebP · maks 5MB</div>
          </div>
          <img id="prev-bride" class="portrait-preview" src="#" alt="">
          <div class="helper">Jika tidak diupload, tema pakai foto gallery sebagai fallback.</div>
        </div>
      </div>
    </div>

    <!-- AKAD -->
    <div class="card">
      <div class="card-title">Akad Nikah</div>
      <div class="form-row">
        <div class="form-group"><label>Tanggal</label><input class="form-input" type="date" name="akad_date" value="{{ form.get('akad_date','') }}"></div>
        <div class="form-group"><label>Waktu</label><input class="form-input" type="time" name="akad_time" value="{{ form.get('akad_time','') }}"></div>
      </div>
      <div class="form-group"><label>Nama Venue</label><input class="form-input" type="text" name="akad_venue" value="{{ form.get('akad_venue','') }}" placeholder="Masjid Al-Ikhlas"></div>
      <div class="form-group"><label>Alamat</label><input class="form-input" type="text" name="akad_address" value="{{ form.get('akad_address','') }}" placeholder="Jl. ..."></div>
    </div>

    <!-- RESEPSI -->
    <div class="card">
      <div class="card-title">Resepsi Pernikahan</div>
      <div class="form-row">
        <div class="form-group"><label>Tanggal</label><input class="form-input" type="date" name="resepsi_date" value="{{ form.get('resepsi_date','') }}"></div>
        <div class="form-group"><label>Waktu</label><input class="form-input" type="time" name="resepsi_time" value="{{ form.get('resepsi_time','') }}"></div>
      </div>
      <div class="form-group"><label>Nama Venue</label><input class="form-input" type="text" name="resepsi_venue" value="{{ form.get('resepsi_venue','') }}" placeholder="Grand Ballroom Hotel ..."></div>
      <div class="form-group"><label>Alamat</label><input class="form-input" type="text" name="resepsi_address" value="{{ form.get('resepsi_address','') }}" placeholder="Jl. ..."></div>
      <div class="form-group"><label>Link Google Maps</label><input class="form-input" type="url" name="maps_url" value="{{ form.get('maps_url','') }}" placeholder="https://maps.google.com/..."></div>
      <div class="form-group">
        <label>Maps Embed URL <span style="color:#bbb;font-weight:300">(opsional — auto-generate dari link di atas)</span></label>
        <input class="form-input" type="text" name="maps_embed" value="{{ form.get('maps_embed','') }}" placeholder="Kosongkan untuk auto-generate">
        <div class="helper">Jika diisi, peta tampil langsung di halaman undangan.</div>
      </div>
    </div>

    <!-- FOTO PREWED / GALLERY -->
    <div class="card">
      <div class="card-title">Foto Prewed — Gallery (maks 10 foto, 5MB/foto)</div>
      <div class="photo-upload-zone" id="galleryZone">
        <input type="file" name="photos" accept=".jpg,.jpeg,.png,.webp" multiple id="galleryFiles" onchange="previewGallery(this)">
        <div class="puz-icon">📸</div>
        <div class="puz-text">Klik atau seret beberapa foto sekaligus</div>
        <div class="puz-sub">JPG, PNG, WebP — maks 5MB per foto • bisa pilih banyak sekaligus</div>
      </div>
      <div class="photo-preview-row" id="galleryPreview"></div>
      <div style="margin-top:1.25rem">
        <div class="card-title" style="margin-top:0">Atau Masukkan URL Foto (Google Drive, dll)</div>
        <div class="helper" style="margin-bottom:.75rem">Untuk Google Drive: ubah link ke format <code>https://drive.google.com/uc?id=FILE_ID</code></div>
        <div id="url-fields">
          <div class="url-row"><input class="form-input" type="url" name="photo_url_0" placeholder="https://..."></div>
        </div>
        <button type="button" class="add-url-btn" onclick="addUrlField()">+ Tambah URL foto</button>
      </div>
    </div>

    <!-- KONTEN -->
    <div class="card">
      <div class="card-title">Konten Undangan</div>
      <div class="form-group">
        <label>Kisah Cinta (Love Story)</label>
        <textarea class="form-input" name="love_story" placeholder="Ceritakan bagaimana kalian bertemu...">{{ form.get('love_story','') }}</textarea>
      </div>
      <div class="form-group">
        <label>URL Musik Latar (MP3)</label>
        <input class="form-input" type="url" name="music_url" value="{{ form.get('music_url','') }}" placeholder="https://... (opsional)">
        <div class="helper">Link langsung ke file MP3. Google Drive: ubah ke format uc?id=...</div>
      </div>
    </div>

    <!-- MASA AKTIF -->
    <div class="card">
      <div class="card-title">Masa Aktif Undangan</div>
      <div class="form-group">
        <label>Tanggal Kadaluarsa</label>
        <input class="form-input" type="date" name="expires_at" value="{{ form.get('expires_at','') }}">
        <div class="helper">Kosongkan = otomatis +1 tahun dari tanggal resepsi.</div>
      </div>
    </div>

    <!-- REKENING -->
    <div class="card">
      <div class="card-title">Rekening Hadiah (Opsional)</div>
      <div class="form-row">
        <div class="form-group"><label>Nama Bank</label><input class="form-input" type="text" name="bank_name" value="{{ form.get('bank_name','') }}" placeholder="BCA / BNI / Mandiri"></div>
        <div class="form-group"><label>Nomor Rekening</label><input class="form-input" type="text" name="account_number" value="{{ form.get('account_number','') }}"></div>
      </div>
      <div class="form-group"><label>Nama Pemilik Rekening</label><input class="form-input" type="text" name="account_name" value="{{ form.get('account_name','') }}"></div>
    </div>

    <div class="submit-area">
      <a href="/admin" class="btn btn-ghost">Batal</a>
      <button type="submit" class="btn btn-primary">Simpan & Buat Undangan →</button>
    </div>
  </form>
</div>

<script>
// ── THEME DATA dari Jinja ──
const THEMES = [
  {% for t in themes %}
  {id:{{ t.id|tojson }},name:{{ t.name|tojson }},preview_color:{{ t.preview_color|tojson }},accent_color:{{ t.accent_color|tojson }},tags:{{ (t.tags or [])|tojson }},price_label:{{ (t.price_label or '')|tojson }},demo_photo:{{ ((t.demo_photos or [None])[0])|tojson }}}{% if not loop.last %},{% endif %}
  {% endfor %}
];

// ── THEME SEARCH PICKER ──
const searchInput = document.getElementById('themeSearch');
const resultsBox  = document.getElementById('themeResults');
const hiddenInput = document.getElementById('theme_id_input');
const selectedBox = document.getElementById('themeSelected');
const tsSwatchEl  = document.getElementById('tsSwatchEl');
const tsNameEl    = document.getElementById('tsNameEl');
const tsIdEl      = document.getElementById('tsIdEl');
let focusedIdx = -1;
let filteredList = [];

// Pre-select if value already set (form repopulation on error)
const initId = hiddenInput.value;
if (initId) { const t = THEMES.find(x => x.id === initId); if (t) applyTheme(t); }

searchInput.addEventListener('input', () => {
  const q = searchInput.value.trim().toLowerCase();
  focusedIdx = -1;
  if (!q) { closeResults(); return; }
  filteredList = THEMES.filter(t =>
    t.name.toLowerCase().includes(q) ||
    t.id.toLowerCase().includes(q) ||
    (t.tags||[]).some(tag => tag.toLowerCase().includes(q))
  );
  renderResults();
});

searchInput.addEventListener('keydown', e => {
  const items = resultsBox.querySelectorAll('.tr-item');
  if (!items.length) return;
  if (e.key === 'ArrowDown')  { e.preventDefault(); focusedIdx = Math.min(focusedIdx+1, items.length-1); highlight(items); }
  else if (e.key === 'ArrowUp')   { e.preventDefault(); focusedIdx = Math.max(focusedIdx-1, 0); highlight(items); }
  else if (e.key === 'Enter' && focusedIdx >= 0) { e.preventDefault(); pickTheme(focusedIdx); }
  else if (e.key === 'Escape')    { closeResults(); }
});

function highlight(items) {
  items.forEach((el,i) => el.classList.toggle('focused', i===focusedIdx));
  if (focusedIdx >= 0) items[focusedIdx].scrollIntoView({block:'nearest'});
}

function renderResults() {
  if (!filteredList.length) {
    resultsBox.innerHTML = '<div class="no-results">Tidak ada tema ditemukan</div>';
  } else {
    resultsBox.innerHTML = filteredList.map((t,i) => {
      const thumb = t.demo_photo
        ? `<img src="${t.demo_photo}" style="width:36px;height:36px;object-fit:cover;border-radius:4px;flex-shrink:0" loading="lazy">`
        : `<div class="tr-swatch" style="background:${t.preview_color}"><span style="color:${t.accent_color}">✦</span></div>`;
      const tags = (t.tags||[]).slice(0,4).join(', ');
      const price = t.price_label ? `<span class="tr-price">${t.price_label}</span>` : '';
      return `<div class="tr-item" onclick="pickTheme(${i})">
        ${thumb}
        <div class="tr-info">
          <div class="tr-name">${t.name}</div>
          ${tags ? `<div class="tr-tags">${tags}</div>` : ''}
        </div>${price}</div>`;
    }).join('');
  }
  resultsBox.classList.add('open');
}

function pickTheme(idx) {
  const t = filteredList[idx];
  if (!t) return;
  applyTheme(t);
  closeResults();
  searchInput.value = '';
}

function applyTheme(t) {
  hiddenInput.value = t.id;
  if (t.demo_photo) {
    tsSwatchEl.innerHTML = `<img src="${t.demo_photo}" style="width:44px;height:44px;object-fit:cover;border-radius:4px">`;
  } else {
    tsSwatchEl.style.background = t.preview_color;
    tsSwatchEl.innerHTML = `<span style="color:${t.accent_color}">✦</span>`;
  }
  tsNameEl.textContent = t.name;
  tsIdEl.textContent   = t.id;
  selectedBox.classList.add('show');
}

function clearTheme() {
  hiddenInput.value = '';
  selectedBox.classList.remove('show');
  searchInput.value = '';
  searchInput.focus();
}

function closeResults() { resultsBox.classList.remove('open'); focusedIdx = -1; }

document.addEventListener('click', e => {
  if (!e.target.closest('.theme-search-wrap')) closeResults();
});

// ── PORTRAIT PREVIEW ──
function previewPortrait(inp, previewId) {
  const img = document.getElementById(previewId);
  if (!inp.files || !inp.files[0]) return;
  img.src = URL.createObjectURL(inp.files[0]);
  img.style.display = 'block';
}

// ── GALLERY PREVIEW (multiple files) ──
function previewGallery(input) {
  const preview = document.getElementById('galleryPreview');
  preview.innerHTML = '';
  Array.from(input.files).slice(0, 10).forEach(f => {
    const img = document.createElement('img');
    img.className = 'photo-thumb';
    img.src = URL.createObjectURL(f);
    preview.appendChild(img);
  });
}

// Drag & drop visual feedback on gallery zone
const galleryZone = document.getElementById('galleryZone');
galleryZone.addEventListener('dragover', e => { e.preventDefault(); galleryZone.classList.add('dragover'); });
['dragleave','drop'].forEach(ev => galleryZone.addEventListener(ev, () => galleryZone.classList.remove('dragover')));

// ── URL FIELDS ──
let urlCount = 1;
function addUrlField() {
  if (urlCount >= 9) return;
  const div = document.createElement('div');
  div.className = 'url-row';
  div.innerHTML = `<input class="form-input" type="url" name="photo_url_${urlCount}" placeholder="https://...">`;
  document.getElementById('url-fields').appendChild(div);
  urlCount++;
}

// ── SUBMIT VALIDATION ──
document.getElementById('mainForm').addEventListener('submit', e => {
  if (!hiddenInput.value) {
    e.preventDefault();
    searchInput.style.borderColor = '#e53935';
    searchInput.focus();
    setTimeout(() => searchInput.style.borderColor = '', 2500);
    alert('Pilih tema terlebih dahulu sebelum menyimpan.');
  }
});
</script>
</body>
</html>
