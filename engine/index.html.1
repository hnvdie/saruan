              rows={3} style={{...S.input,resize:"vertical",fontFamily:"DM Sans,sans-serif"}}/>
          </Field>

          <Field label="Gunakan Variable Data">
            <div style={{display:"flex",gap:6,alignItems:"center"}}>
              <input type="checkbox" checked={el.isVar||false} onChange={e=>update({isVar:e.target.checked})}
                style={{accentColor:"#C4973A",cursor:"pointer"}}/>
              <span style={{fontSize:11,color:"#555",fontFamily:"DM Sans,sans-serif"}}>Aktifkan</span>
            </div>
          </Field>
          {el.isVar && (
            <Field label="Pilih Variable">
              <select value={el.varKey||""} onChange={e=>update({varKey:e.target.value,text:`{{${e.target.value}}}`})}
                style={{...S.input,cursor:"pointer"}}>
                <option value="">— Pilih variable —</option>
                {DATA_VARS.map(v=><option key={v.key} value={v.key}>{v.label}</option>)}
              </select>
            </Field>
          )}

          {/* Photo var — shape controls */}
          {el.isVar && ["inv.groom_photo_url","inv.bride_photo_url"].includes(el.varKey) && (
            <>
              <Divider label="Foto Shape"/>
              <Field label="Bentuk">
                <div style={{display:"flex",gap:4}}>
                  {[["0","⬛ Kotak"],["12","▣ Rounded"],["50%","⬤ Bulat"]].map(([v,l])=>{
                    const cur = el.borderRadius!==undefined?String(el.borderRadius):"0";
                    const active = cur===v;
                    return (
                      <button key={v} onClick={()=>update({borderRadius:v==="50%"?"50%":parseInt(v)})}
                        style={{flex:1,padding:"5px 2px",background:active?"#1a2a1a":"#181818",border:`1px solid ${active?"#7D9470":"#252525"}`,color:active?"#9CD889":"#555",borderRadius:3,cursor:"pointer",fontSize:9,fontFamily:"DM Sans,sans-serif"}}>
                        {l}
                      </button>
                    );
                  })}
                </div>
              </Field>
              {(el.borderRadius!=="50%") && (
                <Field label={`Radius Custom — ${el.borderRadius||0}px`}>
                  <Slider value={typeof el.borderRadius==="number"?el.borderRadius:0} min={0} max={100}
                    onChange={v=>update({borderRadius:v})}/>
                </Field>
              )}
              <Field label={`Tinggi Foto — ${el.width||150}px`}>
                <Slider value={el.width||150} min={60} max={500} onChange={v=>update({width:v})}/>
              </Field>
            </>
          )}

          {/* Skip typography for photo vars */}
          {el.isVar && ["inv.groom_photo_url","inv.bride_photo_url"].includes(el.varKey) ? null : (
          <><Divider label="Tipografi"/>
          <Field label="Font">
            <input value={fontSearch} onChange={e=>setFontSearch(e.target.value)} placeholder="Cari font..."
              style={{...S.input,marginBottom:4,fontSize:11}}/>
            <select value={el.fontFamily||"Playfair Display"} onChange={e=>update({fontFamily:e.target.value})}
              style={{...S.input,cursor:"pointer",fontFamily:`'${el.fontFamily||"Playfair Display"}',serif`}}>
              {filteredFonts.map(f=><option key={f} value={f} style={{fontFamily:`'${f}',serif`}}>{f}</option>)}
            </select>
          </Field>
          <Field label={`Ukuran — ${el.fontSize||24}px`}>
            <Slider value={el.fontSize||24} min={8} max={120} onChange={v=>update({fontSize:v})}/>
          </Field>
          <Field label="Warna Teks">
            <div style={{display:"flex",gap:8,alignItems:"center"}}>
              <input type="color" value={el.color||"#ffffff"} onChange={e=>update({color:e.target.value})}
                style={{width:36,height:28,border:"none",cursor:"pointer",padding:0,borderRadius:4}}/>
              <input value={el.color||"#ffffff"} onChange={e=>update({color:e.target.value})}
                style={{...S.input,flex:1,fontFamily:"monospace",fontSize:11}}/>
            </div>
          </Field>
          <Field label="Perataan">
            <div style={{display:"flex",gap:4}}>
              {["left","center","right"].map(a=>(
                <button key={a} onClick={()=>update({align:a})}
                  style={{flex:1,padding:"5px 0",background:el.align===a?"#222":"#181818",border:`1px solid ${el.align===a?"#C4973A":"#252525"}`,color:el.align===a?"#C4973A":"#666",borderRadius:3,cursor:"pointer",fontSize:12}}>
                  {a==="left"?"⬅":a==="center"?"⬆":"➡"}
                </button>
              ))}
            </div>
          </Field>
          <Field label="Gaya">
            <div style={{display:"flex",gap:4}}>
              <button onClick={()=>update({fontStyle:el.fontStyle==="italic"?"normal":"italic"})}
                style={{flex:1,padding:"5px 0",background:el.fontStyle==="italic"?"#222":"#181818",border:`1px solid ${el.fontStyle==="italic"?"#C4973A":"#252525"}`,color:el.fontStyle==="italic"?"#C4973A":"#666",borderRadius:3,cursor:"pointer",fontSize:12,fontStyle:"italic"}}>I</button>
              <button onClick={()=>update({fontWeight:el.fontWeight==="700"||el.fontWeight===700?"400":"700"})}
                style={{flex:1,padding:"5px 0",background:(el.fontWeight==="700"||el.fontWeight===700)?"#222":"#181818",border:`1px solid ${(el.fontWeight==="700"||el.fontWeight===700)?"#C4973A":"#252525"}`,color:(el.fontWeight==="700"||el.fontWeight===700)?"#C4973A":"#666",borderRadius:3,cursor:"pointer",fontSize:12,fontWeight:"700"}}>B</button>
            </div>
          </Field>
          <Field label={`Letter Spacing — ${el.letterSpacing||0}px`}>
            <Slider value={el.letterSpacing||0} min={-2} max={20} step={0.5} onChange={v=>update({letterSpacing:v})}/>
          </Field>
          <Field label={`Line Height — ${el.lineHeight||1.4}`}>
            <Slider value={el.lineHeight||1.4} min={0.8} max={3} step={0.1} onChange={v=>update({lineHeight:v})}/>
          </Field>
          <Field label="Text Shadow">
            <div style={{display:"flex",gap:6,alignItems:"center"}}>
              <input type="checkbox" checked={el.shadow||false} onChange={e=>update({shadow:e.target.checked})}
                style={{accentColor:"#C4973A",cursor:"pointer"}}/>
              <span style={{fontSize:11,color:"#555",fontFamily:"DM Sans,sans-serif"}}>Aktifkan shadow</span>
            </div>
          </Field>
          {el.shadow && (
            <Field label={`Shadow Blur — ${el.shadowBlur||8}px`}>
              <Slider value={el.shadowBlur||8} min={0} max={40} onChange={v=>update({shadowBlur:v})}/>
            </Field>
          )}
          <Field label={`Lebar Teks — ${el.width||200}px`}>
            <Slider value={el.width||200} min={40} max={CANVAS_W} onChange={v=>update({width:v})}/>
          </Field>
        </>
      )}
        </>
      )}

      <Divider label="Posisi & Transform"/>
      <Field label={`X — ${el.x}px`}>
        <Slider value={el.x} min={-CANVAS_W} max={CANVAS_W*1.5} onChange={v=>update({x:v})}/>
      </Field>
      <Field label={`Y — ${el.y}px`}>
        <Slider value={el.y} min={-CANVAS_H} max={CANVAS_H*1.5} onChange={v=>update({y:v})}/>                      </Field>
      {el.type==="image" && (
        <Field label={`Lebar — ${el.width}px`}>
          <Slider value={el.width} min={10} max={CANVAS_W*1.4} onChange={v=>update({width:v})}/>
        </Field>
      )}
      <Field label={`Rotasi — ${el.rotation||0}°`}>
        <Slider value={el.rotation||0} min={-180} max={180} onChange={v=>update({rotation:v})}/>
      </Field>

      {/* Flip buttons */}
      {el.type==="image" && (
        <Field label="Flip">
          <div style={{display:"flex",gap:6}}>
            <button onClick={()=>update({flipH:!el.flipH})}
              style={{flex:1,padding:"5px 0",background:el.flipH?"#1a1a2a":"#181818",border:`1px solid ${el.flipH?"#4A90D9":"#252525"}`,color:el.flipH?"#4A90D9":"#666",borderRadius:3,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif"}}>
              ↔ Horizontal
            </button>
            <button onClick={()=>update({flipV:!el.flipV})}
              style={{flex:1,padding:"5px 0",background:el.flipV?"#1e1a2a":"#181818",border:`1px solid ${el.flipV?"#9B59B6":"#252525"}`,color:el.flipV?"#9B59B6":"#666",borderRadius:3,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif"}}>
              ↕ Vertikal
            </button>
          </div>
        </Field>
      )}

      <Divider label="Tampilan"/>
      <Field label={`Opacity — ${Math.round((el.opacity||1)*100)}%`}>
        <Slider value={el.opacity||1} min={0} max={1} step={0.01} onChange={v=>update({opacity:v})}/>
      </Field>
      <Field label={`Z-Index — ${el.zIndex||10}`}>
        <div style={{display:"flex",gap:6,alignItems:"center"}}>
          <Slider value={el.zIndex||10} min={1} max={50} onChange={v=>update({zIndex:v})}/>
          <div style={{display:"flex",gap:3,flexShrink:0}}>
            <button onClick={onForward} style={S.microBtn}>↑</button>
            <button onClick={onBackward} style={S.microBtn}>↓</button>
          </div>
        </div>
      </Field>

      <Divider label="Animasi"/>
      <Field label="Jenis Animasi">
        <select value={el.animation||"none"} onChange={e=>update({animation:e.target.value})}
          style={{...S.input,cursor:"pointer"}}>
          {ANIMATIONS.map(a=><option key={a.id} value={a.id}>{a.label}</option>)}
        </select>
      </Field>
      {(el.animation&&el.animation!=="none") && (
        ["sway","float","pulse","shimmer","bounce"].includes(el.animation) ? (
          <Field label={`Durasi — ${el.animDuration||4}s`}>
            <Slider value={el.animDuration||4} min={0.5} max={12} step={0.5} onChange={v=>update({animDuration:v})}/>
          </Field>
        ) : (
          <Field label={`Delay — ${el.animDelay||0}s`}>
            <Slider value={el.animDelay||0} min={0} max={6} step={0.1} onChange={v=>update({animDelay:v})}/>
          </Field>
        )
      )}

      <div style={{display:"flex",gap:6,marginTop:4}}>                                                               <button onClick={onDuplicate}                                                                                  style={{flex:1,padding:"7px 0",background:"#181818",border:"1px solid #222",color:"#666",borderRadius:4,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif"}}>
          Duplikat
        </button>
        <button onClick={onDelete}
          style={{flex:1,padding:"7px 0",background:"#1a0a0a",border:"1px solid #3a1515",color:"#c55",borderRadius:4,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif"}}>
          Hapus
        </button>
      </div>
    </div>
  );
}

// ─── UI Primitives ────────────────────────────────────────────────────────────
function PLabel({ children }) {
  return <div style={{fontSize:10,letterSpacing:1.5,textTransform:"uppercase",color:"#444",fontWeight:700,fontFamily:"DM Sans,sans-serif",marginBottom:4}}>{children}</div>;
}
function Divider({ label }) {
  return (
    <div style={{display:"flex",alignItems:"center",gap:8,margin:"4px 0"}}>
      <div style={{fontSize:10,color:"#2e2e2e",letterSpacing:.8,textTransform:"uppercase",whiteSpace:"nowrap",fontFamily:"DM Sans,sans-serif"}}>{label}</div>
      <div style={{flex:1,height:1,background:"#1a1a1a"}}/>
    </div>
  );
}
function Field({ label, children }) {
  return (
    <div>
      <div style={{fontSize:11,color:"#3a3a3a",marginBottom:3,letterSpacing:.2,fontFamily:"DM Sans,sans-serif"}}>{label}</div>
      {children}
    </div>
  );
}
function Slider({ value, min, max, step=1, onChange }) {
  return (
    <input type="range" value={value} min={min} max={max} step={step}
      onChange={e=>onChange(step<1?parseFloat(e.target.value):parseInt(e.target.value))}
      style={{width:"100%",cursor:"pointer",accentColor:"#C4973A"}}/>
  );
}
function IBtn({ children, onClick, title, danger }) {                                                          return (
    <button onClick={onClick} title={title}
      style={{padding:"2px 5px",background:"transparent",border:"none",
        color:danger?"#522":"#333",cursor:"pointer",fontSize:13,lineHeight:1,
        borderRadius:3,fontFamily:"DM Sans,sans-serif"}}
      onMouseEnter={e=>e.target.style.color=danger?"#f55":"#aaa"}
      onMouseLeave={e=>e.target.style.color=danger?"#522":"#333"}>
      {children}
    </button>
  );
}

// ─── Styles ───────────────────────────────────────────────────────────────────
const S = {
  root:{display:"flex",flexDirection:"column",height:"100vh",background:"#0a0a0a",color:"#ccc",fontFamily:"'DM Sans',system-ui,sans-serif",fontSize:13,overflow:"hidden"},
  topbar:{display:"flex",alignItems:"center",gap:8,padding:"0 14px",height:44,background:"#0e0e0e",borderBottom:"1px solid #161616",flexShrink:0},
  logo:{fontWeight:700,fontSize:14,color:"#C4973A",letterSpacing:.5,fontFamily:"DM Sans,sans-serif"},
  body:{display:"flex",flex:1,overflow:"hidden",minHeight:0},
  leftPanel:{width:200,background:"#0e0e0e",borderRight:"1px solid #161616",display:"flex",flexDirection:"column",overflow:"hidden",flexShrink:0},
  canvasWrap:{flex:1,display:"flex",alignItems:"flex-start",justifyContent:"center",background:"#080808",overflow:"auto",position:"relative",padding:"20px 40px"},
  rightPanel:{width:230,background:"#0e0e0e",borderLeft:"1px solid #161616",overflowY:"auto",padding:"0 12px 24px",flexShrink:0,display:"flex",flexDirection:"column"},
  input:{width:"100%",padding:"6px 8px",background:"#141414",border:"1px solid #222",color:"#bbb",borderRadius:4,fontSize:12,outline:"none",fontFamily:"'DM Sans',sans-serif",transition:"border-color .15s"},
  btnPrimary:{padding:"7px 14px",background:"#C4973A",border:"none",color:"#0a0a0a",borderRadius:4,cursor:"pointer",fontWeight:700,fontSize:12,fontFamily:"'DM Sans',sans-serif"},
  btnSecondary:{padding:"6px 12px",background:"#141414",border:"1px solid #222",color:"#666",borderRadius:4,cursor:"pointer",fontSize:12,fontFamily:"'DM Sans',sans-serif"},
  microBtn:{padding:"3px 6px",background:"#161616",border:"1px solid #222",color:"#555",borderRadius:3,cursor:"pointer",fontSize:12,fontFamily:"'DM Sans',sans-serif",flexShrink:0},
};

ReactDOM.createRoot(document.getElementById("root")).render(<App />);                                        </script>
</body>
</html>
