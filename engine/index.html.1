// ─── Build exported HTML ──────────────────────────────────────────────────────
function buildHTML(sections, invData) {
  const inv = invData || {};
  const animCSS = `
@keyframes fade-in{from{opacity:0}to{opacity:1}}
@keyframes slide-from-left{from{opacity:0;transform:translateX(-32px)}to{opacity:1;transform:none}}
@keyframes slide-from-right{from{opacity:0;transform:translateX(32px)}to{opacity:1;transform:none}}
@keyframes slide-from-top{from{opacity:0;transform:translateY(-32px)}to{opacity:1;transform:none}}
@keyframes slide-from-bottom{from{opacity:0;transform:translateY(32px)}to{opacity:1;transform:none}}
@keyframes zoom-in{from{opacity:0;transform:scale(.82)}to{opacity:1;transform:scale(1)}}
@keyframes rotate-in{from{opacity:0;transform:rotate(-14deg) scale(.88)}to{opacity:1;transform:none}}
@keyframes sway{0%,100%{transform:rotate(0deg)}50%{transform:rotate(6deg)}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.45}}
@keyframes shimmer{0%{filter:brightness(1)}50%{filter:brightness(1.4)}100%{filter:brightness(1)}}
@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}`;

  const elToHTML = (el) => {
    const baseAnim = (anim, dur, delay) => {
      if(!anim || anim==="none") return "";
      const inf = ["sway","float","pulse","shimmer","bounce"].includes(anim);
      return inf ? `animation:${anim} ${dur||4}s ease-in-out infinite;`
                 : `animation:${anim} .8s cubic-bezier(.16,1,.3,1) ${delay||0}s both;`;
    };
    if(el.type==="image") {
      const animS = baseAnim(el.animation, el.animDuration, el.animDelay);
      const flipS = `${el.flipH?"scaleX(-1)":""}${el.flipV?" scaleY(-1)":""}`.trim();
      const transformVal = [`rotate(${el.rotation||0}deg)`, flipS].filter(Boolean).join(" ");
      return `  <img src="${el.src}" alt="" style="position:absolute;left:${el.x}px;top:${el.y}px;width:${el.width}px;transform:${transformVal};opacity:${el.opacity};z-index:${el.zIndex};${animS}pointer-events:none;" />`;
    }
    if(el.type==="text") {
      const animS = baseAnim(el.animation, el.animDuration, el.animDelay);
      const shadowS = el.shadow ? `text-shadow:0 2px ${el.shadowBlur||8}px ${el.shadowColor||"rgba(0,0,0,0.5)"};` : "";
      const rawText = el.isVar && el.varKey ? `{{${el.varKey}}}` : el.text;
      return `  <div style="position:absolute;left:${el.x}px;top:${el.y}px;width:${el.width||200}px;font-size:${el.fontSize||24}px;font-family:'${el.fontFamily||"Playfair Display"}',serif;color:${el.color||"#fff"};text-align:${el.align||"center"};font-style:${el.fontStyle||"normal"};font-weight:${el.fontWeight||400};letter-spacing:${el.letterSpacing||0}px;line-height:${el.lineHeight||1.4};opacity:${el.opacity||1};z-index:${el.zIndex||10};transform:rotate(${el.rotation||0}deg);${shadowS}${animS}">${rawText}</div>`;
    }
    return "";
  };

  const buildSecHTML = (s, i) => {
    const fitMap = {contain:"contain",fill:"100% 100%",center:"auto",cover:"cover"};
    const bgSize = fitMap[s.bgFit||"cover"]||"cover";
    const bgStyle = s.bgImage
      ? `background-image:url('${s.bgImage}');background-size:${bgSize};background-position:center;background-repeat:no-repeat;`
      : `background:${s.bg};`;
    const elsHTML = s.elements.map(elToHTML).filter(Boolean).join("\n");
    let ex = "";
    if(s.type==="countdown") {
      const acc = s.cdAccent||"#C4973A";
      const design = s.cdDesign||"cards";
      const showDate = s.cdShowDate!==false;
      let cdInner = "";
      if(design==="cards") {
        cdInner = `<div style="display:flex;gap:12px;justify-content:center;">${["days","hours","mins","secs"].map((k,i)=>`<div style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.08);border-radius:${s.cdRadius||8}px;padding:14px 12px;min-width:64px;text-align:center;backdrop-filter:blur(8px);"><span id="cd-${k}" style="font-size:42px;font-family:'Playfair Display',serif;color:${acc};display:block;line-height:1;">00</span><span style="font-size:10px;letter-spacing:2px;color:#888;text-transform:uppercase;">${["Hari","Jam","Menit","Detik"][i]}</span></div>`).join("")}</div>`;
      } else if(design==="minimal") {
        cdInner = `<div style="display:flex;gap:4px;align-items:center;justify-content:center;">${["days","hours","mins","secs"].map((k,i)=>`${i>0?`<span style="font-size:32px;color:${acc};opacity:.4;margin:0 2px;">:</span>`:"" }<div style="text-align:center;"><span id="cd-${k}" style="font-size:52px;font-family:'Playfair Display',serif;color:${acc};font-style:italic;display:block;line-height:1;">00</span><span style="font-size:9px;letter-spacing:2.5px;color:#666;text-transform:uppercase;display:block;">${["Hari","Jam","Menit","Detik"][i]}</span></div>`).join("")}</div>`;
      } else if(design==="glass") {
        cdInner = `<div style="display:flex;gap:10px;justify-content:center;">${["days","hours","mins","secs"].map((k,i)=>`<div style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:${s.cdRadius||50}px;padding:18px 10px;min-width:68px;text-align:center;box-shadow:inset 0 1px 0 rgba(255,255,255,.1);"><span id="cd-${k}" style="font-size:38px;font-family:'DM Sans',sans-serif;font-weight:300;color:#fff;display:block;line-height:1;">${acc!=='#C4973A'?`<span style="color:${acc};">0</span>0`:"00"}</span><span style="font-size:10px;letter-spacing:1.5px;color:#777;text-transform:uppercase;">${["Hari","Jam","Menit","Detik"][i]}</span></div>`).join("")}</div>`;
      } else if(design==="line") {
        cdInner = `<div style="display:flex;gap:24px;justify-content:center;align-items:flex-end;">${["days","hours","mins","secs"].map((k,i)=>`<div style="text-align:center;"><span id="cd-${k}" style="font-size:56px;font-family:'Playfair Display',serif;color:${acc};display:block;line-height:1;">00</span><div style="width:100%;height:1px;background:${acc};opacity:.3;margin:6px 0;"></div><span style="font-size:9px;letter-spacing:3px;color:#666;text-transform:uppercase;">${["Hari","Jam","Menit","Detik"][i]}</span></div>`).join("")}</div>`;
      }
      const dateText = showDate ? `<div style="margin-top:18px;font-size:12px;letter-spacing:2px;color:#666;text-transform:uppercase;font-family:'DM Sans',sans-serif;">{{inv.akad_date|format_date}}</div>` : "";
      ex = `\n  <div id="countdown-display" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;z-index:20;"><div style="text-align:center;">${cdInner}${dateText}</div></div>`;
    }
    if(s.type==="rsvp") {
      const acc    = s.rsvpAccent||"#C4973A";
      const radius = s.rsvpRadius!==undefined?s.rsvpRadius:2;
      const style  = s.rsvpStyle||"dark";
      const title  = s.rsvpTitle||"Konfirmasi Kehadiran";
      const inputBg= style==="light"?"rgba(0,0,0,0.05)":style==="glass"?"rgba(255,255,255,0.1)":"rgba(255,255,255,0.08)";
      const inputColor= style==="light"?"#333":"#fff";
      const selectBg= style==="light"?"rgba(0,0,0,0.05)":"#1a1a1a";
      const titleColor= style==="light"?"#333":`${acc}`;
      const noteColor= style==="light"?"#666":"#888";
      ex = `\n  <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;z-index:20;padding:32px 24px;overflow-y:auto;">
  <div style="width:100%;max-width:340px;">
    <div style="text-align:center;margin-bottom:20px;"><div style="font-family:'Playfair Display',serif;font-size:22px;color:${titleColor};">${title}</div><div style="width:40px;height:1px;background:${acc};opacity:.5;margin:10px auto 0;"></div></div>
    <div id="rsvp-form" style="display:flex;flex-direction:column;gap:10px;">
      <input id="rsvp-name" placeholder="Nama Anda" style="padding:12px 16px;background:${inputBg};border:1px solid ${acc}44;color:${inputColor};font-family:'DM Sans',sans-serif;font-size:14px;border-radius:${radius}px;outline:none;width:100%;"/>
      <select id="rsvp-attend" style="padding:12px 16px;background:${selectBg};border:1px solid ${acc}44;color:#aaa;font-family:'DM Sans',sans-serif;font-size:14px;border-radius:${radius}px;outline:none;width:100%;">
        <option value="">Konfirmasi Kehadiran</option>
        <option value="hadir">Insya Allah Hadir ✓</option>
        <option value="tidak">Mohon Maaf Tidak Hadir</option>
        <option value="ragu">Masih Belum Pasti</option>
      </select>
      <input id="rsvp-guests" type="number" min="1" max="10" placeholder="Jumlah Tamu" style="padding:12px 16px;background:${inputBg};border:1px solid ${acc}44;color:${inputColor};font-family:'DM Sans',sans-serif;font-size:14px;border-radius:${radius}px;outline:none;width:100%;"/>
      <textarea id="rsvp-message" placeholder="Ucapan &amp; Doa (opsional)" rows="3" style="padding:12px 16px;background:${inputBg};border:1px solid ${acc}44;color:${inputColor};font-family:'DM Sans',sans-serif;font-size:14px;border-radius:${radius}px;outline:none;resize:none;width:100%;"></textarea>
      <button onclick="submitRSVP()" style="padding:14px;background:${acc};border:none;color:#fff;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;border-radius:${radius}px;cursor:pointer;letter-spacing:.5px;width:100%;">Kirim Konfirmasi</button>
    </div>
    <div id="rsvp-success" style="display:none;text-align:center;padding:30px 0;">
      <div style="font-size:32px;">💌</div>
      <div style="font-family:'Playfair Display',serif;font-size:20px;color:${acc};margin-top:10px;">Terima Kasih!</div>
      <div style="font-size:13px;color:${noteColor};margin-top:6px;">Konfirmasi kehadiran Anda telah kami terima.</div>
    </div>
  </div>
  </div>`;
    }
    if(s.type==="maps") {
      const layout = s.mapsLayout||"fullscreen";
      const radius = s.mapsRadius!==undefined?s.mapsRadius:0;
      const btnColor= s.mapsBtnColor||"#C4973A";
      const btnText = s.mapsBtnText||"Buka di Google Maps";
      if(layout==="fullscreen") {
        ex = `\n  <div style="position:absolute;inset:0;z-index:20;">
  <iframe src="{{inv.maps_embed}}" width="100%" height="100%" style="border:0;display:block;" allowfullscreen="" loading="lazy"></iframe>
  <div style="position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,0.85));padding:24px;text-align:center;">
    <a href="{{inv.maps_url}}" target="_blank" style="display:inline-block;padding:11px 28px;background:${btnColor};color:#000;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;border-radius:${radius}px;text-decoration:none;letter-spacing:.5px;">${btnText}</a>
  </div>
  </div>`;
      } else if(layout==="half") {
        ex = `\n  <div style="position:absolute;inset:0;z-index:20;display:flex;flex-direction:column;">
  <div style="flex:1;overflow:hidden;border-radius:0 0 ${radius}px ${radius}px;">
    <iframe src="{{inv.maps_embed}}" width="100%" height="100%" style="border:0;display:block;" allowfullscreen="" loading="lazy"></iframe>
  </div>
  <div style="flex-shrink:0;padding:20px 24px;text-align:center;background:inherit;">
    <div style="font-family:'Playfair Display',serif;font-size:16px;color:#C4973A;margin-bottom:6px;">{{inv.resepsi_venue}}</div>
    <div style="font-size:12px;color:#888;margin-bottom:14px;font-family:'DM Sans',sans-serif;">{{inv.resepsi_address}}</div>
    <a href="{{inv.maps_url}}" target="_blank" style="display:inline-block;padding:10px 28px;background:${btnColor};color:#000;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;border-radius:${radius}px;text-decoration:none;letter-spacing:.5px;">${btnText}</a>
  </div>
  </div>`;
      } else if(layout==="box") {
        ex = `\n  <div style="position:absolute;inset:0;z-index:20;display:flex;align-items:center;justify-content:center;padding:20px;">
  <div style="width:100%;border-radius:${radius||16}px;overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,.4);">
    <iframe src="{{inv.maps_embed}}" width="100%" height="260" style="border:0;display:block;" allowfullscreen="" loading="lazy"></iframe>
    <div style="padding:16px 20px;text-align:center;background:rgba(255,255,255,0.05);">
      <div style="font-family:'Playfair Display',serif;font-size:15px;color:#C4973A;margin-bottom:4px;">{{inv.resepsi_venue}}</div>
      <div style="font-size:11px;color:#777;margin-bottom:12px;font-family:'DM Sans',sans-serif;">{{inv.resepsi_address}}</div>
      <a href="{{inv.maps_url}}" target="_blank" style="display:inline-block;padding:9px 24px;background:${btnColor};color:#000;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;border-radius:${radius||16}px;text-decoration:none;">${btnText}</a>
    </div>
  </div>
  </div>`;
      }
    }
    if(s.type==="gallery") {
      const imgEls=s.galleryImages||[], shape=s.galleryShape||"kotak", layout=s.galleryLayout||"2", gap=s.galleryGap!==undefined?s.galleryGap:8;
      const gridCols=layout==="1"?"1fr":layout==="3"?"1fr 1fr 1fr":"1fr 1fr";
      const br=shape==="circle"?"50%":shape==="rounded"?"12px":"2px";
      const imgH=layout==="1"||shape==="portrait"?"220px":"150px";
      const aspR=shape==="circle"?"aspect-ratio:1/1;":"";
      const SM=`<svg viewBox="0 0 60 80" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:48px;height:64px;"><circle cx="30" cy="22" r="14" fill="#2a2018"/><path d="M4 80 Q4 48 30 48 Q56 48 56 80Z" fill="#2a2018"/></svg>`;
      const SF=`<svg viewBox="0 0 60 80" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:48px;height:64px;"><circle cx="30" cy="22" r="14" fill="#182028"/><path d="M4 80 Q4 48 30 48 Q56 48 56 80Z" fill="#182028"/></svg>`;
      // Use Jinja photos loop for real data; fallback to any manually-added images in editor
