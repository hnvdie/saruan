// ─── Main App ─────────────────────────────────────────────────────────────────
// Compute initial state from draft or defaults
const _draft = loadDraft();
// Sync _id counter if draft loaded
if (_draft.sections) {
  _draft.sections.forEach(s => s.elements?.forEach(el => { if(el.id > _id) _id = el.id; }));
}

function App() {
  const [sections, setSections]         = useState(() => _draft.sections || initSections);
  const [activeId, setActiveId]         = useState(() => (_draft.sections?.[0]?.id) || 1);
  const [selectedElId, setSelEl]        = useState(null);
  const [drag, setDrag]                 = useState(null);
  const [canvasScale, setCanvasScale]   = useState(0.68);
  const [showAddMenu, setShowAddMenu]   = useState(false);
  const [exportDone, setExportDone]     = useState(false);
  const [tab, setTab]                   = useState("sections");
  const [toast, setToast]               = useState(null);
  const [previewMode, setPreviewMode]   = useState(false);
  const [showDataPanel, setShowDataPanel] = useState(false);
  const [invData, setInvData]           = useState(() => _draft.invData || {});
  const [showFontPicker, setShowFontPicker] = useState(false);
  const [fontSearch, setFontSearch]     = useState("");
  const [rightTab, setRightTab]         = useState("element"); // element | section | data
  const canvasWrapRef = useRef(null);
  const fileInputRef  = useRef(null);
  const bgImgRef      = useRef(null);
  const galleryRef    = useRef(null);

  const activeSection = sections.find(s => s.id === activeId);
  const selectedEl    = activeSection?.elements.find(e => e.id === selectedElId);

  // Auto-save draft to localStorage
  useEffect(() => { saveDraft(sections, invData); }, [sections, invData]);

  const showToast = (msg, type="success") => {
    setToast({msg,type});
    setTimeout(() => setToast(null), 2400);
  };

  useEffect(() => {
    const el = canvasWrapRef.current;
    if (!el) return;
    const ro = new ResizeObserver(() => {
      const { width: w, height: h } = el.getBoundingClientRect();
      setCanvasScale(Math.min((w - 80) / CANVAS_W, (h - 80) / CANVAS_H, 1));
    });
    ro.observe(el);
    return () => ro.disconnect();
  }, [previewMode]);

  // Auto-switch to Sec tab when cover section active & no element selected
  useEffect(() => {
    if (activeSection?.type === "cover" && !selectedElId) {
      setRightTab("section");
    }
  }, [activeSection?.id, selectedElId]);

  // Load Google Fonts for chosen fonts
  useEffect(() => {
    const gFonts = FONTS.filter(f => !["Georgia","Times New Roman","Palatino","Garamond"].includes(f));
    const href = "https://fonts.googleapis.com/css2?"+gFonts.map(f=>`family=${f.replace(/ /g,"+")}:ital,wght@0,400;0,700;1,400`).join("&")+"&display=swap";
    const link = document.createElement("link");
    link.rel = "stylesheet"; link.href = href;
    document.head.appendChild(link);
  }, []);

  // ── Sections ──────────────────────────────────────────────────────────────
  const addSection = (preset) => {
    const s = { id:uid(), ...preset, elements:[], openInviteText:"Buka Undangan", openInviteStyle:{fontSize:16,color:"#C4973A",fontFamily:"Playfair Display"} };
    setSections(p => [...p, s]);
    setActiveId(s.id);
    setSelEl(null);
    setShowAddMenu(false);
    showToast("Section ditambahkan ✦");
  };

  const deleteSection = (id) => {
    setSections(p => {
      const next = p.filter(s => s.id !== id);
      if (activeId === id && next.length) setActiveId(next[0].id);
      return next;
    });
    setSelEl(null);
  };

  const moveSection = (id, dir) => {
    setSections(p => {
      const arr = [...p], idx = arr.findIndex(s => s.id === id);
      const to = idx + dir;
      if (to < 0 || to >= arr.length) return p;
      [arr[idx], arr[to]] = [arr[to], arr[idx]];
      return arr;
    });
  };

  const updateSection = (id, patch) =>
    setSections(p => p.map(s => s.id === id ? { ...s, ...patch } : s));

  // ── Elements ──────────────────────────────────────────────────────────────
  const addElement = (el) => {
    setSections(p => p.map(s => s.id === activeId ? { ...s, elements: [...s.elements, el] } : s));
    setSelEl(el.id);
  };

  const updateEl = (id, patch) =>
    setSections(p => p.map(s => s.id === activeId
      ? { ...s, elements: s.elements.map(e => e.id === id ? { ...e, ...patch } : e) } : s));

  const deleteEl = (id) => {
    setSections(p => p.map(s => s.id === activeId
      ? { ...s, elements: s.elements.filter(e => e.id !== id) } : s));
    setSelEl(null);
  };

  const duplicateEl = (id) => {
    const el = activeSection?.elements.find(e => e.id === id);
    if (!el) return;
    const copy = { ...el, id: uid(), x: el.x + 16, y: el.y + 16 };
    setSections(p => p.map(s => s.id === activeId
      ? { ...s, elements: [...s.elements, copy] } : s));
    setSelEl(copy.id);
    showToast("Elemen diduplikat");
  };

  const bringForward = (id) => { const el=activeSection?.elements.find(e=>e.id===id); if(el) updateEl(id,{zIndex:el.zIndex+1}); };
  const sendBackward = (id) => { const el=activeSection?.elements.find(e=>e.id===id); if(el) updateEl(id,{zIndex:Math.max(1,el.zIndex-1)}); };

  // Move element up/down in array order (visual stacking)
  const moveElInLayer = (id, dir) => {
    setSections(p => p.map(s => {
      if(s.id !== activeId) return s;
      const arr = [...s.elements];
      const idx = arr.findIndex(e => e.id === id);
      const to  = idx + dir;
      if(to < 0 || to >= arr.length) return s;
      [arr[idx], arr[to]] = [arr[to], arr[idx]];
      // keep zIndex in sync with array order
      return { ...s, elements: arr.map((e,i) => ({ ...e, zIndex: i + 1 })) };
    }));
  };

  // ── Upload ────────────────────────────────────────────────────────────────
  const handleUpload = (e) => {
    const files = [...(e.target.files || [])];
    files.forEach(file => {
      const reader = new FileReader();
      reader.onload = ev => addElement(makeImgEl(ev.target.result, file.name));
      reader.readAsDataURL(file);
    });
    e.target.value = "";
    showToast(`${files.length} aset diupload`);
  };

  const handleBgImage = (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => updateSection(activeId, { bgImage: ev.target.result });
    reader.readAsDataURL(file);
    e.target.value = "";
    showToast("Background foto diset");
  };

  const handleGalleryAdd = (e) => {
    const files = [...(e.target.files || [])];
    const curGallery = activeSection?.galleryImages || [];
    Promise.all(files.map(f => new Promise(res => {
      const r = new FileReader();
      r.onload = ev => res(ev.target.result);
      r.readAsDataURL(f);
    }))).then(imgs => {
      updateSection(activeId, { galleryImages: [...curGallery, ...imgs] });
      showToast(`${files.length} foto gallery ditambahkan`);
    });
    e.target.value = "";
  };

  // ── Canvas Drag ───────────────────────────────────────────────────────────
  const onElDown = (e, elId) => {
    e.stopPropagation();
    setSelEl(elId);
    const el = activeSection.elements.find(x => x.id === elId);
    setDrag({ id:elId, sx:e.clientX, sy:e.clientY, ox:el.x, oy:el.y });
  };

  useEffect(() => {
    if (!drag) return;
    const onMove = (e) => updateEl(drag.id, {
      x: Math.round(drag.ox + (e.clientX - drag.sx) / canvasScale),
      y: Math.round(drag.oy + (e.clientY - drag.sy) / canvasScale),
    });
    const onUp = () => setDrag(null);
    window.addEventListener("mousemove", onMove);
    window.addEventListener("mouseup", onUp);
    return () => { window.removeEventListener("mousemove",onMove); window.removeEventListener("mouseup",onUp); };
  }, [drag, canvasScale]);

  // Keyboard
  useEffect(() => {
    const onKey = (e) => {
      if (!selectedElId) return;
      if (["INPUT","TEXTAREA","SELECT"].includes(e.target.tagName)) return;
      const el = activeSection?.elements.find(x => x.id === selectedElId);
      if (!el) return;
      const step = e.shiftKey ? 10 : 1;
      if (e.key==="ArrowLeft")  { e.preventDefault(); updateEl(selectedElId,{x:el.x-step}); }
      if (e.key==="ArrowRight") { e.preventDefault(); updateEl(selectedElId,{x:el.x+step}); }
      if (e.key==="ArrowUp")    { e.preventDefault(); updateEl(selectedElId,{y:el.y-step}); }
      if (e.key==="ArrowDown")  { e.preventDefault(); updateEl(selectedElId,{y:el.y+step}); }
      if (e.key==="Delete"||e.key==="Backspace") { e.preventDefault(); deleteEl(selectedElId); }
      if ((e.ctrlKey||e.metaKey)&&e.key==="d") { e.preventDefault(); duplicateEl(selectedElId); }
    };
    window.addEventListener("keydown", onKey);
    return () => window.removeEventListener("keydown", onKey);
  }, [selectedElId, activeSection, canvasScale]);

  // ── Export ────────────────────────────────────────────────────────────────
  const exportHTML = () => {
    const html = buildHTML(sections, invData);
    const blob = new Blob([html], { type:"text/html" });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement("a");
    a.href = url; a.download = "undangan-export.html"; a.click();
    URL.revokeObjectURL(url);
    setExportDone(true);
    setTimeout(() => setExportDone(false), 2500);
    showToast("Export berhasil! 🎉");
  };

  // ── Render Element on Canvas ──────────────────────────────────────────────
  const renderElOnCanvas = (el) => {
    const isSelected = selectedElId === el.id;
    const flipStyle = {
      ...(el.flipH ? {transform:`rotate(${el.rotation||0}deg) scaleX(-1)`} : {}),
      ...(el.flipV ? {transform:`rotate(${el.rotation||0}deg) scaleY(-1)`} : {}),
      ...(!el.flipH && !el.flipV ? {transform:`rotate(${el.rotation||0}deg)`} : {}),
    };

    const animStyle = (() => {
      if (!el.animation || el.animation === "none") return {};
      const inf = ["sway","float","pulse","shimmer","bounce"].includes(el.animation);
      if (inf) return { animation: `${el.animation} ${el.animDuration||4}s ease-in-out infinite` };
      return { animation: `${el.animation} .8s cubic-bezier(.16,1,.3,1) ${el.animDelay||0}s both` };
    })();

    const containerStyle = {
      position:"absolute", left:el.x, top:el.y,
      width: el.width || (el.type==="text" ? 200 : 150),
      ...flipStyle,
      opacity:el.opacity, zIndex:el.zIndex,
      cursor:"move", userSelect:"none",
      outline: isSelected ? "1.5px solid #C4973A" : "1px solid transparent",
      outlineOffset:2,
      ...animStyle,
    };

    return (
      <div key={el.id}
        onMouseDown={e => onElDown(e, el.id)}
        onClick={e => { e.stopPropagation(); setSelEl(el.id); }}
        style={containerStyle}>

        {el.type === "image" && (
          <img src={el.src} style={{width:"100%",display:"block",pointerEvents:"none",draggable:false}} alt="" />
        )}
        {el.type === "text" && (() => {
          const PHOTO_VARS = new Set(["inv.groom_photo_url","inv.bride_photo_url"]);
          const isPhotoVar = el.isVar && el.varKey && PHOTO_VARS.has(el.varKey);
          if (isPhotoVar) {
            const liveVal = invData[el.varKey.replace("inv.","")];
            const varDef  = DATA_VARS.find(v => v.key === el.varKey);
            const src     = liveVal || varDef?.example || "";
            const imgH    = el.width || 150;
            return src ? (
              <img src={src} alt="" style={{
                width:"100%", height:imgH, objectFit:"cover", display:"block",
                borderRadius: el.borderRadius==="50%"?"50%":`${el.borderRadius||0}px`, pointerEvents:"none",
              }} onError={e=>{e.target.style.opacity=0.3;}} />
            ) : (
              <div style={{
                width:"100%", height:imgH, background:"#1a1412", display:"flex",
                alignItems:"center", justifyContent:"center", borderRadius:el.borderRadius||0,
                fontSize:10, color:"#555", fontFamily:"DM Sans,sans-serif", textAlign:"center", padding:8,
              }}>
                <span>🖼 {el.varKey}<br/><span style={{opacity:.5,fontSize:9}}>set path di Data panel</span></span>
              </div>
            );
          }
          return (
            <div style={{
              fontSize:el.fontSize||24, fontFamily:`'${el.fontFamily||"Playfair Display"}',serif`,
              color: el.color||"#fff", textAlign:el.align||"center",
              fontStyle:el.fontStyle||"normal", fontWeight:el.fontWeight||400,
              letterSpacing:el.letterSpacing||0, lineHeight:el.lineHeight||1.4,
              whiteSpace:"pre-wrap", wordBreak:"break-word",
              textShadow: el.shadow ? `0 2px ${el.shadowBlur||8}px ${el.shadowColor||"rgba(0,0,0,0.5)"}` : "none",
              pointerEvents:"none",
            }}>
              {el.isVar && el.varKey
                ? (() => {
                    const varDef = DATA_VARS.find(v => v.key === el.varKey);
                    const liveVal = invData[el.varKey.replace("inv.","")];
                    return liveVal
                      ? <span>{liveVal}</span>
                      : <span style={{opacity:.75}}>{varDef?.example || el.varKey}</span>;
                  })()
                : el.text}
            </div>
          );
        })()}

        {/* Handles */}
        {isSelected && (
          <>
            {/* Resize handle — orange bottom-right */}
            <div title="Resize" onMouseDown={e => {
              e.stopPropagation();
              const startX=e.clientX, startW=el.width||150;
              const onM=ev=>updateEl(el.id,{width:Math.max(20,Math.round(startW+(ev.clientX-startX)/canvasScale))});
              const onU=()=>{window.removeEventListener("mousemove",onM);window.removeEventListener("mouseup",onU);};
              window.addEventListener("mousemove",onM); window.addEventListener("mouseup",onU);
            }} style={{position:"absolute",right:-5,bottom:-5,width:12,height:12,background:"#C4973A",borderRadius:2,cursor:"se-resize",zIndex:1001}} />

            {/* Rotation handle — green top-center */}
            <div title="Rotasi" onMouseDown={e => {
              e.stopPropagation();
              const rect=e.currentTarget.parentElement.getBoundingClientRect();
              const cx=rect.left+rect.width/2, cy=rect.top+rect.height/2;
              const startAngle=Math.atan2(e.clientY-cy,e.clientX-cx)*180/Math.PI;
              const startRot=el.rotation||0;
              const onM=ev=>{const a=Math.atan2(ev.clientY-cy,ev.clientX-cx)*180/Math.PI;updateEl(el.id,{rotation:Math.round(startRot+(a-startAngle))});};
              const onU=()=>{window.removeEventListener("mousemove",onM);window.removeEventListener("mouseup",onU);};
              window.addEventListener("mousemove",onM); window.addEventListener("mouseup",onU);
            }} style={{position:"absolute",top:-18,left:"50%",transform:"translateX(-50%)",width:10,height:10,background:"#7D9470",borderRadius:"50%",cursor:"grab",zIndex:1001}} />

            {/* Flip-H handle — blue top-left */}
            <div title="Flip Horizontal" onClick={e=>{e.stopPropagation();updateEl(el.id,{flipH:!el.flipH});}}
              style={{position:"absolute",top:-18,left:-5,width:10,height:10,background:"#4A90D9",borderRadius:2,cursor:"pointer",zIndex:1001,fontSize:8,display:"flex",alignItems:"center",justifyContent:"center",color:"#fff"}}>↔</div>

            {/* Flip-V handle — purple top-right */}
            <div title="Flip Vertikal" onClick={e=>{e.stopPropagation();updateEl(el.id,{flipV:!el.flipV});}}
              style={{position:"absolute",top:-18,right:-5,width:10,height:10,background:"#9B59B6",borderRadius:2,cursor:"pointer",zIndex:1001,fontSize:8,display:"flex",alignItems:"center",justifyContent:"center",color:"#fff"}}>↕</div>
          </>
        )}
      </div>
    );
  };

  // ── Render ────────────────────────────────────────────────────────────────
  if (previewMode) {
    const html = buildHTML(sections, invData);
    return (
      <div style={{position:"fixed",inset:0,zIndex:9999,background:"#050505",display:"flex",flexDirection:"column"}}>
        <div style={{height:40,background:"#111",display:"flex",alignItems:"center",padding:"0 16px",gap:12,flexShrink:0,borderBottom:"1px solid #1a1a1a"}}>
          <span style={{color:"#C4973A",fontWeight:700,fontSize:13,fontFamily:"DM Sans,sans-serif"}}>👁 Preview — tampilan HP</span>
          <div style={{flex:1}}/>
          <button onClick={exportHTML} style={{padding:"5px 14px",background:"#C4973A",border:"none",color:"#000",borderRadius:3,cursor:"pointer",fontSize:12,fontWeight:700,fontFamily:"DM Sans,sans-serif"}}>⬇ Export</button>
          <button onClick={()=>setPreviewMode(false)} style={{padding:"5px 14px",background:"#1e1e1e",border:"1px solid #333",color:"#aaa",borderRadius:3,cursor:"pointer",fontSize:12,fontFamily:"DM Sans,sans-serif"}}>✕ Tutup</button>
        </div>
        <div style={{flex:1,display:"flex",alignItems:"center",justifyContent:"center",overflow:"hidden",background:"#080808"}}>
          {/* Phone shell */}
          <div style={{
            width:390,height:"calc(100vh - 100px)",maxHeight:844,
            borderRadius:36,
            boxShadow:"0 0 0 8px #1a1a1a,0 0 0 10px #111,0 32px 80px rgba(0,0,0,.9)",
            overflow:"hidden",flexShrink:0,position:"relative"
          }}>
            {/* notch */}
            <div style={{position:"absolute",top:0,left:"50%",transform:"translateX(-50%)",width:120,height:28,background:"#1a1a1a",borderRadius:"0 0 16px 16px",zIndex:10}}/>
            <iframe srcDoc={html} style={{width:"100%",height:"100%",border:"none"}} />
          </div>
        </div>
      </div>
    );
  }

  return (
    <div style={S.root}>
      {/* Toast */}
      {toast && (
        <div style={{position:"fixed",bottom:20,left:"50%",transform:"translateX(-50%)",
          background: toast.type==="error" ? "#2a0e0e" : "#1e2a1e",
          border:`1px solid ${toast.type==="error" ? "#c55" : "#7D9470"}`,
          color: toast.type==="error" ? "#f88" : "#aed6a0",
          padding:"8px 20px",borderRadius:6,fontSize:12,zIndex:9999,
          animation:"toast-in .2s ease",whiteSpace:"nowrap",fontFamily:"DM Sans,sans-serif"}}>
          {toast.msg}
        </div>
      )}

      {/* TOP BAR */}
      <div style={S.topbar}>
        <span style={S.logo}>🌿 Theme Generator</span>
        <span style={{color:"#333",fontSize:11,marginLeft:4}}>habarkita.com</span>
        <div style={{flex:1}}/>
        <div style={{fontSize:11,color:"#333",marginRight:8,fontFamily:"DM Sans,sans-serif"}}>
          {sections.length} sections · {sections.reduce((a,s)=>a+s.elements.length,0)} el
        </div>
        <button onClick={()=>setShowDataPanel(v=>!v)}
          style={{...S.btnSecondary,marginRight:4,background:showDataPanel?"#1a2010":"#181818",border:showDataPanel?"1px solid #7D9470":"1px solid #252525",color:showDataPanel?"#9CD889":"#666"}}>
          📋 Data
        </button>
        <button onClick={()=>setPreviewMode(true)} style={{...S.btnSecondary,marginRight:4}}>👁 Preview</button>
        <button onClick={() => fileInputRef.current?.click()} style={{...S.btnSecondary,marginRight:4}}>↑ Upload</button>
        <input ref={fileInputRef} type="file" accept="image/*" multiple style={{display:"none"}} onChange={handleUpload} />
        <button onClick={()=>{if(window.confirm("Hapus semua draft? Data akan kembali ke default.")){clearDraft();window.location.reload();}}}
          style={{...S.btnSecondary,marginRight:4,color:"#733",borderColor:"#2a1515"}} title="Reset ke default">
          🗑 Reset
        </button>
        <button onClick={exportHTML}
          style={{...S.btnPrimary,...(exportDone?{background:"#7D9470"}:{})}}>
          {exportDone ? "✓ Berhasil!" : "⬇ Export HTML"}
        </button>
      </div>

      {/* DATA PANEL */}
      {showDataPanel && (
        <div style={{position:"absolute",top:46,right:0,width:320,background:"#111",borderLeft:"1px solid #1e1e1e",borderBottom:"1px solid #1e1e1e",zIndex:500,maxHeight:"calc(100vh - 100px)",overflowY:"auto",padding:16}}>
          <div style={{fontSize:11,letterSpacing:1.2,textTransform:"uppercase",color:"#555",fontWeight:700,marginBottom:14,fontFamily:"DM Sans,sans-serif"}}>📋 Data Undangan</div>
          <div style={{fontSize:11,color:"#444",marginBottom:10,lineHeight:1.6,fontFamily:"DM Sans,sans-serif"}}>
            Isi data di sini untuk preview. Pada hasil export, nilai ini akan menjadi template variable <code style={{color:"#7D9470"}}>{"{{inv.key}}"}</code>
          </div>
          {DATA_VARS.map(v => (
            <div key={v.key} style={{marginBottom:10}}>
              <div style={{fontSize:10,color:"#444",marginBottom:3,fontFamily:"DM Sans,sans-serif"}}>{v.label}</div>
              <input
                value={invData[v.key.replace("inv.","")] || ""}
                onChange={e => setInvData(p=>({...p,[v.key.replace("inv.","")]:e.target.value}))}
                placeholder={v.example}
                style={{...S.input,fontSize:11}}
              />
            </div>
          ))}
        </div>
      )}

      <div style={S.body}>
        {/* LEFT PANEL */}
        <div style={S.leftPanel}>
          <div style={{display:"flex",borderBottom:"1px solid #1a1a1a",flexShrink:0}}>
            {["sections","layers"].map(t => (
              <button key={t} onClick={()=>setTab(t)}
                style={{flex:1,padding:"9px 0",background:"none",border:"none",
                  color:tab===t?"#C4973A":"#444",
                  borderBottom:`2px solid ${tab===t?"#C4973A":"transparent"}`,
                  cursor:"pointer",fontSize:11,letterSpacing:.8,textTransform:"uppercase",fontWeight:600,fontFamily:"DM Sans,sans-serif"}}>
                {t==="sections"?"Sections":"Layers"}
              </button>
            ))}
          </div>

          {tab==="sections" && (
            <>
              <div style={{flex:1,overflowY:"auto"}}>
                {sections.map((s,idx) => (
                  <div key={s.id} onClick={()=>{setActiveId(s.id);setSelEl(null);}}
                    style={{display:"flex",alignItems:"center",gap:6,padding:"7px 8px",
                      cursor:"pointer",transition:"background .12s",
                      background:s.id===activeId?"#191919":"transparent",
                      borderLeft:`3px solid ${s.id===activeId?"#C4973A":"transparent"}`}}>
                    <div style={{width:12,height:12,borderRadius:2,flexShrink:0,
                      background:s.bgImage?"transparent":s.bg,
                      border:"1px solid #2a2a2a",
                      backgroundImage:s.bgImage?`url(${s.bgImage})`:"none",
                      backgroundSize:"cover"}} />
                    <span style={{flex:1,fontSize:11,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",
                      color:s.id===activeId?"#ddd":"#555",fontFamily:"DM Sans,sans-serif"}}>
                      {idx+1}. {s.name}
                    </span>
                    <IBtn onClick={e=>{e.stopPropagation();moveSection(s.id,-1);}}>↑</IBtn>
                    <IBtn onClick={e=>{e.stopPropagation();moveSection(s.id,1);}}>↓</IBtn>
                    <IBtn danger onClick={e=>{e.stopPropagation();deleteSection(s.id);}}>×</IBtn>
                  </div>
                ))}
              </div>
              <div style={{borderTop:"1px solid #1a1a1a",padding:8,flexShrink:0}}>
                <button onClick={()=>setShowAddMenu(m=>!m)}
                  style={{width:"100%",padding:"7px 0",background:"#151515",border:"1px dashed #252525",color:"#C4973A",borderRadius:4,cursor:"pointer",fontSize:12,fontFamily:"DM Sans,sans-serif"}}>
                  {showAddMenu?"— Tutup":"+ Tambah Section"}
                </button>
                {showAddMenu && (
                  <div style={{marginTop:8,display:"flex",flexWrap:"wrap",gap:3}}>
                    {SECTION_PRESETS.map(p => (
                      <button key={p.type} onClick={()=>addSection(p)}
                        style={{padding:"3px 8px",background:"#181818",border:"1px solid #252525",color:"#777",borderRadius:3,cursor:"pointer",fontSize:10,fontFamily:"DM Sans,sans-serif"}}>
                        {p.name}
                      </button>
                    ))}
                  </div>
                )}
                {/* Quick add text button */}
                <button onClick={()=>{addElement(makeTextEl("Teks Baru",80,200));}}
                  style={{width:"100%",marginTop:6,padding:"6px 0",background:"#151515",border:"1px solid #1e2a1e",color:"#7D9470",borderRadius:4,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif"}}>
                  + Teks / Judul
                </button>
                {/* Add var text */}
                <button onClick={()=>{
                  const el=makeTextEl("{{inv.groom_name}}",80,300);
                  el.isVar=true; el.varKey="inv.groom_name"; el.text="{{inv.groom_name}}";
                  addElement(el);
                }}
                  style={{width:"100%",marginTop:4,padding:"6px 0",background:"#151515",border:"1px solid #222a1e",color:"#6aaa60",borderRadius:4,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif"}}>
                  + Data Variable
                </button>
              </div>
            </>
          )}

          {tab==="layers" && (
            <div style={{flex:1,overflowY:"auto"}}>
              {(!activeSection?.elements.length) ? (
                <div style={{padding:20,color:"#333",fontSize:12,textAlign:"center",lineHeight:1.8,fontFamily:"DM Sans,sans-serif"}}>
                  Belum ada elemen.<br/>
                  <span style={{color:"#444"}}>Upload asset atau tambah teks.</span>
                </div>
              ) : (
                <>
                  <div style={{padding:"5px 8px 3px",fontSize:9,color:"#2a2a2a",letterSpacing:1,textTransform:"uppercase",fontFamily:"DM Sans,sans-serif"}}>
                    atas → bawah (urutan render)
                  </div>
                  {activeSection.elements.slice().reverse().map((el, ri) => {
                    const totalLen = activeSection.elements.length;
                    const origIdx = totalLen - 1 - ri; // actual index in array
                    const isTop    = origIdx === totalLen - 1;
                    const isBottom = origIdx === 0;
                    return (
                      <div key={el.id} onClick={()=>setSelEl(el.id)}
                        style={{display:"flex",alignItems:"center",gap:5,padding:"5px 6px 5px 8px",cursor:"pointer",
                          background:el.id===selectedElId?"#191919":"transparent",
                          borderLeft:`3px solid ${el.id===selectedElId?"#7D9470":"transparent"}`,
                          borderBottom:"1px solid #111"}}>
                        {/* thumbnail */}
                        {el.type==="image"
                          ? <img src={el.src} style={{width:20,height:20,objectFit:"cover",borderRadius:2,flexShrink:0,border:"1px solid #222"}}/>
                          : <span style={{width:20,height:20,fontSize:13,display:"flex",alignItems:"center",justifyContent:"center",color:"#555",flexShrink:0,background:"#161616",borderRadius:2}}>T</span>
                        }
                        {/* name */}
                        <span style={{flex:1,fontSize:11,color:el.id===selectedElId?"#bbb":"#555",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",fontFamily:"DM Sans,sans-serif"}}>
                          {el.name||el.text||"Element"}
                        </span>
                        {/* layer up/down */}
                        <div style={{display:"flex",flexDirection:"column",gap:1,flexShrink:0}}>
                          <button
                            onClick={e=>{e.stopPropagation(); moveElInLayer(el.id, 1);}}
                            disabled={isTop}
                            title="Naikkan layer"
                            style={{padding:"1px 5px",background:"transparent",border:"none",
                              color:isTop?"#252525":"#444",cursor:isTop?"default":"pointer",
                              fontSize:10,lineHeight:1,borderRadius:2}}
                            onMouseEnter={e=>{ if(!isTop) e.target.style.color="#C4973A"; }}
                            onMouseLeave={e=>{ e.target.style.color=isTop?"#252525":"#444"; }}>
                            ▲
                          </button>
                          <button
                            onClick={e=>{e.stopPropagation(); moveElInLayer(el.id, -1);}}
                            disabled={isBottom}
                            title="Turunkan layer"
                            style={{padding:"1px 5px",background:"transparent",border:"none",
                              color:isBottom?"#252525":"#444",cursor:isBottom?"default":"pointer",
                              fontSize:10,lineHeight:1,borderRadius:2}}
                            onMouseEnter={e=>{ if(!isBottom) e.target.style.color="#C4973A"; }}
                            onMouseLeave={e=>{ e.target.style.color=isBottom?"#252525":"#444"; }}>
                            ▼
                          </button>
                        </div>
                        <IBtn danger onClick={e=>{e.stopPropagation();deleteEl(el.id);}}>×</IBtn>
                      </div>
                    );
                  })}
                </>
              )}
            </div>
          )}
        </div>

        {/* CANVAS */}
        <div ref={canvasWrapRef} style={S.canvasWrap} onClick={()=>setSelEl(null)}>
          {/* Section dots nav */}
          <div style={{position:"absolute",left:14,top:"50%",transform:"translateY(-50%)",display:"flex",flexDirection:"column",gap:5,zIndex:10}}>
            {sections.map((s,i) => (
              <div key={s.id} onClick={()=>{setActiveId(s.id);setSelEl(null);}} title={s.name}
                style={{width:5,height:5,borderRadius:"50%",background:s.id===activeId?"#C4973A":"#222",cursor:"pointer",transition:"all .2s",transform:s.id===activeId?"scale(1.8)":"scale(1)"}}/>
            ))}
          </div>

          {activeSection ? (
            <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:8}}>
              <div style={{fontSize:11,color:"#333",letterSpacing:.5,fontFamily:"DM Sans,sans-serif"}}>
                {sections.findIndex(s=>s.id===activeId)+1}/{sections.length} — {activeSection.name}
              </div>
              <div style={{
                width:CANVAS_W, height:CANVAS_H,
                background:activeSection.bgImage?undefined:activeSection.bg,
                backgroundImage:activeSection.bgImage?`url(${activeSection.bgImage})`:"none",
                backgroundSize: activeSection.bgImage
                  ? (activeSection.bgFit==="contain"?"contain"
                    :activeSection.bgFit==="fill"?"100% 100%"
                    :activeSection.bgFit==="center"?"auto"
                    :"cover")
                  : undefined,
                backgroundPosition:"center",
                backgroundRepeat:"no-repeat",
                position:"relative", overflow:"hidden",
                boxShadow:"0 0 0 1px #1e1e1e, 0 24px 80px rgba(0,0,0,.9)",
                transform:`scale(${canvasScale})`,
                transformOrigin:"top center",
                flexShrink:0,
              }}>
                {/* Grid */}
                <div style={{position:"absolute",inset:0,zIndex:998,pointerEvents:"none",
                  backgroundImage:"linear-gradient(rgba(255,255,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px)",
                  backgroundSize:"20px 20px"}}/>

                {/* Section type label */}
                <div style={{position:"absolute",top:8,left:8,fontSize:9,letterSpacing:1.5,textTransform:"uppercase",color:"rgba(255,255,255,0.15)",zIndex:999,fontFamily:"DM Sans,sans-serif"}}>
                  {activeSection.type}
                </div>

                {/* Elements */}
