function submitGuestbook(){const name=document.getElementById('gb-name')?.value;const msg=document.getElementById('gb-msg')?.value;if(!name||!msg)return;gbData.unshift({name,msg});document.getElementById('gb-name').value='';document.getElementById('gb-msg').value='';renderGuestbook();}
