<script>
const inv={groom_name:"{{inv.groom_name}}",bride_name:"{{inv.bride_name}}",groom_father:"{{inv.groom_father}}",groom_mother:"{{inv.groom_mother}}",bride_father:"{{inv.bride_father}}",bride_mother:"{{inv.bride_mother}}",akad_date:"{{inv.akad_date}}",akad_time:"{{inv.akad_time}}",akad_venue:"{{inv.akad_venue}}",akad_address:"{{inv.akad_address}}",resepsi_date:"{{inv.resepsi_date}}",resepsi_time:"{{inv.resepsi_time}}",resepsi_venue:"{{inv.resepsi_venue}}",resepsi_address:"{{inv.resepsi_address}}",maps_url:"{{inv.maps_url}}",countdown_date:"{{inv.countdown_date}}",music_url:"{{inv.music_url}}",love_story:"{{inv.love_story}}",bank_name:"{{inv.bank_name}}",account_number:"{{inv.account_number}}",account_name:"{{inv.account_name}}"};
let cur=0;
const secs=document.querySelectorAll('.section'),total=secs.length;
const dotsEl=document.getElementById('dots');
secs.forEach((_,i)=>{const d=document.createElement('button');d.className='dot'+(i===0?' active':'');d.addEventListener('click',()=>goTo(i));dotsEl.appendChild(d);});
function goTo(i){if(i<0||i>=total)return;cur=i;document.getElementById('track').style.transform='translateY(-'+cur*100+'%)';document.querySelectorAll('.dot').forEach((d,j)=>d.classList.toggle('active',j===cur));}
function coverVisible(){const c=document.getElementById('cover-screen');return c&&c.style.display!=='none';}
let sy=0;
document.addEventListener('touchstart',e=>{sy=e.touches[0].clientY;},{passive:true});
document.addEventListener('touchend',e=>{if(coverVisible())return;const dy=sy-e.changedTouches[0].clientY;if(Math.abs(dy)>40)goTo(dy>0?cur+1:cur-1);});
let wl=false;
document.addEventListener('wheel',e=>{if(coverVisible())return;if(wl)return;wl=true;goTo(e.deltaY>0?cur+1:cur-1);setTimeout(()=>wl=false,750);},{passive:true});
document.addEventListener('keydown',e=>{if(e.key==='ArrowDown'||e.key==='PageDown')goTo(cur+1);if(e.key==='ArrowUp'||e.key==='PageUp')goTo(cur-1);});
function openInvitation(){const c=document.getElementById('cover-screen');if(!c)return;c.style.opacity='0';c.style.pointerEvents='none';setTimeout(()=>{c.style.display='none';dotsEl.style.display='flex';goTo(0);},700);}
function updateCountdown(){const t=new Date(inv.countdown_date)-new Date();if(isNaN(t)||t<=0){['days','hours','mins','secs'].forEach(k=>{const e=document.getElementById('cd-'+k);if(e)e.textContent='00';});return;}const d=Math.floor(t/86400000),h=Math.floor((t%86400000)/3600000),m=Math.floor((t%3600000)/60000),s=Math.floor((t%60000)/1000);const pad=n=>String(n).padStart(2,'0');['days','hours','mins','secs'].forEach((k,i)=>{const e=document.getElementById('cd-'+k);if(e)e.textContent=pad([d,h,m,s][i]);});}
if(document.getElementById('cd-days')){updateCountdown();setInterval(updateCountdown,1000);}
