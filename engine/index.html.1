let _id = 200;
const uid = () => ++_id;

// ─── LocalStorage persistence helpers ────────────────────────────────────────
const STORAGE_KEY = "hk_theme_generator_v1";
const STORAGE_INV = "hk_inv_data_v1";
function saveDraft(sections, invData) {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(sections));
    localStorage.setItem(STORAGE_INV, JSON.stringify(invData));
  } catch(e) {}
}
function loadDraft() {
  try {
    const s = localStorage.getItem(STORAGE_KEY);
    const d = localStorage.getItem(STORAGE_INV);
    return { sections: s ? JSON.parse(s) : null, invData: d ? JSON.parse(d) : null };
  } catch(e) { return { sections: null, invData: null }; }
}
function clearDraft() {
  try { localStorage.removeItem(STORAGE_KEY); localStorage.removeItem(STORAGE_INV); } catch(e) {}
}

// Default text element
const makeTextEl = (text="Teks Baru", x=80, y=200) => ({
