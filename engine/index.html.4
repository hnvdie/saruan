      <Field label="Warna Aksen">
        <div style={{display:"flex",gap:8,alignItems:"center"}}>
          <input type="color" value={el.accent||"#C4973A"} onChange={e=>upd({accent:e.target.value})} style={{width:36,height:28,border:"none",cursor:"pointer",padding:0,borderRadius:4}}/>
          <input value={el.accent||"#C4973A"} onChange={e=>upd({accent:e.target.value})} style={{...S.inp,flex:1,fontFamily:"monospace",fontSize:11}}/>
        </div>
      </Field>
      <Field label="Style">
        <div style={{display:"flex",gap:4}}>
          {[["dark","🌑 Dark"],["light","☀️ Light"]].map(([v,l])=><button key={v} onClick={()=>upd({wStyle:v})} style={{flex:1,padding:"5px 0",background:(el.wStyle||"dark")===v?"#1a2a1a":"#181818",border:`1px solid ${(el.wStyle||"dark")===v?"#7D9470":"#252525"}`,color:(el.wStyle||"dark")===v?"#9CD889":"#555",borderRadius:3,cursor:"pointer",fontSize:10,fontFamily:"DM Sans,sans-serif"}}>{l}</button>)}
        </div>
      </Field>
      <Field label={`Border Radius — ${el.radius||4}px`}><Sld value={el.radius||4} min={0} max={40} onChange={v=>upd({radius:v})}/></Field>
      <Div label="Posisi & Ukuran"/>
      <Field label={`X — ${el.x}px`}><Sld value={el.x} min={-50} max={CANVAS_W} onChange={v=>upd({x:v})}/></Field>
      <Field label={`Y — ${el.y}px`}><Sld value={el.y} min={-CANVAS_H} max={CANVAS_H} onChange={v=>upd({y:v})}/></Field>
      <Field label={`Lebar — ${el.width}px`}><Sld value={el.width} min={100} max={CANVAS_W+50} onChange={v=>upd({width:v})}/></Field>
      <Field label={`Tinggi — ${el.height||400}px`}><Sld value={el.height||400} min={80} max={CANVAS_H*2} onChange={v=>upd({height:v})}/></Field>
      <Field label={`Z-Index — ${el.zIndex||10}`}><Sld value={el.zIndex||10} min={1} max={50} onChange={v=>upd({zIndex:v})}/></Field>
      <Field label={`Opacity — ${Math.round((el.opacity||1)*100)}%`}><Sld value={el.opacity||1} min={0} max={1} step={0.01} onChange={v=>upd({opacity:v})}/></Field>
      {el.widgetType==="maps"&&<><Div label="Maps"/><Field label="Mode"><div style={{display:"flex",gap:4}}>{[["embed","📍 Embed"],["button","🔗 Tombol"]].map(([v,l])=><button key={v} onClick={()=>upd({mapsLayout:v})} style={{flex:1,padding:"5px 0",background:(el.mapsLayout||"embed")===v?"#1a2a1a":"#181818",border:`1px solid ${(el.mapsLayout||"embed")===v?"#7D9470":"#252525"}`,color:(el.mapsLayout||"embed")===v?"#9CD889":"#555",borderRadius:3,cursor:"pointer",fontSize:10,fontFamily:"DM Sans,sans-serif"}}>{l}</button>)}</div></Field><Field label="Teks Tombol"><input value={el.mapsBtnText||"Buka di Google Maps"} onChange={e=>upd({mapsBtnText:e.target.value})} style={S.inp}/></Field><div style={{padding:"7px 9px",background:"#0f1a0f",border:"1px solid #1a2a1a",borderRadius:4,fontSize:10,color:"#4a6a4a",fontFamily:"DM Sans,sans-serif",lineHeight:1.8}}>💡 Link URL → Data: <b style={{color:"#6a8a6a"}}>inv.maps_url</b><br/>Embed URL → Data: <b style={{color:"#6a8a6a"}}>inv.maps_embed</b><br/>Format embed: google.com/maps/embed?pb=...</div></>}
      {el.widgetType==="gallery"&&<><Div label="Gallery"/>
        <Field label="Style"><div style={{display:"flex",gap:3,flexWrap:"wrap"}}>
          {[["grid","Grid"],["slide","Slide"],["polaroid","Polaroid"],["masonry","Masonry"]].map(([v,l])=><button key={v} onClick={()=>upd({galleryStyle:v})} style={{flex:1,padding:"5px 2px",...boolBtn((el.galleryStyle||"grid")===v)}}>{l}</button>)}
        </div></Field>
        <Field label="Kolom"><div style={{display:"flex",gap:3}}>{[["1","1"],["2","2"],["3","3"]].map(([v,l])=><button key={v} onClick={()=>upd({galleryLayout:v})} style={{flex:1,padding:"5px 2px",...boolBtn((el.galleryLayout||"2")===v)}}>{l}</button>)}</div></Field>
        <Field label="Bentuk"><div style={{display:"flex",gap:3}}>{[["kotak","Kotak"],["rounded","Bulat"],["circle","Lingkaran"]].map(([v,l])=><button key={v} onClick={()=>upd({galleryShape:v})} style={{flex:1,padding:"5px 2px",...boolBtn((el.galleryShape||"kotak")===v)}}>{l}</button>)}</div></Field>
        <Field label={`Gap — ${el.galleryGap||8}px`}><Sld value={el.galleryGap||8} min={0} max={20} onChange={v=>upd({galleryGap:v})}/></Field>
        <button onClick={()=>gRef.current?.click()} style={{...S.btnS,width:"100%",fontSize:11}}>📷 Upload Foto Gallery ({(el.galleryImages||[]).length} foto)</button>
        {(el.galleryImages||[]).length>0&&<button onClick={()=>upd({galleryImages:[]})} style={{...S.btnS,width:"100%",fontSize:11,color:"#c55",borderColor:"#3a1515"}}>🗑 Hapus Semua Foto</button>}
        <input key={gKey} ref={gRef} type="file" accept="image/*" multiple style={{display:"none"}} onChange={e=>{onGallery(e,el.id);setGKey(k=>k+1);}}/></>}
      {el.widgetType==="countdown"&&<><Div label="Countdown"/>
        <Field label="Layout"><div style={{display:"flex",gap:3}}>
          {[["cards","Cards"],["flip","Flip"],["minimal","Minimal"]].map(([v,l])=><button key={v} onClick={()=>upd({cdLayout:v})} style={{flex:1,padding:"5px 2px",...boolBtn((el.cdLayout||"cards")===v)}}>{l}</button>)}
        </div></Field>
        <Field label="Warna Angka"><div style={{display:"flex",gap:8,alignItems:"center"}}><input type="color" value={el.cdAccent||el.accent||"#C4973A"} onChange={e=>upd({cdAccent:e.target.value})} style={{width:36,height:28,border:"none",cursor:"pointer",padding:0,borderRadius:4}}/><input value={el.cdAccent||el.accent||"#C4973A"} onChange={e=>upd({cdAccent:e.target.value})} style={{...S.inp,flex:1,fontFamily:"monospace",fontSize:11}}/></div></Field>
        <div style={{padding:"7px 9px",background:"#0f1a0f",border:"1px solid #1a2a1a",borderRadius:4,fontSize:10,color:"#4a6a4a",fontFamily:"DM Sans,sans-serif",lineHeight:1.7}}>💡 Tanggal target di Data: <b style={{color:"#6a8a6a"}}>inv.countdown_date</b><br/>Format: 2025-07-12T08:00:00</div></>}
      {el.widgetType==="rsvp"&&<><Div label="RSVP"/><Field label="Judul Form"><input value={el.rsvpTitle||"Konfirmasi Kehadiran"} onChange={e=>upd({rsvpTitle:e.target.value})} style={S.inp}/></Field></>}
      {el.widgetType==="guestbook"&&<><Div label="Guestbook"/><Field label="Judul"><input value={el.gbTitle||"Buku Tamu"} onChange={e=>upd({gbTitle:e.target.value})} style={S.inp}/></Field></>}
      {el.widgetType==="gift"&&<><Div label="Amplop"/><Field label="Judul"><input value={el.giftTitle||"Amplop Digital"} onChange={e=>upd({giftTitle:e.target.value})} style={S.inp}/></Field><Field label="Subjudul"><input value={el.giftSubtitle||"Doa tulus Anda..."} onChange={e=>upd({giftSubtitle:e.target.value})} style={S.inp}/></Field><div style={{padding:"7px 9px",background:"#0f1a0f",border:"1px solid #1a2a1a",borderRadius:4,fontSize:10,color:"#4a6a4a",fontFamily:"DM Sans,sans-serif"}}>💡 Data rekening dari DB Flask (tabel gifts)</div></>}
      <div style={{display:"flex",gap:4,marginTop:4}}>
        <button onClick={onCopy} title="Salin ke section lain (Ctrl+C)" style={{flex:1,padding:"7px 0",background:"#181818",border:"1px solid #222",color:"#5a7aaa",borderRadius:4,cursor:"pointer",fontSize:10,fontFamily:"DM Sans,sans-serif"}}>⎘ Salin</button>
        <button onClick={onDup} style={{flex:1,padding:"7px 0",background:"#181818",border:"1px solid #222",color:"#666",borderRadius:4,cursor:"pointer",fontSize:10,fontFamily:"DM Sans,sans-serif"}}>Duplikat</button>
        <button onClick={onDel} style={{flex:1,padding:"7px 0",background:"#1a0a0a",border:"1px solid #3a1515",color:"#c55",borderRadius:4,cursor:"pointer",fontSize:10,fontFamily:"DM Sans,sans-serif"}}>Hapus</button>
      </div>
    </div>
  );
}

// ─── ElProps ──────────────────────────────────────────────────────────────────
function ElProps({el,upd,onDel,onDup,onCopy,onFwd,onBwd,invData,onFP,setInvData}){
  const dummyRef=useRef(null);
  const PVARS=new Set(["inv.groom_photo_url","inv.bride_photo_url"]);
  const isPhoto=el.isVar&&PVARS.has(el.varKey);
  return(
    <div style={{display:"flex",flexDirection:"column",gap:11,paddingTop:4}}>
      <PLabel>{el.type==="image"?"🖼 Image":"T Teks"} — {el.name||"El"}</PLabel>
      {el.type==="text"&&<>
        <Field label="Teks"><textarea value={el.text} onChange={e=>upd({text:e.target.value})} rows={2} style={{...S.inp,resize:"vertical",fontSize:11,lineHeight:1.5}}/></Field>
        <Field label="Variabel Data">
          <div style={{display:"flex",gap:4,alignItems:"center",marginBottom:4}}>
            <input type="checkbox" checked={!!el.isVar} onChange={e=>upd({isVar:e.target.checked})} style={{accentColor:"#C4973A"}}/>
            <span style={{fontSize:11,color:"#555",fontFamily:"DM Sans,sans-serif"}}>Pakai variabel</span>
          </div>
          {el.isVar&&<select value={el.varKey||""} onChange={e=>upd({varKey:e.target.value})} style={{...S.inp,cursor:"pointer",fontSize:11}}><option value="">— Pilih —</option>{DATA_VARS.map(v=><option key={v.key} value={v.key}>{v.label}</option>)}</select>}
        </Field>
        {isPhoto&&<>
          <Field label={`Tinggi Foto — ${el.height||el.width||150}px`}><Sld value={el.height||el.width||150} min={40} max={CANVAS_H} onChange={v=>upd({height:v})}/></Field>
          <Field label="Border Radius"><div style={{display:"flex",gap:4}}>{[["0","Kotak"],["12","Rounded"],["50%","Bulat"]].map(([v,l])=><button key={v} onClick={()=>upd({borderRadius:v})} style={{flex:1,padding:"4px 2px",...boolBtn(String(el.borderRadius)===v)}}>{l}</button>)}</div></Field>
          <Field label="Preview Foto (sementara)">
            <div style={{fontSize:9,color:"#444",marginBottom:5,fontFamily:"DM Sans,sans-serif",lineHeight:1.6}}>
              Upload foto dummy hanya untuk tampilan editor.<br/>
              <span style={{color:"#2a5a2a"}}>Export tetap pakai <b style={{color:"#4a8a4a"}}>{`{{${el.varKey}}}`}</b></span>
            </div>
            {(invData[el.varKey.replace("inv.","")]||"").startsWith("data:")&&<div style={{position:"relative",marginBottom:5}}>
              <img src={invData[el.varKey.replace("inv.","")]} style={{width:"100%",height:60,objectFit:"cover",borderRadius:3,border:"1px solid #222"}}/>
              <button onClick={()=>setInvData(p=>({...p,[el.varKey.replace("inv.","")]:""}))} style={{position:"absolute",top:2,right:2,width:16,height:16,background:"#c55",border:"none",borderRadius:"50%",color:"#fff",fontSize:9,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center"}}>×</button>
            </div>}
            <button onClick={()=>dummyRef.current?.click()} style={{...S.btnS,width:"100%",fontSize:11}}>
              {(invData[el.varKey.replace("inv.","")]||"").startsWith("data:")?"🔄 Ganti Preview":"📷 Upload Preview"}
            </button>
            <input ref={dummyRef} type="file" accept="image/*" style={{display:"none"}} onChange={e=>{
              const f=e.target.files?.[0];if(!f)return;
              const r=new FileReader();
              r.onload=ev=>setInvData(p=>({...p,[el.varKey.replace("inv.","")]:ev.target.result}));
              r.readAsDataURL(f);e.target.value="";
            }}/>
          </Field>
        </>} 
        {!el.isVar&&<><Div label="Font"/>
          <Field label="Font"><button onClick={onFP} style={{...S.btnS,width:"100%",fontSize:12,fontFamily:`'${el.fontFamily||"Playfair Display"}',serif`,textAlign:"left",padding:"6px 10px"}}>{el.fontFamily||"Playfair Display"} ›</button></Field>
          <Field label={`Ukuran — ${el.fontSize||24}px`}><Sld value={el.fontSize||24} min={8} max={120} onChange={v=>upd({fontSize:v})}/></Field>
          <Field label="Warna"><div style={{display:"flex",gap:8,alignItems:"center"}}><input type="color" value={el.color||"#ffffff"} onChange={e=>upd({color:e.target.value})} style={{width:36,height:28,border:"none",cursor:"pointer",padding:0,borderRadius:4}}/><input value={el.color||"#ffffff"} onChange={e=>upd({color:e.target.value})} style={{...S.inp,flex:1,fontFamily:"monospace",fontSize:11}}/></div></Field>
          <Field label="Alignment"><div style={{display:"flex",gap:4}}>{[["left","◁"],["center","◈"],["right","▷"]].map(([v,l])=><button key={v} onClick={()=>upd({align:v})} style={{flex:1,padding:"5px 0",background:(el.align||"center")===v?"#1a2a1a":"#181818",border:`1px solid ${(el.align||"center")===v?"#7D9470":"#252525"}`,color:(el.align||"center")===v?"#9CD889":"#555",borderRadius:3,cursor:"pointer",fontSize:14,lineHeight:1}}>{l}</button>)}</div></Field>
          <Field label="Style"><div style={{display:"flex",gap:4}}>{[["italic","Italic"],["bold","Bold"]].map(v=><button key={v} onClick={()=>{if(v==="bold")upd({fontWeight:el.fontWeight==="700"?"400":"700"});else upd({fontStyle:el.fontStyle===v?"normal":v});}} style={{flex:1,padding:"4px 0",...boolBtn(v==="bold"?el.fontWeight==="700":el.fontStyle===v)}}>{v}</button>)}</div></Field>
          <Field label={`Letter Spacing — ${el.letterSpacing||0}px`}><Sld value={el.letterSpacing||0} min={-2} max={20} onChange={v=>upd({letterSpacing:v})}/></Field>
          <Field label={`Line Height — ${el.lineHeight||1.4}`}><Sld value={el.lineHeight||1.4} min={0.8} max={3} step={0.05} onChange={v=>upd({lineHeight:v})}/></Field>
          <Field label="Shadow"><div style={{display:"flex",gap:6,alignItems:"center"}}><input type="checkbox" checked={!!el.shadow} onChange={e=>upd({shadow:e.target.checked})} style={{accentColor:"#C4973A"}}/><span style={{fontSize:11,color:"#555",fontFamily:"DM Sans,sans-serif"}}>Text shadow</span></div></Field>
        </>}
      </>}
      <Div label="Posisi"/>
      <Field label={`X — ${el.x}px`}><Sld value={el.x} min={-CANVAS_W} max={CANVAS_W} onChange={v=>upd({x:v})}/></Field>
      <Field label={`Y — ${el.y}px`}><Sld value={el.y} min={-CANVAS_H} max={CANVAS_H*1.5} onChange={v=>upd({y:v})}/></Field>
      {el.type==="image"&&<Field label={`Lebar — ${el.width}px`}><Sld value={el.width} min={10} max={CANVAS_W*1.5} onChange={v=>upd({width:v})}/></Field>}
      {el.type==="text"&&!el.isVar&&<Field label={`Lebar Box — ${el.width||200}px`}><Sld value={el.width||200} min={20} max={CANVAS_W} onChange={v=>upd({width:v})}/></Field>}
      <Field label={`Rotasi — ${el.rotation||0}°`}><Sld value={el.rotation||0} min={-180} max={180} onChange={v=>upd({rotation:v})}/></Field>
      {el.type==="image"&&<Field label="Flip"><div style={{display:"flex",gap:6}}><button onClick={()=>upd({flipH:!el.flipH})} style={{flex:1,padding:"5px 0",...boolBtn(el.flipH,"#4A90D9")}}>↔ H</button><button onClick={()=>upd({flipV:!el.flipV})} style={{flex:1,padding:"5px 0",...boolBtn(el.flipV,"#9B59B6")}}>↕ V</button></div></Field>}
      <Div label="Tampilan"/>
      <Field label={`Opacity — ${Math.round((el.opacity||1)*100)}%`}><Sld value={el.opacity||1} min={0} max={1} step={0.01} onChange={v=>upd({opacity:v})}/></Field>
      <Field label={`Z-Index — ${el.zIndex||10}`}><div style={{display:"flex",gap:6,alignItems:"center"}}><Sld value={el.zIndex||10} min={1} max={50} onChange={v=>upd({zIndex:v})}/><button onClick={onFwd} style={S.micro}>↑</button><button onClick={onBwd} style={S.micro}>↓</button></div></Field>
      <Div label="Animasi"/>
      <Field label="Animasi"><select value={el.animation||"none"} onChange={e=>upd({animation:e.target.value})} style={{...S.inp,cursor:"pointer"}}>{ANIMATIONS.map(a=><option key={a.id} value={a.id}>{a.label}</option>)}</select></Field>
      {el.animation&&el.animation!=="none"&&(["sway","float","pulse","shimmer","bounce"].includes(el.animation)?<Field label={`Durasi — ${el.animDuration||4}s`}><Sld value={el.animDuration||4} min={0.5} max={12} step={0.5} onChange={v=>upd({animDuration:v})}/></Field>:<Field label={`Delay — ${el.animDelay||0}s`}><Sld value={el.animDelay||0} min={0} max={6} step={0.1} onChange={v=>upd({animDelay:v})}/></Field>)}
      <div style={{display:"flex",gap:4,marginTop:4}}>
        <button onClick={onCopy} title="Salin ke section lain (Ctrl+C)" style={{flex:1,padding:"7px 0",background:"#181818",border:"1px solid #222",color:"#5a7aaa",borderRadius:4,cursor:"pointer",fontSize:10,fontFamily:"DM Sans,sans-serif"}}>⎘ Salin</button>
        <button onClick={onDup} style={{flex:1,padding:"7px 0",background:"#181818",border:"1px solid #222",color:"#666",borderRadius:4,cursor:"pointer",fontSize:10,fontFamily:"DM Sans,sans-serif"}}>Duplikat</button>
        <button onClick={onDel} style={{flex:1,padding:"7px 0",background:"#1a0a0a",border:"1px solid #3a1515",color:"#c55",borderRadius:4,cursor:"pointer",fontSize:10,fontFamily:"DM Sans,sans-serif"}}>Hapus</button>
      </div>
    </div>
  );
}

// ─── UI Primitives ────────────────────────────────────────────────────────────
const boolBtn=(on,col="#7D9470")=>({background:on?"#1a2a1a":"#181818",border:`1px solid ${on?col:"#252525"}`,color:on?col:"#555",borderRadius:3,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif"});
function PLabel({children}){return<div style={{fontSize:10,letterSpacing:1.5,textTransform:"uppercase",color:"#444",fontWeight:700,fontFamily:"DM Sans,sans-serif",marginBottom:4}}>{children}</div>;}
function Div({label}){return<div style={{display:"flex",alignItems:"center",gap:8,margin:"4px 0"}}><div style={{fontSize:9,color:"#2e2e2e",letterSpacing:.8,textTransform:"uppercase",whiteSpace:"nowrap",fontFamily:"DM Sans,sans-serif"}}>{label}</div><div style={{flex:1,height:1,background:"#1a1a1a"}}/></div>;}
function Field({label,children}){return<div><div style={{fontSize:11,color:"#3a3a3a",marginBottom:3,letterSpacing:.2,fontFamily:"DM Sans,sans-serif"}}>{label}</div>{children}</div>;}
function Sld({value,min,max,step=1,onChange}){return<input type="range" value={value} min={min} max={max} step={step} onChange={e=>onChange(step<1?parseFloat(e.target.value):parseInt(e.target.value))} style={{width:"100%",cursor:"pointer",accentColor:"#C4973A"}}/>;}
function IBtn({children,onClick,danger}){return<button onClick={onClick} style={{padding:"2px 5px",background:"transparent",border:"none",color:danger?"#522":"#333",cursor:"pointer",fontSize:13,lineHeight:1,borderRadius:3,fontFamily:"DM Sans,sans-serif"}} onMouseEnter={e=>e.target.style.color=danger?"#f55":"#aaa"} onMouseLeave={e=>e.target.style.color=danger?"#522":"#333"}>{children}</button>;}
function Tbtn({children,onClick,col}){return<button onClick={onClick} style={{padding:"5px 11px",background:"#181818",border:"1px solid #222",color:col||"#777",borderRadius:4,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif",display:"flex",alignItems:"center",gap:4}}>{children}</button>;}

const S={
  root:{display:"flex",flexDirection:"column",height:"100vh",background:"#0a0a0a",color:"#ccc",fontFamily:"'DM Sans',system-ui,sans-serif",fontSize:13,overflow:"hidden"},
  topbar:{display:"flex",alignItems:"center",gap:7,padding:"0 14px",height:44,background:"#0e0e0e",borderBottom:"1px solid #161616",flexShrink:0},
  logo:{fontWeight:700,fontSize:14,color:"#C4973A",letterSpacing:.5,fontFamily:"DM Sans,sans-serif"},
  body:{display:"flex",flex:1,overflow:"hidden",minHeight:0},
  left:{width:200,background:"#0e0e0e",borderRight:"1px solid #161616",display:"flex",flexDirection:"column",overflow:"hidden",flexShrink:0},
  canvas:{flex:1,display:"flex",alignItems:"flex-start",justifyContent:"center",background:"#080808",overflow:"auto",position:"relative",padding:"20px 40px"},
  right:{width:230,background:"#0e0e0e",borderLeft:"1px solid #161616",overflowY:"auto",padding:"0 12px 24px",flexShrink:0,display:"flex",flexDirection:"column"},
  inp:{width:"100%",padding:"6px 8px",background:"#141414",border:"1px solid #222",color:"#bbb",borderRadius:4,fontSize:12,outline:"none",fontFamily:"'DM Sans',sans-serif"},
  btnP:{padding:"7px 14px",background:"#C4973A",border:"none",color:"#0a0a0a",borderRadius:4,cursor:"pointer",fontWeight:700,fontSize:12,fontFamily:"'DM Sans',sans-serif"},
  btnS:{padding:"6px 12px",background:"#141414",border:"1px solid #222",color:"#666",borderRadius:4,cursor:"pointer",fontSize:12,fontFamily:"'DM Sans',sans-serif"},
  micro:{padding:"3px 6px",background:"#161616",border:"1px solid #222",color:"#555",borderRadius:3,cursor:"pointer",fontSize:12,fontFamily:"DM Sans,sans-serif",flexShrink:0},
};


// ─── ThemeConfigModal ─────────────────────────────────────────────────────────
function ThemeConfigModal({cfg,setCfg,onClose,sections}){
  const upd=patch=>setCfg(p=>({...p,...patch}));
  const previewColor=sections[0]?.bg||cfg.preview_color||"#1a0e08";
  return(
    <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,.85)",zIndex:9998,display:"flex",alignItems:"center",justifyContent:"center"}} onClick={e=>{if(e.target===e.currentTarget)onClose();}}>
      <div style={{background:"#111",border:"1px solid #222",borderRadius:8,width:500,maxWidth:"95vw",maxHeight:"85vh",display:"flex",flexDirection:"column",overflow:"hidden"}}>
        <div style={{padding:"14px 18px",borderBottom:"1px solid #1e1e1e",display:"flex",alignItems:"center"}}>
          <span style={{flex:1,fontWeight:700,fontSize:14,color:"#C4973A",fontFamily:"DM Sans,sans-serif"}}>🎨 Konfigurasi Tema</span>
          <button onClick={onClose} style={{background:"none",border:"none",color:"#555",cursor:"pointer",fontSize:20,lineHeight:1}}>✕</button>
        </div>
        <div style={{overflowY:"auto",flex:1,padding:"16px 18px",display:"flex",flexDirection:"column",gap:12}}>

          <div style={{padding:"10px 12px",background:"#0f1a0f",border:"1px solid #1a3a1a",borderRadius:6,fontSize:11,color:"#4a7a4a",fontFamily:"DM Sans,sans-serif",lineHeight:1.8}}>
            📦 Export ZIP akan menghasilkan:<br/>
            <span style={{color:"#6a9a6a"}}>templates/themes/<b>{cfg.id||"tema-baru"}</b>.html</span><br/>
            <span style={{color:"#6a9a6a"}}>themes/<b>{cfg.id||"tema-baru"}</b>.json</span><br/>
            <span style={{color:"#6a9a6a"}}>static/themes/<b>{cfg.id||"tema-baru"}</b>/... (semua aset)</span>
          </div>

          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
            <div>
              <div style={{fontSize:10,color:"#3a3a3a",marginBottom:3,fontFamily:"DM Sans,sans-serif"}}>ID Tema (lowercase, no spasi)</div>
              <input value={cfg.id||""} onChange={e=>upd({id:e.target.value.toLowerCase().replace(/[^a-z0-9_-]/g,"")})} placeholder="tema-baru" style={{...S.inp,fontFamily:"monospace",fontSize:12}}/>
            </div>
            <div>
              <div style={{fontSize:10,color:"#3a3a3a",marginBottom:3,fontFamily:"DM Sans,sans-serif"}}>Nama Tampil</div>
              <input value={cfg.name||""} onChange={e=>upd({name:e.target.value})} placeholder="Nama Tema" style={S.inp}/>
            </div>
          </div>

          <div>
            <div style={{fontSize:10,color:"#3a3a3a",marginBottom:3,fontFamily:"DM Sans,sans-serif"}}>Deskripsi</div>
            <textarea value={cfg.description||""} onChange={e=>upd({description:e.target.value})} rows={2} placeholder="Deskripsi singkat tema..." style={{...S.inp,resize:"vertical"}}/>
          </div>

          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
            <div>
              <div style={{fontSize:10,color:"#3a3a3a",marginBottom:3,fontFamily:"DM Sans,sans-serif"}}>Accent Color</div>
              <div style={{display:"flex",gap:6,alignItems:"center"}}>
                <input type="color" value={cfg.accent_color||"#C4973A"} onChange={e=>upd({accent_color:e.target.value})} style={{width:36,height:28,border:"none",cursor:"pointer",padding:0,borderRadius:4,flexShrink:0}}/>
                <input value={cfg.accent_color||"#C4973A"} onChange={e=>upd({accent_color:e.target.value})} style={{...S.inp,fontFamily:"monospace",fontSize:11}}/>
              </div>
            </div>
            <div>
              <div style={{fontSize:10,color:"#3a3a3a",marginBottom:3,fontFamily:"DM Sans,sans-serif"}}>Preview Color (auto dari section 0)</div>
              <div style={{display:"flex",gap:6,alignItems:"center"}}>
                <div style={{width:36,height:28,background:previewColor,borderRadius:4,border:"1px solid #333",flexShrink:0}}/>
                <input value={previewColor} readOnly style={{...S.inp,fontFamily:"monospace",fontSize:11,color:"#555",cursor:"default"}}/>
              </div>
            </div>
          </div>

          <div>
            <div style={{fontSize:10,color:"#3a3a3a",marginBottom:3,fontFamily:"DM Sans,sans-serif"}}>Tags (pisah dengan koma)</div>
            <input value={cfg.tags||""} onChange={e=>upd({tags:e.target.value})} placeholder="luxury,dark,elegant,gold" style={S.inp}/>
          </div>

          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:12}}>
            <div>
              <div style={{fontSize:10,color:"#3a3a3a",marginBottom:3,fontFamily:"DM Sans,sans-serif"}}>Harga (Rp)</div>
              <input type="number" value={cfg.price||25000} onChange={e=>upd({price:parseInt(e.target.value)||0})} style={S.inp}/>
            </div>
            <div>
              <div style={{fontSize:10,color:"#3a3a3a",marginBottom:3,fontFamily:"DM Sans,sans-serif"}}>Harga Asli (coret)</div>
              <input type="number" value={cfg.price_original||50000} onChange={e=>upd({price_original:parseInt(e.target.value)||0})} style={S.inp}/>
            </div>
            <div>
              <div style={{fontSize:10,color:"#3a3a3a",marginBottom:3,fontFamily:"DM Sans,sans-serif"}}>Catatan Harga</div>
              <input value={cfg.price_note||""} onChange={e=>upd({price_note:e.target.value})} placeholder="" style={S.inp}/>
            </div>
          </div>

          <div style={{padding:"10px 12px",background:"#141414",border:"1px solid #1e1e1e",borderRadius:6,fontSize:10,color:"#444",fontFamily:"DM Sans,sans-serif",lineHeight:1.8}}>
            💡 Setelah export, extract ZIP di root folder Flask:<br/>
            <span style={{color:"#555",fontFamily:"monospace"}}>cd /path/to/app && unzip {cfg.id||"tema-baru"}.zip</span><br/>
            Semua file otomatis masuk ke tempat yang benar.
          </div>
        </div>
        <div style={{padding:"12px 18px",borderTop:"1px solid #181818",display:"flex",gap:8}}>
          <button onClick={onClose} style={{flex:1,padding:"9px",background:"#1a2a1a",border:"1px solid #2a3a2a",color:"#7D9470",borderRadius:4,cursor:"pointer",fontSize:12,fontWeight:700,fontFamily:"DM Sans,sans-serif"}}>✓ Simpan & Tutup</button>
        </div>
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>
