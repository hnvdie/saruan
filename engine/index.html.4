    <div style="width:32px;height:1px;background:${acc};opacity:.4;margin:8px auto 0;"></div>
  </div>
  <input id="rn-${wid}" placeholder="Nama Anda" style="width:100%;padding:10px 14px;background:${ib};border:1px solid ${acc}44;color:${ic};font-family:'DM Sans',sans-serif;font-size:13px;border-radius:${r}px;outline:none;margin-bottom:8px;display:block;"/>
  <input id="rg-${wid}" type="number" min="1" placeholder="Jumlah Tamu" style="width:100%;padding:10px 14px;background:${ib};border:1px solid ${acc}44;color:${ic};font-family:'DM Sans',sans-serif;font-size:13px;border-radius:${r}px;outline:none;margin-bottom:8px;display:block;"/>
  <select id="ra-${wid}" style="width:100%;padding:10px 14px;background:${dk?"#1a1a1a":ib};border:1px solid ${acc}44;color:${ic};font-family:'DM Sans',sans-serif;font-size:13px;border-radius:${r}px;outline:none;margin-bottom:8px;display:block;">
    <option value="">Konfirmasi Kehadiran ▾</option>
    <option value="hadir">Insya Allah Hadir 🤍</option>
    <option value="tidak">Tidak Dapat Hadir</option>
  </select>
  <textarea id="rm-${wid}" placeholder="Ucapan &amp; Doa..." rows="3" style="width:100%;padding:10px 14px;background:${ib};border:1px solid ${acc}44;color:${ic};font-family:'DM Sans',sans-serif;font-size:13px;border-radius:${r}px;outline:none;resize:none;display:block;margin-bottom:12px;"></textarea>
  <button onclick="submitRSVP_${wid}()" style="width:100%;padding:12px;background:${acc};border:none;color:#000;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:700;border-radius:${r}px;cursor:pointer;">Kirim Konfirmasi 💌</button>
</div>
<div id="rsvp-ok-${wid}" style="display:none;padding:60px 20px;text-align:center;">
  <div style="font-family:'Playfair Display',serif;font-size:40px;color:${acc};">✦</div>
  <div style="font-family:'Playfair Display',serif;font-size:22px;color:${dk?"#fff":"#333"};margin-top:12px;">Terima Kasih</div>
  <div style="font-size:13px;color:#888;margin-top:8px;font-family:'DM Sans',sans-serif;line-height:1.7;">Konfirmasi Anda telah kami terima.<br>Kami sangat menantikan kehadiran Anda.</div>
</div>
</div>
<script>
function submitRSVP_${wid}(){
  var name=document.getElementById('rn-${wid}').value.trim();
  var count=document.getElementById('rg-${wid}').value||'1';
  var attend=document.getElementById('ra-${wid}').value;
  var msg=document.getElementById('rm-${wid}').value.trim();
  if(!name||!attend){alert('Mohon isi nama dan konfirmasi kehadiran.');return;}
  var btn=document.querySelector('#rsvp-form-${wid} button');
  btn.textContent='Mengirim...';btn.disabled=true;
  fetch('{{url_for("user_rsvp",inv_id=inv.id)}}',{
    method:'POST',
    headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
    body:JSON.stringify({name:name,count:count,attend:attend,message:msg})
  }).then(r=>r.json()).then(d=>{
    document.getElementById('rsvp-form-${wid}').style.display='none';
    document.getElementById('rsvp-ok-${wid}').style.display='block';
  }).catch(()=>{
    document.getElementById('rsvp-form-${wid}').style.display='none';
    document.getElementById('rsvp-ok-${wid}').style.display='block';
  });
}
<\/script>`;}
    if(el.widgetType==="maps"){const em=inv.maps_embed||"",lk=inv.maps_url||"#",bt=el.mapsBtnText||"Buka di Google Maps";if(el.mapsLayout==="embed"&&em)return `<div style="${ws}border-radius:${r}px;overflow:hidden;"><iframe src="${em}" width="100%" height="100%" style="border:0;display:block;" allowfullscreen="" loading="lazy"></iframe><a href="${lk}" target="_blank" rel="noopener" style="position:absolute;bottom:14px;left:50%;transform:translateX(-50%);display:inline-block;padding:9px 22px;background:${acc};color:#000;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;border-radius:${r}px;text-decoration:none;white-space:nowrap;box-shadow:0 2px 12px rgba(0,0,0,.5);">${bt}</a></div>`;return `<div style="position:absolute;left:${el.x}px;top:${el.y}px;width:${el.width}px;z-index:${el.zIndex};text-align:center;padding:20px 0;"><a href="${lk}" target="_blank" rel="noopener" style="display:inline-block;padding:13px 30px;background:${acc};color:#000;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:700;border-radius:${r}px;text-decoration:none;">${bt}</a></div>`;}
    if(el.widgetType==="gallery"){const lay=el.galleryLayout||"2",shp=el.galleryShape||"kotak",gap=el.galleryGap||8,cols=lay==="1"?"1fr":lay==="3"?"repeat(3,1fr)":"repeat(2,1fr)",br=shp==="circle"?"50%":shp==="rounded"?"12px":"2px",imgH=lay==="1"||shp==="portrait"?"220px":"150px",tit=el.title?`<div style="text-align:center;margin-bottom:${gap}px;font-family:'Playfair Display',serif;font-size:20px;color:${acc};">${el.title}</div>`:"";const statics=(el.galleryImages||[]).map(src=>{const ps=(imagePathMap&&imagePathMap[src])||src;return`<div style="overflow:hidden;border-radius:${br};"><img src="${ps}" style="width:100%;height:${imgH};object-fit:cover;display:block;cursor:pointer;" onclick="openLightbox('${src}','${wid}')"/></div>`).join("");const jinja=`{%- for photo in photos %}<div style="overflow:hidden;border-radius:${br};"><img src="{{ photo_src(photo) }}" style="width:100%;height:${imgH};object-fit:cover;display:block;cursor:pointer;" onclick="openLightbox('{{ photo_src(photo) }}','${wid}')" loading="lazy"/></div>{%- endfor %}`;const imgs=statics||('{%- if photos %}'+jinja+'{%- else %}<div style="color:#555;text-align:center;padding:30px;font-size:12px;font-family:\'DM Sans\',sans-serif;grid-column:1/-1;">Gallery akan tampil di sini</div>{%- endif %}');return `<div style="${ws}padding:${gap}px;">${tit}<div style="display:grid;grid-template-columns:${cols};gap:${gap}px;">${imgs}</div></div><div id="lb-${wid}" onclick="this.style.display='none'" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.95);z-index:9999;align-items:center;justify-content:center;cursor:pointer;"><img id="lb-img-${wid}" style="max-width:90%;max-height:90%;object-fit:contain;"/></div>`;}
    if(el.widgetType==="guestbook"){const tit=el.title||el.gbTitle||"Buku Tamu";return `<div style="${ws}">
  <div style="text-align:center;padding:16px 4px 12px;">
    <div style="font-family:'Playfair Display',serif;font-size:20px;color:${tc};">${tit}</div>
    <div style="width:32px;height:1px;background:${acc};opacity:.4;margin:8px auto 0;"></div>
  </div>
  <div id="gb-chat-${wid}" style="display:flex;flex-direction:column;gap:10px;padding:0 4px 12px;overflow-y:auto;max-height:calc(100% - 70px);">
    {%- if rsvps %}
    {%- for r in rsvps %}
