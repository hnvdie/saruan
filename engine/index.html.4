// ─── DataModal ────────────────────────────────────────────────────────────────
function DataModal({invData,setInvData,onClose}){
  return(
    <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,.85)",zIndex:9998,display:"flex",alignItems:"center",justifyContent:"center"}} onClick={e=>{if(e.target===e.currentTarget)onClose();}}>
      <div style={{background:"#111",border:"1px solid #222",borderRadius:8,width:520,maxWidth:"95vw",maxHeight:"80vh",display:"flex",flexDirection:"column",overflow:"hidden"}}>
        <div style={{padding:"14px 18px",borderBottom:"1px solid #1e1e1e",display:"flex",alignItems:"center"}}>
          <span style={{flex:1,fontWeight:700,fontSize:14,color:"#C4973A",fontFamily:"DM Sans,sans-serif"}}>📋 Data Undangan</span>
          <button onClick={onClose} style={{background:"none",border:"none",color:"#555",cursor:"pointer",fontSize:20,lineHeight:1}}>✕</button>
        </div>
        <div style={{overflowY:"auto",flex:1,padding:"14px 18px",display:"flex",flexDirection:"column",gap:10}}>
          {DATA_VARS.map(v=><div key={v.key}><div style={{fontSize:10,color:"#3a3a3a",marginBottom:3,fontFamily:"DM Sans,sans-serif"}}>{v.label}</div><input value={invData[v.key.replace("inv.","")]||""} onChange={e=>setInvData(p=>({...p,[v.key.replace("inv.","")]:e.target.value}))} placeholder={v.example} style={{...S.inp,fontSize:11}}/></div>)}
        </div>
        <div style={{padding:"10px 18px",borderTop:"1px solid #181818"}}><button onClick={onClose} style={{...S.btnP,width:"100%"}}>Tutup</button></div>
      </div>
    </div>
  );
}

// ─── FontPicker ───────────────────────────────────────────────────────────────
function FontPicker({current,search,setSearch,onPick,onClose}){
  return(
    <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,.85)",zIndex:9998,display:"flex",alignItems:"center",justifyContent:"center"}} onClick={e=>{if(e.target===e.currentTarget)onClose();}}>
      <div style={{background:"#111",border:"1px solid #222",borderRadius:8,width:360,maxWidth:"95vw",maxHeight:"70vh",display:"flex",flexDirection:"column",overflow:"hidden"}}>
        <div style={{padding:"10px 14px",borderBottom:"1px solid #1e1e1e",display:"flex",gap:8}}>
          <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="Cari font..." autoFocus style={{...S.inp,flex:1,fontSize:12}}/>
          <button onClick={onClose} style={{background:"none",border:"none",color:"#555",cursor:"pointer",fontSize:18}}>✕</button>
        </div>
        <div style={{overflowY:"auto",flex:1}}>
          {FONTS.filter(f=>!search||f.toLowerCase().includes(search.toLowerCase())).map(f=>(
            <div key={f} onClick={()=>onPick(f)} style={{padding:"9px 16px",cursor:"pointer",fontFamily:`'${f}',serif`,fontSize:16,color:current===f?"#C4973A":"#999",borderBottom:"1px solid #111",background:current===f?"#181818":"transparent"}} onMouseEnter={e=>e.currentTarget.style.background="#141414"} onMouseLeave={e=>e.currentTarget.style.background=current===f?"#181818":"transparent"}>{f}</div>
          ))}
        </div>
      </div>
    </div>
  );
}

// ─── SecProps ─────────────────────────────────────────────────────────────────
