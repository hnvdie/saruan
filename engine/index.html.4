  if(el.widgetType==="rsvp"){const tit=el.title||el.rsvpTitle||"Konfirmasi Kehadiran";return<div style={{position:"absolute",inset:0,overflowY:"auto",padding:"16px 8px"}}><div style={{textAlign:"center",marginBottom:14}}><div style={{fontFamily:"Playfair Display,serif",fontSize:16,color:tc}}>{tit}</div><div style={{width:28,height:1,background:acc,opacity:.4,margin:"7px auto 0"}}/></div>{["Nama Anda","Jumlah Tamu"].map((ph,i)=><div key={i} style={{padding:"9px 12px",background:ib,border:`1px solid ${acc}44`,borderRadius:r,color:ic,fontFamily:"DM Sans,sans-serif",fontSize:12,marginBottom:7}}>{ph}</div>)}<div style={{padding:"9px 12px",background:dk?"#1a1a1a":ib,border:`1px solid ${acc}44`,borderRadius:r,color:ic,fontFamily:"DM Sans,sans-serif",fontSize:12,marginBottom:7}}>Konfirmasi ▾</div><div style={{padding:"20px 12px",background:ib,border:`1px solid ${acc}44`,borderRadius:r,color:ic,fontFamily:"DM Sans,sans-serif",fontSize:12,marginBottom:10}}>Ucapan &amp; Doa...</div><div style={{padding:"11px",background:acc,borderRadius:r,color:"#000",fontFamily:"DM Sans,sans-serif",fontSize:12,fontWeight:700,textAlign:"center"}}>Kirim 💌</div></div>;}
  if(el.widgetType==="maps"){const bt=el.mapsBtnText||"Buka di Google Maps";return<div style={{position:"absolute",inset:0}}><div style={{width:"100%",height:"100%",background:"#1a2a1a",display:"flex",alignItems:"center",justifyContent:"center",position:"relative",overflow:"hidden"}}><div style={{position:"absolute",inset:0,backgroundImage:"linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px)",backgroundSize:"28px 28px"}}/><div style={{textAlign:"center",color:"#3a5a3a",fontSize:11,fontFamily:"DM Sans,sans-serif",zIndex:1}}>🗺<br/>Maps{el.mapsLayout==="embed"?" (Embed)":""}</div></div><div style={{position:"absolute",bottom:12,left:"50%",transform:"translateX(-50%)",display:"inline-block",padding:"7px 18px",background:acc,color:"#000",fontFamily:"DM Sans,sans-serif",fontSize:11,fontWeight:700,borderRadius:r,whiteSpace:"nowrap"}}>{bt}</div></div>;}
  if(el.widgetType==="gallery"){
