const DATA_VARS=[{key:"inv.groom_name",label:"Nama Mempelai Pria",example:"Ahmad Rizky"},{key:"inv.bride_name",label:"Nama Mempelai Wanita",example:"Siti Rahayu"},{key:"inv.groom_father",label:"Nama Ayah Pria",example:"Bapak Hasan"},{key:"inv.groom_mother",label:"Nama Ibu Pria",example:"Ibu Aminah"},{key:"inv.bride_father",label:"Nama Ayah Wanita",example:"Bapak Yusuf"},{key:"inv.bride_mother",label:"Nama Ibu Wanita",example:"Ibu Fatimah"},{key:"inv.akad_date",label:"Tanggal Akad",example:"Sabtu, 12 Juli 2025"},{key:"inv.akad_time",label:"Waktu Akad",example:"08.00–10.00 WIB"},{key:"inv.akad_venue",label:"Tempat Akad",example:"Masjid Al-Ikhlas"},{key:"inv.akad_address",label:"Alamat Akad",example:"Jl. Mawar No. 12, Jakarta"},{key:"inv.resepsi_date",label:"Tanggal Resepsi",example:"Sabtu, 12 Juli 2025"},{key:"inv.resepsi_time",label:"Waktu Resepsi",example:"11.00–14.00 WIB"},{key:"inv.resepsi_venue",label:"Tempat Resepsi",example:"Gedung Serbaguna Barokah"},{key:"inv.resepsi_address",label:"Alamat Resepsi",example:"Jl. Melati No. 45, Jakarta"},{key:"inv.groom_photo_url",label:"Foto Mempelai Pria",example:"/static/demo-photos/individual/groom.jpg"},{key:"inv.bride_photo_url",label:"Foto Mempelai Wanita",example:"/static/demo-photos/individual/bride.jpg"},{key:"inv.maps_url",label:"Link Google Maps",example:"https://maps.google.com/?q=..."},{key:"inv.maps_embed",label:"Maps Embed URL",example:"https://www.google.com/maps/embed?pb=..."},{key:"inv.countdown_date",label:"Target Countdown",example:"2025-07-12T08:00:00"},{key:"inv.music_url",label:"URL File Musik",example:"static/music/lagu.mp3"},{key:"inv.love_story",label:"Cerita Love Story",example:"Kami pertama bertemu..."}];

