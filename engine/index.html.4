  useEffect(()=>{const f=e=>{if(!selId)return;if(["INPUT","TEXTAREA","SELECT"].includes(e.target.tagName))return;const el=actSec?.elements.find(x=>x.id===selId);if(!el)return;const st=e.shiftKey?10:1;if(e.key==="ArrowLeft"){e.preventDefault();updEl(selId,{x:el.x-st});}if(e.key==="ArrowRight"){e.preventDefault();updEl(selId,{x:el.x+st});}if(e.key==="ArrowUp"){e.preventDefault();updEl(selId,{y:el.y-st});}if(e.key==="ArrowDown"){e.preventDefault();updEl(selId,{y:el.y+st});}if(e.key==="Delete"||e.key==="Backspace"){e.preventDefault();delEl(selId);}if((e.ctrlKey||e.metaKey)&&e.key==="d"){e.preventDefault();dupEl(selId);}
