  return<div style={{position:"absolute",inset:0,border:`1.5px dashed ${acc}44`,display:"flex",alignItems:"center",justifyContent:"center",background:`${acc}08`,borderRadius:4}}><div style={{textAlign:"center",color:`${acc}77`,fontSize:11,fontFamily:"DM Sans,sans-serif"}}>{el.name}</div></div>;
