        {sec.bgImage&&<div style={{marginTop:6}}><div style={{fontSize:10,color:"#3a3a3a",marginBottom:4,fontFamily:"DM Sans,sans-serif"}}>Fit Mode</div><div style={{display:"flex",gap:3}}>{[["cover","Cover"],["contain","Contain"],["fill","Stretch"],["center","Center"]].map(([v,l])=><button key={v} onClick={()=>upd({bgFit:v})} style={{flex:1,padding:"4px 2px",background:(sec.bgFit||"cover")===v?"#1a2a1a":"#181818",border:`1px solid ${(sec.bgFit||"cover")===v?"#7D9470":"#252525"}`,color:(sec.bgFit||"cover")===v?"#9CD889":"#555",borderRadius:3,cursor:"pointer",fontSize:8,fontFamily:"DM Sans,sans-serif"}}>{l}</button>)}</div></div>}
      </Field>
      {sec.type==="cover"&&<>
        <Div label="Tombol Buka Undangan"/>
        <Field label="Teks Tombol"><input value={sec.openInviteText||"Buka Undangan"} onChange={e=>upd({openInviteText:e.target.value})} style={S.inp}/></Field>
        <Field label="Warna Teks/Border">
          <div style={{display:"flex",gap:8,alignItems:"center"}}>
            <input type="color" value={sec.openInviteStyle?.color||"#C4973A"} onChange={e=>upd({openInviteStyle:{...sec.openInviteStyle,color:e.target.value}})} style={{width:36,height:28,border:"none",cursor:"pointer",padding:0,borderRadius:4}}/>
            <input value={sec.openInviteStyle?.color||"#C4973A"} onChange={e=>upd({openInviteStyle:{...sec.openInviteStyle,color:e.target.value}})} style={{...S.inp,flex:1,fontFamily:"monospace",fontSize:11}}/>
          </div>
        </Field>
        <Field label="Background Tombol"><input value={sec.openInviteStyle?.bgColor||"transparent"} onChange={e=>upd({openInviteStyle:{...sec.openInviteStyle,bgColor:e.target.value}})} placeholder="transparent/#hex/rgba" style={{...S.inp,fontSize:11}}/></Field>
        <Field label={`Font Size — ${sec.openInviteStyle?.fontSize||16}px`}><Sld value={sec.openInviteStyle?.fontSize||16} min={10} max={28} onChange={v=>upd({openInviteStyle:{...sec.openInviteStyle,fontSize:v}})}/></Field>
        <Field label={`Border Radius — ${sec.openInviteStyle?.borderRadius||2}px`}><Sld value={sec.openInviteStyle?.borderRadius||2} min={0} max={50} onChange={v=>upd({openInviteStyle:{...sec.openInviteStyle,borderRadius:v}})}/></Field>
        <Field label={`Posisi Bawah — ${sec.openInviteStyle?.posBottom||80}px`}><Sld value={sec.openInviteStyle?.posBottom||80} min={20} max={700} onChange={v=>upd({openInviteStyle:{...sec.openInviteStyle,posBottom:v}})}/></Field>
      </>}
    </div>
  );
}

// ─── WidgetProps ──────────────────────────────────────────────────────────────
function WidgetProps({el,upd,onDel,onDup,onGallery}){
