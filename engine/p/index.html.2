const SECTION_PRESETS=[{type:"cover",name:"Cover / Buka Undangan",bg:"#1a0e08"},{type:"blank",name:"✦ Halaman Kosong",bg:"#1a1a1a"},{type:"quran",name:"Ayat Quran",bg:"#FAF6EE"},{type:"couple",name:"Profil Mempelai",bg:"#1A100A"},{type:"lovestory",name:"Love Story",bg:"#F7EFE0"},{type:"event",name:"Detail Acara",bg:"#FAF6EE"},{type:"closing",name:"Closing",bg:"#1A100A"}];
const WIDGET_DEFS=[{id:"countdown",label:"⏱ Countdown",h:180},{id:"rsvp",label:"📋 Form RSVP",h:520},{id:"maps",label:"🗺 Peta Lokasi",h:380},{id:"gallery",label:"🖼 Gallery",h:500},{id:"guestbook",label:"💌 Buku Tamu",h:480},{id:"gift",label:"💰 Amplop",h:400}];
const DATA_VARS=[{key:"inv.groom_name",label:"Nama Mempelai Pria",example:"Ahmad Rizky"},{key:"inv.bride_name",label:"Nama Mempelai Wanita",example:"Siti Rahayu"},{key:"inv.groom_parents",label:"Nama Orang Tua Pria",example:"Bapak Hasan & Ibu Aminah"},{key:"inv.bride_parents",label:"Nama Orang Tua Wanita",example:"Bapak Yusuf & Ibu Fatimah"},{key:"inv.akad_date",label:"Tanggal Akad",example:"Sabtu, 12 Juli 2025"},{key:"inv.akad_time",label:"Waktu Akad",example:"08.00–10.00 WIB"},{key:"inv.akad_venue",label:"Tempat Akad",example:"Masjid Al-Ikhlas"},{key:"inv.akad_address",label:"Alamat Akad",example:"Jl. Mawar No. 12, Jakarta"},{key:"inv.resepsi_date",label:"Tanggal Resepsi",example:"Sabtu, 12 Juli 2025"},{key:"inv.resepsi_time",label:"Waktu Resepsi",example:"11.00–14.00 WIB"},{key:"inv.resepsi_venue",label:"Tempat Resepsi",example:"Gedung Serbaguna Barokah"},{key:"inv.resepsi_address",label:"Alamat Resepsi",example:"Jl. Melati No. 45, Jakarta"},{key:"inv.groom_photo_url",label:"Foto Mempelai Pria",example:"demo-photos/individual/groom.jpg"},{key:"inv.bride_photo_url",label:"Foto Mempelai Wanita",example:"demo-photos/individual/bride.jpg"},{key:"inv.maps_url",label:"Link Google Maps",example:"https://maps.google.com/?q=..."},{key:"inv.maps_embed",label:"Maps Embed URL",example:"https://www.google.com/maps/embed?pb=..."},{key:"inv.countdown_date",label:"Target Countdown",example:"2025-07-12T08:00:00"},{key:"inv.music_url",label:"URL File Musik",example:"static/music/lagu.mp3"},{key:"inv.love_story",label:"Cerita Love Story",example:"Kami pertama bertemu..."}];

let _id=200;
const uid=()=>++_id;

// ─── Multi-Project localStorage ───────────────────────────────────────────────
const PROJECTS_KEY="hk_projects_v4",DRAFT_KEY="hk_draft_v4";
function getProjects(){try{return JSON.parse(localStorage.getItem(PROJECTS_KEY)||"[]");}catch(e){return[];}}
function saveProject(pid,name,sections,invData){try{const ps=getProjects(),id=pid||("p_"+Date.now()),now=new Date().toLocaleString("id-ID"),obj={id,name:name||"Proyek Baru",sections,invData,updatedAt:now},idx=ps.findIndex(p=>p.id===id);if(idx>=0)ps[idx]=obj;else ps.push(obj);localStorage.setItem(PROJECTS_KEY,JSON.stringify(ps));return id;}catch(e){return null;}}
function deleteProject(id){try{localStorage.setItem(PROJECTS_KEY,JSON.stringify(getProjects().filter(p=>p.id!==id)));}catch(e){}}
function saveDraft(sections,invData,projectId,projectName){try{localStorage.setItem(DRAFT_KEY,JSON.stringify({sections,invData,projectId,projectName}));}catch(e){}}
function loadDraft(){try{return JSON.parse(localStorage.getItem(DRAFT_KEY)||"null")||{sections:null,invData:null,projectId:null,projectName:"Proyek Baru"};}catch(e){return{sections:null,invData:null,projectId:null,projectName:"Proyek Baru"};}}
// ─── Server detection ─────────────────────────────────────────────────────────
const SERVER_URL="http://localhost:8765";
let _serverOnline=null;
async function checkServer(){if(_serverOnline!==null)return _serverOnline;try{const r=await fetch(SERVER_URL+"/api/projects",{signal:AbortSignal.timeout(800)});_serverOnline=r.ok;}catch{_serverOnline=false;}return _serverOnline;}

// ─── Image extraction helpers ─────────────────────────────────────────────────
function isB64Img(s){return typeof s==="string"&&s.startsWith("data:image/");}
function isDemo(s){return typeof s==="string"&&s.startsWith("demo-photos/");}
function slugify(n){return(n||"untitled").trim().toLowerCase().replace(/[^a-z0-9\s_-]/g,"").replace(/\s+/g,"_")||"untitled";}

// Collect all images referenced in sections
function collectImages(sections){
  const imgs=new Map(); // src -> {type, ext, id}
  let c=0;
  const reg=(src)=>{
    if(!src||imgs.has(src)||src.startsWith("{{"))return;
    const isb=isB64Img(src),isd=isDemo(src);
    if(!isb&&!isd)return;
    const ext=isb?(src.match(/data:image\/(\w+);/)||[])[1]||"jpg":"jpg";
    imgs.set(src,{type:isb?"base64":"demo",ext,id:`img_${String(++c).padStart(4,"0")}`});
  };
  for(const s of sections){
    if(s.bgImage)reg(s.bgImage);
    for(const el of s.elements||[]){
      if(el.type==="image")reg(el.src);
      for(const g of el.galleryImages||[])reg(g);
    }
  }
  return imgs;
}

// Produce sections clone with base64/demo src replaced by static path
function stripSections(sections,imgMap,themeId){
  return JSON.parse(JSON.stringify(sections)).map(s=>{
    if(s.bgImage&&imgMap.has(s.bgImage)){
      const m=imgMap.get(s.bgImage);s.bgImage=`static/themes/${themeId}/${m.id}.${m.ext}`;
    }
    for(const el of s.elements||[]){
      if(el.type==="image"&&imgMap.has(el.src)){
        const m=imgMap.get(el.src);el.src=`static/themes/${themeId}/${m.id}.${m.ext}`;
      }
      if(el.galleryImages){
        el.galleryImages=el.galleryImages.map(g=>{
          if(imgMap.has(g)){const m=imgMap.get(g);return`static/themes/${themeId}/${m.id}.${m.ext}`;}
          return g;
        });
      }
    }
    return s;
  });
}

// ─── Export to server (saves to projects/namaproyek/) ────────────────────────
async function exportToServer(name,sections,invData,htmlStr,onProgress){
  onProgress("Mengirim ke server...");
  const themeId=slugify(name);
  const res=await fetch(SERVER_URL+"/api/save",{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({name,theme_id:themeId,sections,invData,html:htmlStr}),
    signal:AbortSignal.timeout(30000)
  });
  const data=await res.json();
  if(!data.ok)throw new Error(data.error||"Server error");
  return data;
}

// ─── Export as ZIP (fallback, no server needed) ───────────────────────────────
async function exportAsZip(name,sections,invData,htmlStr,onProgress){
  onProgress("Mempersiapkan ZIP...");
  // Dynamically load JSZip from CDN
  if(!window.JSZip){
    await new Promise((res,rej)=>{
      const s=document.createElement("script");
      s.src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js";
      s.onload=res;s.onerror=rej;document.head.appendChild(s);
    });
  }
  const themeId=slugify(name);
  const zip=new JSZip();
  const imgMap=collectImages(sections);
  const cleanSections=stripSections(sections,imgMap,themeId);

  // Patch HTML: replace all base64/demo srcs with static paths
  let htmlOut=htmlStr;
  for(const[orig,m]of imgMap){
    const newPath=`static/themes/${themeId}/${m.id}.${m.ext}`;
    htmlOut=htmlOut.split(orig).join(newPath);
  }

  onProgress("Mengemas gambar...");
  // Add images to zip
  for(const[orig,m]of imgMap){
    const fname=`${themeId}/static/themes/${themeId}/${m.id}.${m.ext}`;
    if(m.type==="base64"){
      const b64=orig.split(",")[1];
      zip.file(fname,b64,{base64:true});
    } else if(m.type==="demo"){
      // Fetch from server's demo-photos endpoint
      try{
        const rel=orig.replace(/^demo-photos\//,"");
        const r=await fetch(`${SERVER_URL}/demo-photos/${rel}`,{signal:AbortSignal.timeout(5000)});
        if(r.ok){const buf=await r.arrayBuffer();zip.file(fname,buf);}
      }catch{/* skip if server not available */}
    }
  }

  onProgress("Menulis HTML & JSON...");
  zip.file(`${themeId}/${themeId}.html`,htmlOut);
  zip.file(`${themeId}/${themeId}.json`,JSON.stringify({
    id:themeId,name,skeleton:themeId,
    generated:new Date().toLocaleString("id-ID"),
    inv_data_keys:Object.keys(invData),
    assets:[...imgMap.values()].map(m=>`static/themes/${themeId}/${m.id}.${m.ext}`)
  },null,2));

  onProgress("Mengompres...");
  const blob=await zip.generateAsync({type:"blob",compression:"DEFLATE"});
  const url=URL.createObjectURL(blob);
  const a=document.createElement("a");
  a.href=url;a.download=`${themeId}.zip`;a.click();
  setTimeout(()=>URL.revokeObjectURL(url),5000);
  return {zipSize:blob.size,images:imgMap.size};
}

function exportJSON(name,sections,invData){const blob=new Blob([JSON.stringify({name,sections,invData},null,2)],{type:"application/json"}),url=URL.createObjectURL(blob),a=document.createElement("a");a.href=url;a.download=(name||"project")+".json";a.click();URL.revokeObjectURL(url);}
function importJSON(text,cb){try{const d=JSON.parse(text);if(d.sections){const pid=saveProject(null,d.name||"Import",d.sections,d.invData||{});cb(pid,d.name||"Import",d.sections,d.invData||{});}else alert("JSON tidak valid");}catch(e){alert("Gagal baca JSON");}}

// ─── Element Factories ────────────────────────────────────────────────────────
const makeTextEl=(text="Teks Baru",x=80,y=200)=>({id:uid(),type:"text",name:text.slice(0,20),text,x,y,fontSize:24,fontFamily:"Playfair Display",color:"#ffffff",align:"center",fontStyle:"normal",fontWeight:"400",letterSpacing:0,lineHeight:1.4,opacity:1,zIndex:10,animation:"none",animDelay:0,animDuration:4,rotation:0,width:250,shadow:false,shadowColor:"rgba(0,0,0,0.5)",shadowBlur:8,isVar:false,varKey:"",borderRadius:0,height:150});
const makeImgEl=(src,name)=>({id:uid(),type:"image",name,src,x:20+Math.floor(Math.random()*40),y:20+Math.floor(Math.random()*40),width:150,rotation:0,opacity:1,zIndex:10,animation:"none",animDelay:0,animDuration:4,flipH:false,flipV:false});
const makeWidgetEl=(widgetType)=>{const def=WIDGET_DEFS.find(w=>w.id===widgetType)||{h:400};return{id:uid(),type:"widget",widgetType,name:(def.label||widgetType),x:20,y:40,width:350,height:def.h,zIndex:10,opacity:1,accent:"#C4973A",radius:4,wStyle:"dark",title:"",mapsLayout:"embed",mapsBtnText:"Buka di Google Maps",galleryImages:[],galleryLayout:"2",galleryShape:"kotak",galleryGap:8,cdAccent:"#C4973A",rsvpTitle:"Konfirmasi Kehadiran",gbTitle:"Buku Tamu",giftTitle:"Amplop Digital",giftSubtitle:"Doa tulus Anda adalah hadiah terindah."};};

const initSections=[{id:1,type:"cover",name:"Cover / Buka Undangan",bg:"#1a0e08",elements:[],openInviteText:"Buka Undangan",openInviteStyle:{fontSize:16,color:"#C4973A",fontFamily:"Playfair Display"}},{id:2,type:"quran",name:"Ayat Quran",bg:"#FAF6EE",elements:[]},{id:3,type:"couple",name:"Profil Mempelai",bg:"#1A100A",elements:[]},{id:4,type:"event",name:"Detail Acara",bg:"#FAF6EE",elements:[]},{id:5,type:"closing",name:"Closing",bg:"#1A100A",elements:[]}];

// ─── Build Exported HTML ──────────────────────────────────────────────────────
function buildHTML(sections,invData){
  const inv=invData||{};
  const rv=k=>inv[k.replace("inv.","")]||"";
  const animCSS=`@keyframes fade-in{from{opacity:0}to{opacity:1}}@keyframes slide-from-left{from{opacity:0;transform:translateX(-32px)}to{opacity:1;transform:none}}@keyframes slide-from-right{from{opacity:0;transform:translateX(32px)}to{opacity:1;transform:none}}@keyframes slide-from-top{from{opacity:0;transform:translateY(-32px)}to{opacity:1;transform:none}}@keyframes slide-from-bottom{from{opacity:0;transform:translateY(32px)}to{opacity:1;transform:none}}@keyframes zoom-in{from{opacity:0;transform:scale(.82)}to{opacity:1;transform:scale(1)}}@keyframes rotate-in{from{opacity:0;transform:rotate(-14deg) scale(.88)}to{opacity:1;transform:none}}@keyframes sway{0%,100%{transform:rotate(0)}50%{transform:rotate(6deg)}}@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}@keyframes pulse{0%,100%{opacity:1}50%{opacity:.45}}@keyframes shimmer{0%{filter:brightness(1)}50%{filter:brightness(1.4)}100%{filter:brightness(1)}}@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}`;
  const ba=(anim,dur,delay)=>{if(!anim||anim==="none")return"";const inf=["sway","float","pulse","shimmer","bounce"].includes(anim);return inf?`animation:${anim} ${dur||4}s ease-in-out infinite;`:`animation:${anim} .8s cubic-bezier(.16,1,.3,1) ${delay||0}s both;`;};
  const PHOTO_VARS=new Set(["inv.groom_photo_url","inv.bride_photo_url"]);
  // For export: photo vars become Flask template vars {{ inv.groom_photo_url }}
  // For preview in editor: uses demo-photos/individual/ local path

  const elToHTML=el=>{
    if(el.type==="image"){const animS=ba(el.animation,el.animDuration,el.animDelay),flip=[el.flipH?"scaleX(-1)":"",el.flipV?"scaleY(-1)":""].filter(Boolean).join(" "),trx=[`rotate(${el.rotation||0}deg)`,flip].filter(Boolean).join(" ");return `<img src="${el.src}" alt="" style="position:absolute;left:${el.x}px;top:${el.y}px;width:${el.width}px;transform:${trx||"none"};opacity:${el.opacity};z-index:${el.zIndex};${animS}pointer-events:none;"/>`;}
    if(el.type==="text"){
      const animS=ba(el.animation,el.animDuration,el.animDelay),shd=el.shadow?`text-shadow:0 2px ${el.shadowBlur||8}px ${el.shadowColor||"rgba(0,0,0,.5)"};`:"";
      if(el.isVar&&el.varKey&&PHOTO_VARS.has(el.varKey)){const br=el.borderRadius==="50%"?"50%":`${el.borderRadius||0}px`,h=el.height||el.width||150;return `<img src="{{${el.varKey}}}" alt="" style="position:absolute;left:${el.x}px;top:${el.y}px;width:${el.width||150}px;height:${h}px;object-fit:cover;border-radius:${br};z-index:${el.zIndex};opacity:${el.opacity};pointer-events:none;"/>`;}
      const txt=el.isVar&&el.varKey?(rv(el.varKey)||`{{${el.varKey}}}`):el.text;
      return `<div style="position:absolute;left:${el.x}px;top:${el.y}px;width:${el.width||200}px;font-size:${el.fontSize||24}px;font-family:'${el.fontFamily||"Playfair Display"}',serif;color:${el.color||"#fff"};text-align:${el.align||"center"};font-style:${el.fontStyle||"normal"};font-weight:${el.fontWeight||400};letter-spacing:${el.letterSpacing||0}px;line-height:${el.lineHeight||1.4};opacity:${el.opacity||1};z-index:${el.zIndex||10};transform:rotate(${el.rotation||0}deg);${shd}${animS}">${txt}</div>`;
    }
    if(el.type==="widget")return widgetToHTML(el,inv);
    return"";
  };

  const widgetToHTML=(el,inv)=>{
    const acc=el.accent||"#C4973A",r=el.radius||4,dk=(el.wStyle||"dark")==="dark",ib=dk?"rgba(255,255,255,0.08)":"rgba(0,0,0,0.06)",ic=dk?"#aaa":"#333",tc=dk?acc:"#333",ws=`position:absolute;left:${el.x}px;top:${el.y}px;width:${el.width}px;height:${el.height}px;z-index:${el.zIndex};opacity:${el.opacity};overflow-y:auto;`,wid=el.id;
    if(el.widgetType==="countdown"){const ca=el.cdAccent||acc,tit=el.title?`<div style="font-family:'Playfair Display',serif;font-size:18px;color:${ca};margin-bottom:16px;text-align:center;">${el.title}</div>`:"";return `<div style="${ws}padding:20px 0;">${tit}<div style="display:flex;gap:10px;justify-content:center;padding:0 8px;">${[["cd-days","Hari"],["cd-hours","Jam"],["cd-mins","Mnt"],["cd-secs","Det"]].map(([cid,lbl])=>`<div style="flex:1;background:${dk?"rgba(255,255,255,.06)":"rgba(0,0,0,.06)"};border-radius:8px;padding:14px 4px;text-align:center;"><div id="${cid}" style="font-family:'Playfair Display',serif;font-size:30px;color:${ca};line-height:1;">00</div><div style="font-size:9px;color:${dk?"#666":"#999"};text-transform:uppercase;letter-spacing:1.5px;margin-top:6px;font-family:'DM Sans',sans-serif;">${lbl}</div></div>`).join("")}</div></div>`;}
    if(el.widgetType==="rsvp"){const tit=el.title||el.rsvpTitle||"Konfirmasi Kehadiran";return `<div style="${ws}"><div id="rsvp-form-${wid}" style="padding:20px 4px;"><div style="text-align:center;margin-bottom:20px;"><div style="font-family:'Playfair Display',serif;font-size:20px;color:${tc};">${tit}</div><div style="width:32px;height:1px;background:${acc};opacity:.4;margin:8px auto 0;"></div></div><input id="rn-${wid}" placeholder="Nama Anda" style="width:100%;padding:10px 14px;background:${ib};border:1px solid ${acc}44;color:${ic};font-family:'DM Sans',sans-serif;font-size:13px;border-radius:${r}px;outline:none;margin-bottom:8px;display:block;"/><input id="rg-${wid}" type="number" min="1" placeholder="Jumlah Tamu" style="width:100%;padding:10px 14px;background:${ib};border:1px solid ${acc}44;color:${ic};font-family:'DM Sans',sans-serif;font-size:13px;border-radius:${r}px;outline:none;margin-bottom:8px;display:block;"/><select id="ra-${wid}" style="width:100%;padding:10px 14px;background:${dk?"#1a1a1a":ib};border:1px solid ${acc}44;color:${ic};font-family:'DM Sans',sans-serif;font-size:13px;border-radius:${r}px;outline:none;margin-bottom:8px;display:block;"><option value="">Konfirmasi Kehadiran ▾</option><option value="hadir">Insya Allah Hadir 🤍</option><option value="tidak">Tidak Dapat Hadir</option></select><textarea id="rm-${wid}" placeholder="Ucapan &amp; Doa..." rows="3" style="width:100%;padding:10px 14px;background:${ib};border:1px solid ${acc}44;color:${ic};font-family:'DM Sans',sans-serif;font-size:13px;border-radius:${r}px;outline:none;resize:none;display:block;margin-bottom:12px;"></textarea><button onclick="submitRSVP('${wid}')" style="width:100%;padding:12px;background:${acc};border:none;color:#000;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:700;border-radius:${r}px;cursor:pointer;">Kirim Konfirmasi 💌</button></div><div id="rsvp-ok-${wid}" style="display:none;padding:60px 20px;text-align:center;"><div style="font-family:'Playfair Display',serif;font-size:40px;color:${acc};">✦</div><div style="font-family:'Playfair Display',serif;font-size:22px;color:${dk?"#fff":"#333"};margin-top:12px;">Terima Kasih</div><div style="font-size:13px;color:#888;margin-top:8px;font-family:'DM Sans',sans-serif;line-height:1.7;">Konfirmasi Anda telah kami terima.</div></div></div>`;}
    if(el.widgetType==="maps"){const em=inv.maps_embed||"",lk=inv.maps_url||"#",bt=el.mapsBtnText||"Buka di Google Maps";if(el.mapsLayout==="embed"&&em)return `<div style="${ws}border-radius:${r}px;overflow:hidden;"><iframe src="${em}" width="100%" height="100%" style="border:0;display:block;" allowfullscreen="" loading="lazy"></iframe><a href="${lk}" target="_blank" rel="noopener" style="position:absolute;bottom:14px;left:50%;transform:translateX(-50%);display:inline-block;padding:9px 22px;background:${acc};color:#000;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;border-radius:${r}px;text-decoration:none;white-space:nowrap;box-shadow:0 2px 12px rgba(0,0,0,.5);">${bt}</a></div>`;return `<div style="position:absolute;left:${el.x}px;top:${el.y}px;width:${el.width}px;z-index:${el.zIndex};text-align:center;padding:20px 0;"><a href="${lk}" target="_blank" rel="noopener" style="display:inline-block;padding:13px 30px;background:${acc};color:#000;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:700;border-radius:${r}px;text-decoration:none;">${bt}</a></div>`;}
