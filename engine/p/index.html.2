  const script=`
const inv={groom_name:"{{inv.groom_name}}",bride_name:"{{inv.bride_name}}",maps_url:"{{inv.maps_url}}",countdown_date:"{{inv.countdown_date}}",music_url:"{{inv.music_url}}"};
let cur=0,navLock=false;
const secs=document.querySelectorAll('.section'),total=secs.length,dotsEl=document.getElementById('dots');
secs.forEach((_,i)=>{const d=document.createElement('button');d.className='dot'+(i===0?' active':'');d.addEventListener('click',()=>goTo(i));dotsEl.appendChild(d);});
function goTo(i){if(i<0||i>=total)return;cur=i;document.getElementById('track').style.transform='translateY(-'+cur*100+'dvh)';document.querySelectorAll('.dot').forEach((d,j)=>d.classList.toggle('active',j===cur));}
function safeGoTo(i){if(navLock)return;navLock=true;goTo(i);setTimeout(()=>navLock=false,850);}
function coverVisible(){const c=document.getElementById('cover-screen');return c&&c.style.display!=='none'&&c.style.opacity!=='0'&&c.style.pointerEvents!=='none';}
let sy=0;
