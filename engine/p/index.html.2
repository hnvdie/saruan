            <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:8}}>
              <div style={{fontSize:10,color:"#2a2a2a",letterSpacing:.5,fontFamily:"DM Sans,sans-serif"}}>{sections.findIndex(s=>s.id===activeId)+1}/{sections.length} — {actSec.name}</div>
              <div style={{width:CANVAS_W,height:CANVAS_H,background:actSec.bgImage?undefined:actSec.bg,backgroundImage:actSec.bgImage?`url(${actSec.bgImage})`:"none",backgroundSize:actSec.bgFit==="contain"?"contain":actSec.bgFit==="fill"?"100% 100%":actSec.bgFit==="center"?"auto":"cover",backgroundPosition:"center",backgroundRepeat:"no-repeat",position:"relative",overflow:"hidden",boxShadow:"0 0 0 1px #1e1e1e,0 24px 80px rgba(0,0,0,.9)",transform:`scale(${scale})`,transformOrigin:"top center",flexShrink:0}}>
