          <input value={el.accent||"#C4973A"} onChange={e=>upd({accent:e.target.value})} style={{...S.inp,flex:1,fontFamily:"monospace",fontSize:11}}/>
        </div>
      </Field>
      <Field label="Style">
        <div style={{display:"flex",gap:4}}>
          {[["dark","🌑 Dark"],["light","☀️ Light"]].map(([v,l])=><button key={v} onClick={()=>upd({wStyle:v})} style={{flex:1,padding:"5px 0",background:(el.wStyle||"dark")===v?"#1a2a1a":"#181818",border:`1px solid ${(el.wStyle||"dark")===v?"#7D9470":"#252525"}`,color:(el.wStyle||"dark")===v?"#9CD889":"#555",borderRadius:3,cursor:"pointer",fontSize:10,fontFamily:"DM Sans,sans-serif"}}>{l}</button>)}
        </div>
      </Field>
      <Field label={`Border Radius — ${el.radius||4}px`}><Sld value={el.radius||4} min={0} max={40} onChange={v=>upd({radius:v})}/></Field>
      <Div label="Posisi & Ukuran"/>
      <Field label={`X — ${el.x}px`}><Sld value={el.x} min={-50} max={CANVAS_W} onChange={v=>upd({x:v})}/></Field>
      <Field label={`Y — ${el.y}px`}><Sld value={el.y} min={-CANVAS_H} max={CANVAS_H} onChange={v=>upd({y:v})}/></Field>
      <Field label={`Lebar — ${el.width}px`}><Sld value={el.width} min={100} max={CANVAS_W+50} onChange={v=>upd({width:v})}/></Field>
      <Field label={`Tinggi — ${el.height||400}px`}><Sld value={el.height||400} min={80} max={CANVAS_H*2} onChange={v=>upd({height:v})}/></Field>
      <Field label={`Z-Index — ${el.zIndex||10}`}><Sld value={el.zIndex||10} min={1} max={50} onChange={v=>upd({zIndex:v})}/></Field>
      <Field label={`Opacity — ${Math.round((el.opacity||1)*100)}%`}><Sld value={el.opacity||1} min={0} max={1} step={0.01} onChange={v=>upd({opacity:v})}/></Field>
      {el.widgetType==="maps"&&<><Div label="Maps"/><Field label="Mode"><div style={{display:"flex",gap:4}}>{[["embed","📍 Embed"],["button","🔗 Tombol"]].map(([v,l])=><button key={v} onClick={()=>upd({mapsLayout:v})} style={{flex:1,padding:"5px 0",background:(el.mapsLayout||"embed")===v?"#1a2a1a":"#181818",border:`1px solid ${(el.mapsLayout||"embed")===v?"#7D9470":"#252525"}`,color:(el.mapsLayout||"embed")===v?"#9CD889":"#555",borderRadius:3,cursor:"pointer",fontSize:10,fontFamily:"DM Sans,sans-serif"}}>{l}</button>)}</div></Field><Field label="Teks Tombol"><input value={el.mapsBtnText||"Buka di Google Maps"} onChange={e=>upd({mapsBtnText:e.target.value})} style={S.inp}/></Field><div style={{padding:"7px 9px",background:"#0f1a0f",border:"1px solid #1a2a1a",borderRadius:4,fontSize:10,color:"#4a6a4a",fontFamily:"DM Sans,sans-serif",lineHeight:1.8}}>💡 Link URL → Data: <b style={{color:"#6a8a6a"}}>inv.maps_url</b><br/>Embed URL → Data: <b style={{color:"#6a8a6a"}}>inv.maps_embed</b><br/>Format embed: google.com/maps/embed?pb=...</div></>}
      {el.widgetType==="gallery"&&<><Div label="Gallery"/><Field label="Layout"><div style={{display:"flex",gap:3}}>{[["1","1 Kolom"],["2","2 Kolom"],["3","3 Kolom"]].map(([v,l])=><button key={v} onClick={()=>upd({galleryLayout:v})} style={{flex:1,padding:"5px 2px",background:(el.galleryLayout||"2")===v?"#1a2a1a":"#181818",border:`1px solid ${(el.galleryLayout||"2")===v?"#7D9470":"#252525"}`,color:(el.galleryLayout||"2")===v?"#9CD889":"#555",borderRadius:3,cursor:"pointer",fontSize:10,fontFamily:"DM Sans,sans-serif"}}>{l}</button>)}</div></Field><Field label="Bentuk"><div style={{display:"flex",gap:3}}>{[["kotak","Kotak"],["rounded","Bulat"],["circle","Lingkaran"]].map(([v,l])=><button key={v} onClick={()=>upd({galleryShape:v})} style={{flex:1,padding:"5px 2px",background:(el.galleryShape||"kotak")===v?"#1a2a1a":"#181818",border:`1px solid ${(el.galleryShape||"kotak")===v?"#7D9470":"#252525"}`,color:(el.galleryShape||"kotak")===v?"#9CD889":"#555",borderRadius:3,cursor:"pointer",fontSize:10,fontFamily:"DM Sans,sans-serif"}}>{l}</button>)}</div></Field><Field label={`Gap — ${el.galleryGap||8}px`}><Sld value={el.galleryGap||8} min={0} max={20} onChange={v=>upd({galleryGap:v})}/></Field><button onClick={()=>gRef.current?.click()} style={{...S.btnS,width:"100%",fontSize:11}}>📷 Upload Foto Gallery ({(el.galleryImages||[]).length} foto)</button>{(el.galleryImages||[]).length>0&&<button onClick={()=>upd({galleryImages:[]})} style={{...S.btnS,width:"100%",fontSize:11,color:"#c55",borderColor:"#3a1515"}}>🗑 Hapus Semua Foto</button>}<input key={gKey} ref={gRef} type="file" accept="image/*" multiple style={{display:"none"}} onChange={e=>{onGallery(e,el.id);setGKey(k=>k+1);}}/></>}
      {el.widgetType==="countdown"&&<><Div label="Countdown"/><Field label="Warna Angka"><div style={{display:"flex",gap:8,alignItems:"center"}}><input type="color" value={el.cdAccent||el.accent||"#C4973A"} onChange={e=>upd({cdAccent:e.target.value})} style={{width:36,height:28,border:"none",cursor:"pointer",padding:0,borderRadius:4}}/><input value={el.cdAccent||el.accent||"#C4973A"} onChange={e=>upd({cdAccent:e.target.value})} style={{...S.inp,flex:1,fontFamily:"monospace",fontSize:11}}/></div></Field><div style={{padding:"7px 9px",background:"#0f1a0f",border:"1px solid #1a2a1a",borderRadius:4,fontSize:10,color:"#4a6a4a",fontFamily:"DM Sans,sans-serif",lineHeight:1.7}}>💡 Tanggal target di Data: <b style={{color:"#6a8a6a"}}>inv.countdown_date</b><br/>Format: 2025-07-12T08:00:00</div></>}
      {el.widgetType==="rsvp"&&<><Div label="RSVP"/><Field label="Judul Form"><input value={el.rsvpTitle||"Konfirmasi Kehadiran"} onChange={e=>upd({rsvpTitle:e.target.value})} style={S.inp}/></Field></>}
      {el.widgetType==="guestbook"&&<><Div label="Guestbook"/><Field label="Judul"><input value={el.gbTitle||"Buku Tamu"} onChange={e=>upd({gbTitle:e.target.value})} style={S.inp}/></Field></>}
      {el.widgetType==="gift"&&<><Div label="Amplop"/><Field label="Judul"><input value={el.giftTitle||"Amplop Digital"} onChange={e=>upd({giftTitle:e.target.value})} style={S.inp}/></Field><Field label="Subjudul"><input value={el.giftSubtitle||"Doa tulus Anda..."} onChange={e=>upd({giftSubtitle:e.target.value})} style={S.inp}/></Field><div style={{padding:"7px 9px",background:"#0f1a0f",border:"1px solid #1a2a1a",borderRadius:4,fontSize:10,color:"#4a6a4a",fontFamily:"DM Sans,sans-serif"}}>💡 Data rekening dari DB Flask (tabel gifts)</div></>}
      <div style={{display:"flex",gap:6,marginTop:4}}>
        <button onClick={onDup} style={{flex:1,padding:"7px 0",background:"#181818",border:"1px solid #222",color:"#666",borderRadius:4,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif"}}>Duplikat</button>
        <button onClick={onDel} style={{flex:1,padding:"7px 0",background:"#1a0a0a",border:"1px solid #3a1515",color:"#c55",borderRadius:4,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif"}}>Hapus</button>
      </div>
    </div>
  );
}

// ─── ElProps ──────────────────────────────────────────────────────────────────
function ElProps({el,upd,onDel,onDup,onFwd,onBwd,invData,onFP}){
  const PVARS=new Set(["inv.groom_photo_url","inv.bride_photo_url"]);
  const isPhoto=el.isVar&&PVARS.has(el.varKey);
  return(
    <div style={{display:"flex",flexDirection:"column",gap:11,paddingTop:4}}>
      <PLabel>{el.type==="image"?"🖼 Image":"T Teks"} — {el.name||"El"}</PLabel>
      {el.type==="text"&&<>
        <Field label="Teks"><textarea value={el.text} onChange={e=>upd({text:e.target.value})} rows={2} style={{...S.inp,resize:"vertical",fontSize:11,lineHeight:1.5}}/></Field>
        <Field label="Variabel Data">
          <div style={{display:"flex",gap:4,alignItems:"center",marginBottom:4}}>
            <input type="checkbox" checked={!!el.isVar} onChange={e=>upd({isVar:e.target.checked})} style={{accentColor:"#C4973A"}}/>
            <span style={{fontSize:11,color:"#555",fontFamily:"DM Sans,sans-serif"}}>Pakai variabel</span>
          </div>
          {el.isVar&&<select value={el.varKey||""} onChange={e=>upd({varKey:e.target.value})} style={{...S.inp,cursor:"pointer",fontSize:11}}><option value="">— Pilih —</option>{DATA_VARS.map(v=><option key={v.key} value={v.key}>{v.label}</option>)}</select>}
        </Field>
        {isPhoto&&<><Field label={`Tinggi Foto — ${el.height||el.width||150}px`}><Sld value={el.height||el.width||150} min={40} max={CANVAS_H} onChange={v=>upd({height:v})}/></Field><Field label="Border Radius"><div style={{display:"flex",gap:4}}>{[["0","Kotak"],["12","Rounded"],["50%","Bulat"]].map(([v,l])=><button key={v} onClick={()=>upd({borderRadius:v})} style={{flex:1,padding:"4px 2px",background:String(el.borderRadius)===v?"#1a2a1a":"#181818",border:`1px solid ${String(el.borderRadius)===v?"#7D9470":"#252525"}`,color:String(el.borderRadius)===v?"#9CD889":"#555",borderRadius:3,cursor:"pointer",fontSize:10,fontFamily:"DM Sans,sans-serif"}}>{l}</button>)}</div></Field></>}
        {!el.isVar&&<><Div label="Font"/>
          <Field label="Font"><button onClick={onFP} style={{...S.btnS,width:"100%",fontSize:12,fontFamily:`'${el.fontFamily||"Playfair Display"}',serif`,textAlign:"left",padding:"6px 10px"}}>{el.fontFamily||"Playfair Display"} ›</button></Field>
          <Field label={`Ukuran — ${el.fontSize||24}px`}><Sld value={el.fontSize||24} min={8} max={120} onChange={v=>upd({fontSize:v})}/></Field>
          <Field label="Warna"><div style={{display:"flex",gap:8,alignItems:"center"}}><input type="color" value={el.color||"#ffffff"} onChange={e=>upd({color:e.target.value})} style={{width:36,height:28,border:"none",cursor:"pointer",padding:0,borderRadius:4}}/><input value={el.color||"#ffffff"} onChange={e=>upd({color:e.target.value})} style={{...S.inp,flex:1,fontFamily:"monospace",fontSize:11}}/></div></Field>
          <Field label="Alignment"><div style={{display:"flex",gap:4}}>{[["left","◁"],["center","◈"],["right","▷"]].map(([v,l])=><button key={v} onClick={()=>upd({align:v})} style={{flex:1,padding:"5px 0",background:(el.align||"center")===v?"#1a2a1a":"#181818",border:`1px solid ${(el.align||"center")===v?"#7D9470":"#252525"}`,color:(el.align||"center")===v?"#9CD889":"#555",borderRadius:3,cursor:"pointer",fontSize:14,lineHeight:1}}>{l}</button>)}</div></Field>
          <Field label="Style"><div style={{display:"flex",gap:4}}>{[["italic","Italic"],["bold","Bold"]].map(v=><button key={v} onClick={()=>{if(v==="bold")upd({fontWeight:el.fontWeight==="700"?"400":"700"});else upd({fontStyle:el.fontStyle===v?"normal":v});}} style={{flex:1,padding:"4px 0",...boolBtn(v==="bold"?el.fontWeight==="700":el.fontStyle===v)}}>{v}</button>)}</div></Field>
          <Field label={`Letter Spacing — ${el.letterSpacing||0}px`}><Sld value={el.letterSpacing||0} min={-2} max={20} onChange={v=>upd({letterSpacing:v})}/></Field>
          <Field label={`Line Height — ${el.lineHeight||1.4}`}><Sld value={el.lineHeight||1.4} min={0.8} max={3} step={0.05} onChange={v=>upd({lineHeight:v})}/></Field>
          <Field label="Shadow"><div style={{display:"flex",gap:6,alignItems:"center"}}><input type="checkbox" checked={!!el.shadow} onChange={e=>upd({shadow:e.target.checked})} style={{accentColor:"#C4973A"}}/><span style={{fontSize:11,color:"#555",fontFamily:"DM Sans,sans-serif"}}>Text shadow</span></div></Field>
        </>}
      </>}
      <Div label="Posisi"/>
      <Field label={`X — ${el.x}px`}><Sld value={el.x} min={-CANVAS_W} max={CANVAS_W} onChange={v=>upd({x:v})}/></Field>
      <Field label={`Y — ${el.y}px`}><Sld value={el.y} min={-CANVAS_H} max={CANVAS_H*1.5} onChange={v=>upd({y:v})}/></Field>
      {el.type==="image"&&<Field label={`Lebar — ${el.width}px`}><Sld value={el.width} min={10} max={CANVAS_W*1.5} onChange={v=>upd({width:v})}/></Field>}
      {el.type==="text"&&!el.isVar&&<Field label={`Lebar Box — ${el.width||200}px`}><Sld value={el.width||200} min={20} max={CANVAS_W} onChange={v=>upd({width:v})}/></Field>}
      <Field label={`Rotasi — ${el.rotation||0}°`}><Sld value={el.rotation||0} min={-180} max={180} onChange={v=>upd({rotation:v})}/></Field>
      {el.type==="image"&&<Field label="Flip"><div style={{display:"flex",gap:6}}><button onClick={()=>upd({flipH:!el.flipH})} style={{flex:1,padding:"5px 0",...boolBtn(el.flipH,"#4A90D9")}}>↔ H</button><button onClick={()=>upd({flipV:!el.flipV})} style={{flex:1,padding:"5px 0",...boolBtn(el.flipV,"#9B59B6")}}>↕ V</button></div></Field>}
      <Div label="Tampilan"/>
      <Field label={`Opacity — ${Math.round((el.opacity||1)*100)}%`}><Sld value={el.opacity||1} min={0} max={1} step={0.01} onChange={v=>upd({opacity:v})}/></Field>
      <Field label={`Z-Index — ${el.zIndex||10}`}><div style={{display:"flex",gap:6,alignItems:"center"}}><Sld value={el.zIndex||10} min={1} max={50} onChange={v=>upd({zIndex:v})}/><button onClick={onFwd} style={S.micro}>↑</button><button onClick={onBwd} style={S.micro}>↓</button></div></Field>
      <Div label="Animasi"/>
      <Field label="Animasi"><select value={el.animation||"none"} onChange={e=>upd({animation:e.target.value})} style={{...S.inp,cursor:"pointer"}}>{ANIMATIONS.map(a=><option key={a.id} value={a.id}>{a.label}</option>)}</select></Field>
      {el.animation&&el.animation!=="none"&&(["sway","float","pulse","shimmer","bounce"].includes(el.animation)?<Field label={`Durasi — ${el.animDuration||4}s`}><Sld value={el.animDuration||4} min={0.5} max={12} step={0.5} onChange={v=>upd({animDuration:v})}/></Field>:<Field label={`Delay — ${el.animDelay||0}s`}><Sld value={el.animDelay||0} min={0} max={6} step={0.1} onChange={v=>upd({animDelay:v})}/></Field>)}
      <div style={{display:"flex",gap:6,marginTop:4}}>
        <button onClick={onDup} style={{flex:1,padding:"7px 0",background:"#181818",border:"1px solid #222",color:"#666",borderRadius:4,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif"}}>Duplikat</button>
        <button onClick={onDel} style={{flex:1,padding:"7px 0",background:"#1a0a0a",border:"1px solid #3a1515",color:"#c55",borderRadius:4,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif"}}>Hapus</button>
      </div>
    </div>
  );
}

// ─── UI Primitives ────────────────────────────────────────────────────────────
const boolBtn=(on,col="#7D9470")=>({background:on?"#1a2a1a":"#181818",border:`1px solid ${on?col:"#252525"}`,color:on?col:"#555",borderRadius:3,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif"});
function PLabel({children}){return<div style={{fontSize:10,letterSpacing:1.5,textTransform:"uppercase",color:"#444",fontWeight:700,fontFamily:"DM Sans,sans-serif",marginBottom:4}}>{children}</div>;}
function Div({label}){return<div style={{display:"flex",alignItems:"center",gap:8,margin:"4px 0"}}><div style={{fontSize:9,color:"#2e2e2e",letterSpacing:.8,textTransform:"uppercase",whiteSpace:"nowrap",fontFamily:"DM Sans,sans-serif"}}>{label}</div><div style={{flex:1,height:1,background:"#1a1a1a"}}/></div>;}
function Field({label,children}){return<div><div style={{fontSize:11,color:"#3a3a3a",marginBottom:3,letterSpacing:.2,fontFamily:"DM Sans,sans-serif"}}>{label}</div>{children}</div>;}
function Sld({value,min,max,step=1,onChange}){return<input type="range" value={value} min={min} max={max} step={step} onChange={e=>onChange(step<1?parseFloat(e.target.value):parseInt(e.target.value))} style={{width:"100%",cursor:"pointer",accentColor:"#C4973A"}}/>;}
function IBtn({children,onClick,danger}){return<button onClick={onClick} style={{padding:"2px 5px",background:"transparent",border:"none",color:danger?"#522":"#333",cursor:"pointer",fontSize:13,lineHeight:1,borderRadius:3,fontFamily:"DM Sans,sans-serif"}} onMouseEnter={e=>e.target.style.color=danger?"#f55":"#aaa"} onMouseLeave={e=>e.target.style.color=danger?"#522":"#333"}>{children}</button>;}
function Tbtn({children,onClick,col}){return<button onClick={onClick} style={{padding:"5px 11px",background:"#181818",border:"1px solid #222",color:col||"#777",borderRadius:4,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif",display:"flex",alignItems:"center",gap:4}}>{children}</button>;}

