                </div>
                <div style={{marginTop:8,fontSize:10,color:"#3a5a3a",fontFamily:"DM Sans,sans-serif"}}>
                  Extract lalu salin ke Flask: <code style={{color:"#6a9a6a"}}>projects/{slugify(projName)}/</code>
                </div>
              </>}
              <button onClick={onClose} style={{...S2.btn,marginTop:14,marginBottom:0,background:"#C4973A",color:"#000",border:"none"}}>Tutup</button>
            </div>
          )}

          {status==="err"&&(
            <div style={{padding:"16px",background:"#1a0d0d",border:"1px solid #3a1a1a",borderRadius:8}}>
              <div style={{color:"#f88",fontSize:13,fontFamily:"DM Sans,sans-serif",marginBottom:10}}>✗ Gagal</div>
              <div style={{fontSize:11,color:"#8a5a5a",fontFamily:"DM Sans,sans-serif",wordBreak:"break-word"}}>{msg}</div>
              <button onClick={()=>{setStatus("idle");setMsg("");}} style={{...S2.btn,marginTop:14,marginBottom:0,background:"#2a1a1a",color:"#c55",border:"1px solid #3a1515",fontSize:12}}>Coba Lagi</button>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

// ─── ProjectManager Modal ─────────────────────────────────────────────────────
function ProjectManager({sections,invData,projectId,projectName,onLoad,onClose}){
  const [ps,setPs]=useState(()=>getProjects());
  const [nm,setNm]=useState(projectName||"");
  const [msg,setMsg]=useState("");
  const fRef=useRef(null);
  const ref=()=>setPs(getProjects());
  const toast=m=>{setMsg(m);setTimeout(()=>setMsg(""),2200);};
  const handleSave=()=>{const n=nm.trim()||"Proyek Baru",pid=saveProject(projectId,n,sections,invData);if(pid){ref();onLoad(pid,n,sections,invData);toast("Tersimpan ✦");}};
  const handleNew=()=>{const n=nm.trim()||"Proyek Baru",pid=saveProject(null,n,sections,invData);if(pid){ref();onLoad(pid,n,sections,invData);toast("Proyek baru dibuat");}};
  const handleImp=e=>{const f=e.target.files?.[0];if(!f)return;const r=new FileReader();r.onload=ev=>importJSON(ev.target.result,(pid,n,s,d)=>{ref();toast(`Import: "${n}" berhasil`);});r.readAsText(f);e.target.value="";};
  return(
    <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,.85)",zIndex:9998,display:"flex",alignItems:"center",justifyContent:"center"}} onClick={e=>{if(e.target===e.currentTarget)onClose();}}>
      <div style={{background:"#111",border:"1px solid #222",borderRadius:8,width:480,maxWidth:"95vw",maxHeight:"80vh",display:"flex",flexDirection:"column",overflow:"hidden"}}>
        <div style={{padding:"14px 18px",borderBottom:"1px solid #1e1e1e",display:"flex",alignItems:"center"}}>
          <span style={{flex:1,fontWeight:700,fontSize:14,color:"#C4973A",fontFamily:"DM Sans,sans-serif"}}>📁 Manajemen Proyek</span>
          <button onClick={onClose} style={{background:"none",border:"none",color:"#555",cursor:"pointer",fontSize:20,lineHeight:1}}>✕</button>
        </div>
        <div style={{padding:"12px 18px",borderBottom:"1px solid #181818",display:"flex",gap:8}}>
          <input value={nm} onChange={e=>setNm(e.target.value)} placeholder="Nama proyek..." style={{flex:1,padding:"7px 10px",background:"#141414",border:"1px solid #2a2a2a",color:"#bbb",borderRadius:4,fontSize:12,outline:"none",fontFamily:"DM Sans,sans-serif"}}/>
          <button onClick={handleSave} style={{padding:"6px 12px",background:"#C4973A",border:"none",color:"#000",borderRadius:4,cursor:"pointer",fontSize:12,fontWeight:700,fontFamily:"DM Sans,sans-serif",flexShrink:0}}>💾 Simpan</button>
          <button onClick={handleNew} style={{padding:"6px 12px",background:"#1a2a1a",border:"1px solid #2a3a2a",color:"#7D9470",borderRadius:4,cursor:"pointer",fontSize:12,fontFamily:"DM Sans,sans-serif",flexShrink:0}}>+ Baru</button>
        </div>
        <div style={{flex:1,overflowY:"auto",padding:"6px 0"}}>
          {ps.length===0?<div style={{padding:"30px",textAlign:"center",color:"#333",fontSize:12,fontFamily:"DM Sans,sans-serif"}}>Belum ada proyek tersimpan.</div>:ps.slice().reverse().map(p=>(
            <div key={p.id} style={{display:"flex",alignItems:"center",gap:8,padding:"10px 18px",borderBottom:"1px solid #141414",background:p.id===projectId?"#181818":"transparent"}}>
              <div style={{flex:1,minWidth:0}}>
                <div style={{fontSize:13,color:p.id===projectId?"#C4973A":"#bbb",fontWeight:600,fontFamily:"DM Sans,sans-serif",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{p.name}</div>
                <div style={{fontSize:10,color:"#333",fontFamily:"DM Sans,sans-serif",marginTop:2}}>{p.updatedAt} · {(p.sections||[]).length} section</div>
              </div>
              <button onClick={()=>{onLoad(p.id,p.name,p.sections,p.invData);onClose();}} style={{padding:"4px 10px",background:"#1e2a1e",border:"1px solid #2a3a2a",color:"#7D9470",borderRadius:3,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif",flexShrink:0}}>Load</button>
              <button onClick={()=>exportJSON(p.name,p.sections,p.invData)} style={{padding:"4px 10px",background:"#1a1a2a",border:"1px solid #2a2a3a",color:"#5a7aaa",borderRadius:3,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif",flexShrink:0}}>JSON</button>
              <button onClick={()=>{if(confirm("Hapus proyek ini?")){deleteProject(p.id);ref();}}} style={{padding:"4px 8px",background:"transparent",border:"none",color:"#522",cursor:"pointer",fontSize:15,lineHeight:1,flexShrink:0}} onMouseEnter={e=>e.target.style.color="#f55"} onMouseLeave={e=>e.target.style.color="#522"}>×</button>
            </div>
          ))}
        </div>
        <div style={{padding:"10px 18px",borderTop:"1px solid #181818",display:"flex",gap:10,alignItems:"center"}}>
          <button onClick={()=>fRef.current?.click()} style={{padding:"6px 14px",background:"#181818",border:"1px solid #2a2a2a",color:"#666",borderRadius:4,cursor:"pointer",fontSize:11,fontFamily:"DM Sans,sans-serif"}}>⬆ Import JSON</button>
          <input ref={fRef} type="file" accept=".json" style={{display:"none"}} onChange={handleImp}/>
          {msg&&<span style={{fontSize:11,color:"#7D9470",fontFamily:"DM Sans,sans-serif"}}>{msg}</span>}
        </div>
      </div>
    </div>
  );
}
// ─── Main App ─────────────────────────────────────────────────────────────────
const _draft=loadDraft();
if(_draft.sections)_draft.sections.forEach(s=>s.elements?.forEach(el=>{if(el.id>_id)_id=el.id;}));

function App(){
  const [sections,setSections]=useState(()=>_draft.sections||initSections);
  const [activeId,setActiveId]=useState(()=>(_draft.sections?.[0]?.id)||1);
  const [selId,setSelId]=useState(null);
  const [drag,setDrag]=useState(null);
  const [scale,setScale]=useState(0.68);
  const [addMenu,setAddMenu]=useState(false);
  const [preview,setPreview]=useState(false);
  const [toast,setToast]=useState(null);
  const [tab,setTab]=useState("sections");
  const [rtab,setRtab]=useState("element");
  const [invData,setInvData]=useState(()=>_draft.invData||{});
  const [showFP,setShowFP]=useState(false);
  const [fpSearch,setFpSearch]=useState("");
  const [showData,setShowData]=useState(false);
  const [projId,setProjId]=useState(()=>_draft.projectId||null);
  const [projName,setProjName]=useState(()=>_draft.projectName||"Proyek Baru");
  const [showProj,setShowProj]=useState(false);
  const [showExport,setShowExport]=useState(false);
  const cwRef=useRef(null),upRef=useRef(null),bgRef=useRef(null);

  const actSec=sections.find(s=>s.id===activeId);
  const selEl=actSec?.elements.find(e=>e.id===selId);

  useEffect(()=>{saveDraft(sections,invData,projId,projName);},[sections,invData,projId,projName]);
  const showT=(m,type="ok")=>{setToast({m,type});setTimeout(()=>setToast(null),2400);};

  useEffect(()=>{
    const el=cwRef.current;if(!el)return;
    const ro=new ResizeObserver(()=>{const{width:w,height:h}=el.getBoundingClientRect();setScale(Math.min((w-80)/CANVAS_W,(h-80)/CANVAS_H,1));});
    ro.observe(el);return()=>ro.disconnect();
  },[preview]);

  useEffect(()=>{
    const gFonts=FONTS.filter(f=>!["Georgia","Times New Roman"].includes(f));
    const link=document.createElement("link");link.rel="stylesheet";link.href="https://fonts.googleapis.com/css2?"+gFonts.map(f=>`family=${f.replace(/ /g,"+")}:ital,wght@0,400;0,700;1,400`).join("&")+"&display=swap";document.head.appendChild(link);
  },[]);

  // Ops
  const addSec=p=>{const s={id:uid(),...p,elements:[],openInviteText:"Buka Undangan",openInviteStyle:{fontSize:16,color:"#C4973A",fontFamily:"Playfair Display"}};setSections(pr=>[...pr,s]);setActiveId(s.id);setSelId(null);setAddMenu(false);showT("Section ditambahkan");};
  const delSec=id=>{setSections(p=>{const n=p.filter(s=>s.id!==id);if(activeId===id&&n.length)setActiveId(n[0].id);return n;});setSelId(null);};
  const moveSec=(id,dir)=>{setSections(p=>{const a=[...p],i=a.findIndex(s=>s.id===id),t=i+dir;if(t<0||t>=a.length)return p;[a[i],a[t]]=[a[t],a[i]];return a;});};
  const updSec=(id,patch)=>setSections(p=>p.map(s=>s.id===id?{...s,...patch}:s));
  const addEl=el=>{setSections(p=>p.map(s=>s.id===activeId?{...s,elements:[...s.elements,el]}:s));setSelId(el.id);};
  const updEl=(id,patch)=>setSections(p=>p.map(s=>s.id===activeId?{...s,elements:s.elements.map(e=>e.id===id?{...e,...patch}:e)}:s));
  const delEl=id=>{setSections(p=>p.map(s=>s.id===activeId?{...s,elements:s.elements.filter(e=>e.id!==id)}:s));setSelId(null);};
  const dupEl=id=>{const el=actSec?.elements.find(e=>e.id===id);if(!el)return;const c={...el,id:uid(),x:el.x+16,y:el.y+16};setSections(p=>p.map(s=>s.id===activeId?{...s,elements:[...s.elements,c]}:s));setSelId(c.id);showT("Diduplikat");};
  const moveLayer=(id,dir)=>{setSections(p=>p.map(s=>{if(s.id!==activeId)return s;const a=[...s.elements],i=a.findIndex(e=>e.id===id),t=i+dir;if(t<0||t>=a.length)return s;[a[i],a[t]]=[a[t],a[i]];return{...s,elements:a.map((e,j)=>({...e,zIndex:j+1}))}}));};

  const handleUp=e=>{const files=[...(e.target.files||[])];files.forEach(f=>{const r=new FileReader();r.onload=ev=>addEl(makeImgEl(ev.target.result,f.name));r.readAsDataURL(f);});e.target.value="";showT(`${files.length} aset diupload`);};
  const handleBg=e=>{const f=e.target.files?.[0];if(!f)return;const r=new FileReader();r.onload=ev=>updSec(activeId,{bgImage:ev.target.result});r.readAsDataURL(f);e.target.value="";showT("BG diset");};
  const handleGallUp=(e,elId)=>{const files=[...(e.target.files||[])];const el=actSec?.elements.find(x=>x.id===elId),cur=el?.galleryImages||[];Promise.all(files.map(f=>new Promise(res=>{const r=new FileReader();r.onload=ev=>res(ev.target.result);r.readAsDataURL(f);}))).then(imgs=>{updEl(elId,{galleryImages:[...cur,...imgs]});showT(`${files.length} foto gallery`);});e.target.value="";};

  // Drag
  const onDown=(e,id)=>{e.stopPropagation();setSelId(id);const el=actSec.elements.find(x=>x.id===id);setDrag({id,sx:e.clientX,sy:e.clientY,ox:el.x,oy:el.y});};
  useEffect(()=>{if(!drag)return;const onM=e=>updEl(drag.id,{x:Math.round(drag.ox+(e.clientX-drag.sx)/scale),y:Math.round(drag.oy+(e.clientY-drag.sy)/scale)});const onU=()=>setDrag(null);window.addEventListener("mousemove",onM);window.addEventListener("mouseup",onU);return()=>{window.removeEventListener("mousemove",onM);window.removeEventListener("mouseup",onU);};},[drag,scale]);
  useEffect(()=>{const f=e=>{if(!selId)return;if(["INPUT","TEXTAREA","SELECT"].includes(e.target.tagName))return;const el=actSec?.elements.find(x=>x.id===selId);if(!el)return;const st=e.shiftKey?10:1;if(e.key==="ArrowLeft"){e.preventDefault();updEl(selId,{x:el.x-st});}if(e.key==="ArrowRight"){e.preventDefault();updEl(selId,{x:el.x+st});}if(e.key==="ArrowUp"){e.preventDefault();updEl(selId,{y:el.y-st});}if(e.key==="ArrowDown"){e.preventDefault();updEl(selId,{y:el.y+st});}if(e.key==="Delete"||e.key==="Backspace"){e.preventDefault();delEl(selId);}if((e.ctrlKey||e.metaKey)&&e.key==="d"){e.preventDefault();dupEl(selId);}};window.addEventListener("keydown",f);return()=>window.removeEventListener("keydown",f);},[selId,actSec,scale]);

  const exportHTML=()=>{const html=buildHTML(sections,invData),blob=new Blob([html],{type:"text/html"}),url=URL.createObjectURL(blob),a=document.createElement("a");a.href=url;a.download="undangan.html";a.click();URL.revokeObjectURL(url);showT("Export HTML berhasil 🎉");};
  const handleProjLoad=(pid,pn,ps,pd)=>{if(ps)ps.forEach(s=>s.elements?.forEach(el=>{if(el.id>_id)_id=el.id;}));setSections(ps||initSections);setInvData(pd||{});setProjId(pid);setProjName(pn||"Proyek Baru");setActiveId((ps||[])[0]?.id||1);setSelId(null);showT(`"${pn}" dimuat`);};

  // Canvas element renderer
  const renderEl=el=>{
    const isSel=selId===el.id,isW=el.type==="widget";
    const flipS=el.flipH?{transform:`rotate(${el.rotation||0}deg) scaleX(-1)`}:el.flipV?{transform:`rotate(${el.rotation||0}deg) scaleY(-1)`}:{transform:`rotate(${el.rotation||0}deg)`};
    const animS=(()=>{if(!el.animation||el.animation==="none")return{};const inf=["sway","float","pulse","shimmer","bounce"].includes(el.animation);return inf?{animation:`${el.animation} ${el.animDuration||4}s ease-in-out infinite`}:{animation:`${el.animation} .8s cubic-bezier(.16,1,.3,1) ${el.animDelay||0}s both`};})();
    const cs={position:"absolute",left:el.x,top:el.y,width:isW?el.width:(el.width||(el.type==="text"?200:150)),...(isW?{height:el.height}:{}),...flipS,opacity:el.opacity,zIndex:el.zIndex,cursor:"move",userSelect:"none",outline:isSel?"1.5px solid #C4973A":"1px solid transparent",outlineOffset:2,...animS};
    const PVARS=new Set(["inv.groom_photo_url","inv.bride_photo_url"]);
    return(
      <div key={el.id} onMouseDown={e=>onDown(e,el.id)} onClick={e=>{e.stopPropagation();setSelId(el.id);}} style={cs}>
        {el.type==="image"&&<img src={el.src} style={{width:"100%",display:"block",pointerEvents:"none"}} alt=""/>}
        {el.type==="text"&&(()=>{
          const acc=el.accent||"#C4973A";
          if(el.isVar&&PVARS.has(el.varKey)){const live=invData[el.varKey.replace("inv.","")],ex=DATA_VARS.find(v=>v.key===el.varKey)?.example||"",src=live||ex,h=el.height||el.width||150;return src?<img src={src} alt="" style={{width:"100%",height:h,objectFit:"cover",display:"block",borderRadius:el.borderRadius==="50%"?"50%":`${el.borderRadius||0}px`,pointerEvents:"none"}} onError={e2=>{e2.target.style.opacity=0.2;}}/>:<div style={{width:"100%",height:h,background:"#1a1412",display:"flex",alignItems:"center",justifyContent:"center",fontSize:10,color:"#555",fontFamily:"DM Sans,sans-serif",textAlign:"center",padding:8}}><span>🖼 {el.varKey}<br/><span style={{opacity:.5,fontSize:9}}>set di Data</span></span></div>;}
          const disp=el.isVar&&el.varKey?(invData[el.varKey.replace("inv.","")]||<span style={{opacity:.5}}>{DATA_VARS.find(v=>v.key===el.varKey)?.example||el.varKey}</span>):el.text;
          return<div style={{fontSize:el.fontSize||24,fontFamily:`'${el.fontFamily||"Playfair Display"}',serif`,color:el.color||"#fff",textAlign:el.align||"center",fontStyle:el.fontStyle||"normal",fontWeight:el.fontWeight||400,letterSpacing:el.letterSpacing||0,lineHeight:el.lineHeight||1.4,whiteSpace:"pre-wrap",wordBreak:"break-word",textShadow:el.shadow?`0 2px ${el.shadowBlur||8}px ${el.shadowColor||"rgba(0,0,0,.5)"}`:"none",pointerEvents:"none"}}>{disp}</div>;
        })()}
        {el.type==="widget"&&<WidgetCanvas el={el} invData={invData}/>}
        {isSel&&<>
          <div title="Resize lebar" onMouseDown={e=>{e.stopPropagation();const sw=e.clientX,ww=el.width||150;const mM=ev=>updEl(el.id,{width:Math.max(20,Math.round(ww+(ev.clientX-sw)/scale))});const mU=()=>{window.removeEventListener("mousemove",mM);window.removeEventListener("mouseup",mU);};window.addEventListener("mousemove",mM);window.addEventListener("mouseup",mU);}} style={{position:"absolute",right:-5,bottom:-5,width:12,height:12,background:"#C4973A",borderRadius:2,cursor:"se-resize",zIndex:1001}}/>
          {isW&&<div title="Resize tinggi" onMouseDown={e=>{e.stopPropagation();const sh=e.clientY,wh=el.height||400;const mM=ev=>updEl(el.id,{height:Math.max(80,Math.round(wh+(ev.clientY-sh)/scale))});const mU=()=>{window.removeEventListener("mousemove",mM);window.removeEventListener("mouseup",mU);};window.addEventListener("mousemove",mM);window.addEventListener("mouseup",mU);}} style={{position:"absolute",right:-5,bottom:10,width:12,height:12,background:"#7D9470",borderRadius:2,cursor:"s-resize",zIndex:1001}}/>}
          {!isW&&<>
            <div title="Rotasi" onMouseDown={e=>{e.stopPropagation();const rect=e.currentTarget.parentElement.getBoundingClientRect(),cx=rect.left+rect.width/2,cy=rect.top+rect.height/2,sa=Math.atan2(e.clientY-cy,e.clientX-cx)*180/Math.PI,sr=el.rotation||0;const mM=ev=>{const a=Math.atan2(ev.clientY-cy,ev.clientX-cx)*180/Math.PI;updEl(el.id,{rotation:Math.round(sr+(a-sa))});};const mU=()=>{window.removeEventListener("mousemove",mM);window.removeEventListener("mouseup",mU);};window.addEventListener("mousemove",mM);window.addEventListener("mouseup",mU);}} style={{position:"absolute",top:-18,left:"50%",transform:"translateX(-50%)",width:10,height:10,background:"#7D9470",borderRadius:"50%",cursor:"grab",zIndex:1001}}/>
            <div onClick={e=>{e.stopPropagation();updEl(el.id,{flipH:!el.flipH});}} style={{position:"absolute",top:-18,left:-5,width:10,height:10,background:"#4A90D9",borderRadius:2,cursor:"pointer",zIndex:1001,fontSize:8,display:"flex",alignItems:"center",justifyContent:"center",color:"#fff"}}>↔</div>
            <div onClick={e=>{e.stopPropagation();updEl(el.id,{flipV:!el.flipV});}} style={{position:"absolute",top:-18,right:-5,width:10,height:10,background:"#9B59B6",borderRadius:2,cursor:"pointer",zIndex:1001,fontSize:8,display:"flex",alignItems:"center",justifyContent:"center",color:"#fff"}}>↕</div>
          </>}
        </>}
      </div>
    );
  };

  if(preview){const html=buildHTML(sections,invData);return(
    <div style={{position:"fixed",inset:0,zIndex:9999,background:"#050505",display:"flex",flexDirection:"column"}}>
      <div style={{height:40,background:"#111",display:"flex",alignItems:"center",padding:"0 16px",gap:12,flexShrink:0,borderBottom:"1px solid #1a1a1a"}}>
        <span style={{color:"#C4973A",fontWeight:700,fontSize:13,fontFamily:"DM Sans,sans-serif"}}>👁 Preview</span>
        <div style={{flex:1}}/>
        <button onClick={()=>{setPreview(false);setShowExport(true);}} style={{padding:"5px 14px",background:"#C4973A",border:"none",color:"#000",borderRadius:3,cursor:"pointer",fontSize:12,fontWeight:700,fontFamily:"DM Sans,sans-serif"}}>⬇ Export</button>
        <button onClick={()=>setPreview(false)} style={{padding:"5px 14px",background:"#1e1e1e",border:"1px solid #333",color:"#aaa",borderRadius:3,cursor:"pointer",fontSize:12,fontFamily:"DM Sans,sans-serif"}}>✕ Tutup</button>
      </div>
      <div style={{flex:1,display:"flex",alignItems:"center",justifyContent:"center",overflow:"hidden",background:"#080808"}}>
        <div style={{width:390,height:"calc(100vh - 100px)",maxHeight:844,borderRadius:36,boxShadow:"0 0 0 8px #1a1a1a,0 32px 80px rgba(0,0,0,.9)",overflow:"hidden",flexShrink:0,position:"relative"}}>
          <div style={{position:"absolute",top:0,left:"50%",transform:"translateX(-50%)",width:120,height:28,background:"#1a1a1a",borderRadius:"0 0 16px 16px",zIndex:10}}/>
          <iframe srcDoc={html} style={{width:"100%",height:"100%",border:"none"}} title="preview"/>
        </div>
      </div>
    </div>
  );}

  return(
    <div style={S.root}>
      {toast&&<div style={{position:"fixed",bottom:20,left:"50%",transform:"translateX(-50%)",background:toast.type==="err"?"#2a0e0e":"#1e2a1e",border:`1px solid ${toast.type==="err"?"#c55":"#7D9470"}`,color:toast.type==="err"?"#f88":"#aed6a0",padding:"8px 20px",borderRadius:6,fontSize:12,zIndex:9999,animation:"toast-in .3s ease",fontFamily:"DM Sans,sans-serif",whiteSpace:"nowrap"}}>{toast.m}</div>}
      {showProj&&<ProjectManager sections={sections} invData={invData} projectId={projId} projectName={projName} onLoad={handleProjLoad} onClose={()=>setShowProj(false)}/>}
      {showExport&&<ExportModal sections={sections} invData={invData} projName={projName} buildHTMLFn={buildHTML} onClose={()=>setShowExport(false)}/>}
      {showData&&<DataModal invData={invData} setInvData={setInvData} onClose={()=>setShowData(false)}/>}
      {showFP&&selEl?.type==="text"&&<FontPicker current={selEl.fontFamily} search={fpSearch} setSearch={setFpSearch} onPick={f=>{updEl(selEl.id,{fontFamily:f});setShowFP(false);}} onClose={()=>setShowFP(false)}/>}

      {/* TOPBAR */}
      <div style={S.topbar}>
        <span style={S.logo}>habarkita</span>
        <div style={{width:1,height:20,background:"#1e1e1e"}}/>
        <span style={{fontSize:11,color:"#3a3a3a",fontFamily:"DM Sans",maxWidth:150,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{projName}</span>
        <div style={{flex:1}}/>
        <Tbtn onClick={()=>setShowProj(true)} col="#7D9470">📁 Proyek</Tbtn>
        <Tbtn onClick={()=>{const pid=saveProject(projId,projName,sections,invData);if(pid){setProjId(pid);showT("Tersimpan ✦");}}} col="#7D9470">💾 Simpan</Tbtn>
        <Tbtn onClick={()=>setShowData(true)} col="#5a7aaa">📋 Data</Tbtn>
        <Tbtn onClick={()=>setPreview(true)} col="#888">👁 Preview</Tbtn>
        <button onClick={()=>setShowExport(true)} style={{...S.btnP,padding:"5px 16px",fontSize:12}}>⬇ Export</button>
      </div>

      {/* BODY */}
      <div style={S.body}>
        {/* LEFT */}
        <div style={S.left}>
          <div style={{display:"flex",borderBottom:"1px solid #161616",flexShrink:0}}>
            {[["sections","Sections"],["assets","Assets"]].map(([k,l])=>(
              <button key={k} onClick={()=>setTab(k)} style={{flex:1,padding:"8px 0",background:"none",border:"none",color:tab===k?"#C4973A":"#333",borderBottom:`2px solid ${tab===k?"#C4973A":"transparent"}`,cursor:"pointer",fontSize:10,letterSpacing:.8,textTransform:"uppercase",fontWeight:600,fontFamily:"DM Sans,sans-serif"}}>{l}</button>
            ))}
          </div>
