let wl=false,wAcc=0;
document.addEventListener('wheel',e=>{if(coverVisible()||navLock)return;wAcc+=e.deltaY;if(wl)return;if(Math.abs(wAcc)<80)return;const dir=wAcc>0?1:-1;wAcc=0;wl=true;safeGoTo(cur+dir);setTimeout(()=>{wl=false;wAcc=0;},900);},{passive:true});
document.addEventListener('keydown',e=>{if(coverVisible())return;if(e.key==='ArrowDown'||e.key==='PageDown')safeGoTo(cur+1);if(e.key==='ArrowUp'||e.key==='PageUp')safeGoTo(cur-1);});
function openInvitation(){const c=document.getElementById('cover-screen');if(!c)return;c.style.opacity='0';c.style.pointerEvents='none';navLock=true;wAcc=0;setTimeout(()=>{c.style.display='none';dotsEl.style.display='flex';goTo(0);},700);setTimeout(()=>{navLock=false;wAcc=0;},1600);}
function updateCountdown(){const t=new Date(inv.countdown_date)-new Date();if(isNaN(t)||t<=0){['cd-days','cd-hours','cd-mins','cd-secs'].forEach(k=>{const e=document.getElementById(k);if(e)e.textContent='00';});return;}const d=Math.floor(t/86400000),h=Math.floor(t%86400000/3600000),m=Math.floor(t%3600000/60000),s=Math.floor(t%60000/1000),pad=n=>String(n).padStart(2,'0');[['cd-days',d],['cd-hours',h],['cd-mins',m],['cd-secs',s]].forEach(([id,v])=>{const e=document.getElementById(id);if(e)e.textContent=pad(v);});}
if(document.querySelector('.section')){updateCountdown();setInterval(updateCountdown,1000);}
let bgmPlaying=false;
function toggleBGM(){const a=document.getElementById('bgm');if(!a)return;bgmPlaying?(a.pause(),document.getElementById('bgm-btn').innerHTML='&#9834;',bgmPlaying=false):(a.play(),document.getElementById('bgm-btn').innerHTML='&#9646;&#9646;',bgmPlaying=true);}
const gbStore={};
function submitRSVP(id){const n=document.getElementById('rn-'+id)?.value?.trim(),g=document.getElementById('rg-'+id)?.value,a=document.getElementById('ra-'+id)?.value,m=document.getElementById('rm-'+id)?.value?.trim();if(!n||!a){alert('Mohon isi nama dan konfirmasi kehadiran.');return;}const f=document.getElementById('rsvp-form-'+id),ok=document.getElementById('rsvp-ok-'+id);if(f)f.style.display='none';if(ok)ok.style.display='block';if(m&&n){if(!gbStore._global)gbStore._global=[];gbStore._global.unshift({n,m,a});document.querySelectorAll('[id^="gb-list-"]').forEach(list=>{const wid=list.id.replace('gb-list-','');renderGB(wid);});}}
function renderGB(id){const list=document.getElementById('gb-list-'+id);if(!list)return;const items=gbStore._global||[];const acc=list.closest('[style*="position:absolute"]')?.style?.getPropertyValue('--acc')||'#C4973A';list.innerHTML=items.length?items.map(g=>'<div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:4px;padding:12px;margin-bottom:6px;"><div style="font-weight:600;font-size:13px;color:#C4973A;margin-bottom:3px;">'+g.n+(g.a==='hadir'?' ✓':'')+'</div><div style="font-size:12px;color:#888;line-height:1.5;">'+g.m+'</div></div>').join(''):'<div style="color:#444;text-align:center;font-size:12px;padding:16px;font-family:\'DM Sans\',sans-serif;">Belum ada ucapan</div>';}
function openLightbox(src,id){const lb=document.getElementById('lb-'+id),img=document.getElementById('lb-img-'+id);if(!lb||!img)return;img.src=src;lb.style.display='flex';}`;

  return `<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<title>Undangan ${groom} &amp; ${bride}</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;height:100%;overflow:hidden;-webkit-user-select:none;user-select:none;background:#000;}
