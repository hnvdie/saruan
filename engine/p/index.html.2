                <div style={{position:"absolute",top:8,left:8,fontSize:8,letterSpacing:1.5,textTransform:"uppercase",color:"rgba(255,255,255,0.1)",zIndex:999,fontFamily:"DM Sans,sans-serif"}}>{actSec.type}</div>
                {actSec.elements.map(renderEl)}
                {actSec.type==="cover"&&(()=>{const ois=actSec.openInviteStyle||{},posB=ois.posBottom!==undefined?ois.posBottom:80,posL=ois.posLeft,cen=posL===null||posL===undefined;return(
                  <div style={{position:"absolute",...(cen?{bottom:posB,left:0,right:0,textAlign:"center"}:{bottom:posB,left:posL}),zIndex:50,cursor:"move"}} title="Drag pindah · Edit di tab Sec"
                    onMouseDown={e=>{e.stopPropagation();const sy=e.clientY,sx=e.clientX,sb=posB,sl=posL!==null&&posL!==undefined?posL:CANVAS_W/2-60;const mM=ev=>{const nb=Math.round(Math.max(0,Math.min(CANVAS_H-40,sb-(ev.clientY-sy)/scale)));const nl=Math.round(sl+(ev.clientX-sx)/scale);updSec(actSec.id,{openInviteStyle:{...ois,posBottom:nb,posLeft:nl}});};const mU=()=>{window.removeEventListener("mousemove",mM);window.removeEventListener("mouseup",mU);};window.addEventListener("mousemove",mM);window.addEventListener("mouseup",mU);}}>
                    <div style={{display:"inline-block",padding:`${ois.paddingV||12}px ${ois.paddingH||30}px`,border:`${ois.borderWidth||1}px solid ${ois.color||"#C4973A"}`,color:ois.color||"#C4973A",background:ois.bgColor||"transparent",fontFamily:`'${ois.fontFamily||"Playfair Display"}',serif`,fontSize:ois.fontSize||16,borderRadius:ois.borderRadius||2,letterSpacing:1.5,textTransform:"uppercase",userSelect:"none"}}>
                      {actSec.openInviteText||"Buka Undangan"}
                    </div>
                  </div>
                );})()}
              </div>
              <div style={{fontSize:9,color:"#222",fontFamily:"DM Sans,sans-serif"}}>{selEl?"↑↓←→ geser · Shift×10 · Del hapus · Ctrl+D duplikat":"Klik elemen · Drag pindah"}</div>
            </div>
          ):<div style={{color:"#222",fontSize:13,fontFamily:"DM Sans,sans-serif"}}>Pilih section</div>}
        </div>

        {/* RIGHT */}
        <div style={S.right}>
          <div style={{display:"flex",borderBottom:"1px solid #1a1a1a",marginBottom:8,flexShrink:0}}>
            {[["element","El"],["section","Sec"],["data","Data"]].map(([k,l])=>(
              <button key={k} onClick={()=>setRtab(k)} style={{flex:1,padding:"7px 0",background:"none",border:"none",color:rtab===k?"#C4973A":"#333",borderBottom:`2px solid ${rtab===k?"#C4973A":"transparent"}`,cursor:"pointer",fontSize:10,letterSpacing:.8,textTransform:"uppercase",fontWeight:600,fontFamily:"DM Sans,sans-serif"}}>{l}</button>
            ))}
          </div>
          {rtab==="element"&&(selEl?(selEl.type==="widget"?<WidgetProps el={selEl} upd={p=>updEl(selEl.id,p)} onDel={()=>delEl(selEl.id)} onDup={()=>dupEl(selEl.id)} onGallery={handleGallUp}/>:<ElProps el={selEl} upd={p=>updEl(selEl.id,p)} onDel={()=>delEl(selEl.id)} onDup={()=>dupEl(selEl.id)} onFwd={()=>{const e=actSec?.elements.find(x=>x.id===selId);if(e)updEl(selId,{zIndex:e.zIndex+1});}} onBwd={()=>{const e=actSec?.elements.find(x=>x.id===selId);if(e)updEl(selId,{zIndex:Math.max(1,e.zIndex-1)});}} invData={invData} onFP={()=>setShowFP(true)}/>):<div style={{padding:"20px 0",color:"#333",fontSize:12,textAlign:"center",lineHeight:1.8,fontFamily:"DM Sans,sans-serif"}}>Pilih elemen di canvas<br/>atau tambah di Assets.</div>)}
          {rtab==="section"&&actSec&&<SecProps sec={actSec} upd={p=>updSec(actSec.id,p)} onBg={()=>bgRef.current?.click()} onClrBg={()=>updSec(actSec.id,{bgImage:undefined})}/>}
          {rtab==="data"&&<div style={{display:"flex",flexDirection:"column",gap:10,paddingTop:4}}>
            <div style={{fontSize:10,letterSpacing:1.5,textTransform:"uppercase",color:"#444",fontWeight:700,fontFamily:"DM Sans,sans-serif"}}>📋 Data Undangan</div>
            {DATA_VARS.slice(0,8).map(v=><div key={v.key}><div style={{fontSize:10,color:"#3a3a3a",marginBottom:2,fontFamily:"DM Sans,sans-serif"}}>{v.label}</div><input value={invData[v.key.replace("inv.","")]||""} onChange={e=>setInvData(p=>({...p,[v.key.replace("inv.","")]:e.target.value}))} placeholder={v.example} style={{...S.inp,fontSize:11}}/></div>)}
            <button onClick={()=>setShowData(true)} style={{...S.btnS,fontSize:11,padding:"6px 0"}}>Lihat Semua Data →</button>
          </div>}
        </div>
      </div>

      <input ref={upRef} type="file" accept="image/*" multiple style={{display:"none"}} onChange={handleUp}/>
      <input ref={bgRef} type="file" accept="image/*" style={{display:"none"}} onChange={handleBg}/>
      <style>{`@keyframes toast-in{from{opacity:0;transform:translateX(-50%) translateY(8px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}@keyframes sway{0%,100%{transform:rotate(0)}50%{transform:rotate(6deg)}}@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}@keyframes pulse{0%,100%{opacity:1}50%{opacity:.45}}@keyframes shimmer{0%{filter:brightness(1)}50%{filter:brightness(1.5)}100%{filter:brightness(1)}}@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}@keyframes fade-in{from{opacity:0}to{opacity:1}}@keyframes zoom-in{from{opacity:0;transform:scale(.85)}to{opacity:1;transform:scale(1)}}`}</style>
    </div>
  );
}
