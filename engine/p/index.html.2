t-size:12px;color:#888;">a/n {{ gift.ewallet_name }}</div><button onclick="(function(b){var t=document.getElementById('acc-{{ loop.index }}');navigator.clipboard&&navigator.clipboard.writeText(t.textContent.trim());b.textContent='Disalin ✓';setTimeout(()=>b.textContent='Salin Nomor',2000);})(this)" style="margin-top:12px;padding:7px 20px;background:transparent;border:1px solid ${acc}66;color:${acc};font-family:'DM Sans',sans-serif;font-size:11px;border-radius:${r}px;cursor:pointer;">Salin Nomor</button>{%- endif %}</div>{%- endfor %}</div>`;}
