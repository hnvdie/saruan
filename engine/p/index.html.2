// ─── ExportModal ──────────────────────────────────────────────────────────────
function ExportModal({sections,invData,projName,onClose,buildHTMLFn}){
  const [status,setStatus]=useState("idle"); // idle | checking | saving | done | err
  const [msg,setMsg]=useState("");
  const [result,setResult]=useState(null);
  const [serverUp,setServerUp]=useState(null);

  useEffect(()=>{
    checkServer().then(up=>{setServerUp(up);});
  },[]);

  const progress=(m)=>setMsg(m);

  const doExport=async(mode)=>{
    setStatus("saving");setMsg("Membangun HTML...");
    try{
      const html=buildHTMLFn(sections,invData);
      let res;
      if(mode==="server"){
        res=await exportToServer(projName,sections,invData,html,progress);
        setResult({mode:"server",...res});
      } else {
        res=await exportAsZip(projName,sections,invData,html,progress);
        setResult({mode:"zip",...res});
      }
      setStatus("done");
    }catch(e){
      setStatus("err");setMsg("Error: "+e.message);
    }
  };

  const S2={
    overlay:{position:"fixed",inset:0,background:"rgba(0,0,0,.88)",zIndex:9998,display:"flex",alignItems:"center",justifyContent:"center"},
    box:{background:"#111",border:"1px solid #222",borderRadius:10,width:460,maxWidth:"95vw",overflow:"hidden"},
    head:{padding:"14px 18px",borderBottom:"1px solid #1e1e1e",display:"flex",alignItems:"center"},
    body:{padding:"20px 18px"},
    btn:{padding:"12px 0",border:"none",borderRadius:6,cursor:"pointer",fontSize:13,fontWeight:700,fontFamily:"DM Sans,sans-serif",width:"100%",marginBottom:10},
  };

  return(
    <div style={S2.overlay} onClick={e=>{if(e.target===e.currentTarget)onClose();}}>
      <div style={S2.box}>
        <div style={S2.head}>
          <span style={{flex:1,fontWeight:700,fontSize:14,color:"#C4973A",fontFamily:"DM Sans,sans-serif"}}>⬇ Export Proyek</span>
          <button onClick={onClose} style={{background:"none",border:"none",color:"#555",cursor:"pointer",fontSize:20,lineHeight:1}}>✕</button>
        </div>
        <div style={S2.body}>
          {/* Project name */}
          <div style={{marginBottom:16,padding:"10px 12px",background:"#0d0d0d",borderRadius:6,border:"1px solid #1e1e1e"}}>
            <div style={{fontSize:10,color:"#444",letterSpacing:1,textTransform:"uppercase",fontFamily:"DM Sans,sans-serif",marginBottom:4}}>Proyek</div>
            <div style={{fontSize:15,color:"#C4973A",fontFamily:"Playfair Display,serif"}}>{projName}</div>
            <div style={{fontSize:10,color:"#333",fontFamily:"DM Sans,sans-serif",marginTop:2}}>theme_id: <span style={{color:"#555"}}>{slugify(projName)}</span></div>
          </div>

          {/* Server status */}
          <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:16,fontSize:11,fontFamily:"DM Sans,sans-serif"}}>
            <div style={{width:8,height:8,borderRadius:"50%",background:serverUp===null?"#555":serverUp?"#7D9470":"#c55",flexShrink:0,boxShadow:serverUp?"0 0 6px #7D9470":undefined}}/>
            <span style={{color:serverUp===null?"#444":serverUp?"#7D9470":"#c55"}}>
              {serverUp===null?"Mengecek server...":serverUp?"Server aktif di localhost:8765":"Server tidak aktif (gunakan ZIP)"}
            </span>
          </div>

          {status==="idle"&&<>
            {/* Option 1: Save to server */}
            <button onClick={()=>doExport("server")} disabled={!serverUp} style={{...S2.btn,background:serverUp?"#1a2a1a":"#111",color:serverUp?"#9CD889":"#2a2a2a",border:`1px solid ${serverUp?"#2a4a2a":"#1e1e1e"}`}}>
              💾 Simpan ke Folder projects/
              {serverUp&&<div style={{fontSize:10,fontWeight:400,marginTop:3,color:"#6a8a6a"}}>projects/{slugify(projName)}/ — HTML + JSON + semua aset</div>}
            </button>

            {/* Option 2: Download ZIP */}
            <button onClick={()=>doExport("zip")} style={{...S2.btn,background:"#1a1a2a",color:"#7a9aDD",border:"1px solid #2a2a3a"}}>
              📦 Download sebagai ZIP
              <div style={{fontSize:10,fontWeight:400,marginTop:3,color:"#5a6a8a"}}>Bisa dipakai tanpa server · HTML + aset terpisah</div>
            </button>

            {/* Option 3: Export draft JSON */}
            <button onClick={()=>{exportJSON(projName,sections,invData);onClose();}} style={{...S2.btn,background:"#141414",color:"#555",border:"1px solid #1e1e1e",fontSize:12}}>
              📋 Export Draft JSON
              <div style={{fontSize:10,fontWeight:400,marginTop:3,color:"#333"}}>Simpan state editor — bisa di-import lagi nanti</div>
            </button>
          </>}

          {status==="saving"&&(
            <div style={{textAlign:"center",padding:"30px 0"}}>
              <div style={{fontSize:24,marginBottom:12}}>⏳</div>
              <div style={{color:"#C4973A",fontSize:13,fontFamily:"DM Sans,sans-serif"}}>{msg}</div>
            </div>
          )}

          {status==="done"&&result&&(
            <div style={{padding:"16px",background:"#0d1a0d",border:"1px solid #1a3a1a",borderRadius:8}}>
              <div style={{color:"#9CD889",fontSize:15,fontFamily:"DM Sans,sans-serif",fontWeight:700,marginBottom:10}}>✓ Berhasil!</div>
              {result.mode==="server"&&<>
                <div style={{fontSize:11,color:"#5a8a5a",fontFamily:"DM Sans,sans-serif",lineHeight:2}}>
                  📄 {result.structure?.html}<br/>
