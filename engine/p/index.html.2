        <div style={{display:"flex",gap:8,alignItems:"center"}}>
          <input type="color" value={sec.bg?.startsWith("#")?sec.bg:"#000000"} onChange={e=>upd({bg:e.target.value})} style={{width:36,height:28,border:"none",background:"none",cursor:"pointer",padding:0,borderRadius:4}}/>
          <input value={sec.bg} onChange={e=>upd({bg:e.target.value})} style={{...S.inp,flex:1,fontFamily:"monospace",fontSize:11}} placeholder="#000000"/>
        </div>
      </Field>
      <Field label="Background Foto">
